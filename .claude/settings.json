{
  "extraKnownMarketplaces": {
    "ecology": {
      "source": {
        "source": "github",
        "repo": "esassoc/ecology"
      }
    }
  },
  "enabledPlugins": {
    "spoke-kit@ecology": true
  },
  "hooks": {
