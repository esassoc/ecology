      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/onboarding-share-reminder.mjs\""
          }
        ]
      }
    ]
  }
}
