---
<esa-button-toggle id="theme-switcher" size="sm" aria-label="Preview theme"></esa-button-toggle>

<script>
  import '@esa/ecology/esa-button-toggle';

  const KEY = 'esa-theme';
  const root = document.documentElement;
  const el = document.querySelector('#theme-switcher') as any;
  if (!el) throw new Error('ThemeSwitcher: #theme-switcher not found');

  const themes = ['default', 'beacon', 'qanat'];
  el.options = themes.map((t) => ({ label: t, value: t }));

  const saved = localStorage.getItem(KEY) || 'default';
  root.setAttribute('data-theme', saved);
  el.value = saved;

  el.addEventListener('change', (e: CustomEvent) => {
    const t = e.detail.value;
    root.setAttribute('data-theme', t);
    localStorage.setItem(KEY, t);
  });
</script>
