---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { withBase } from '@esa/docs/base';

const patterns = [
  {
    slug: 'app-shell',
    name: 'App shell',
    desc: 'Top app bar + sidebar navigation + content area — the chrome every prototype app starts from.',
    from: 'Proven in beacon-design and biochar-design.',
  },
  {
    slug: 'list-filters',
    name: 'List + filters',
    desc: 'Filter bar, result cards, pagination, and the empty state — the workhorse data view.',
    from: 'Proven in cb-fish search and the beacon requirement tracker.',
  },
  {
    slug: 'record-detail',
    name: 'Record detail',
    desc: 'Record header with status, tabbed sections, key-value facts, and a side-panel editor.',
    from: 'Proven in the beacon requirement tracker.',
  },
  {
    slug: 'form-section',
    name: 'Form section',
    desc: 'Labeled fields, helper and error states, and the action row — composed, not hand-rolled.',
    from: 'The form-control idiom every spoke uses.',
  },
];
---
<DocsLayout title="Pattern Library — Ecology" activeHref="/patterns">
  <nav class="crumbs"><a href={withBase('/')}>Ecology</a> <span>/</span> <span>Patterns</span></nav>
  <h1>Pattern Library</h1>
  <p class="lede">The component library gives you the parts; patterns give you the <em>compositions</em> — page archetypes assembled from <code>esa-*</code> legos, live and themeable. Start a screen from a pattern and fill it with your content: this is the level non-developers compose at, and the level <code>/new-prototype</code> reaches for first.</p>

  <div class="pl-grid">
    {patterns.map((p) => (
      <a class="pl-card" href={withBase(`/patterns/${p.slug}`)}>
        <h2>{p.name}</h2>
        <p>{p.desc}</p>
        <span class="pl-from">{p.from}</span>
        <span class="pl-go">View the pattern →</span>
      </a>
    ))}
  </div>

  <p class="pl-note">Each pattern is built only from documented components under the hub's default theme — switch the theme and the whole pattern re-skins, which is the point. Patterns are promoted from spokes once they prove out; if a composition you keep rebuilding isn't here, that's a <code>/request-lego</code>.</p>
</DocsLayout>

<style>
  .pl-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: var(--spacing-400); margin: var(--spacing-500) 0; }
  .pl-card { display: flex; flex-direction: column; gap: var(--spacing-200); border: 1px solid var(--color-border); border-radius: 12px; padding: var(--spacing-500); transition: border-color var(--transition-fast); }
  .pl-card:hover { border-color: var(--color-primary); }
  .pl-card h2 { margin: 0; font-size: 1.2rem; }
  .pl-card p { margin: 0; color: var(--color-text-secondary); }
  .pl-from { color: var(--color-text-muted); font-size: 0.9rem; }
  .pl-go { color: var(--color-text-link); font-weight: 500; }
  .pl-note { color: var(--color-text-secondary); max-width: 70ch; }
</style>
