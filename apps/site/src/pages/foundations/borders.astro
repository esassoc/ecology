<script>
  // Drag the nested-composition background image via pointer + transform, so it
  // can be moved under the cards to preview shadow/ring tinting over color.
  for (const img of document.querySelectorAll('.nest-bg')) {
    let originX = 0, originY = 0, startX = 0, startY = 0, dragging = false;
    img.addEventListener('pointerdown', (e) => {
      dragging = true;
      startX = e.clientX; startY = e.clientY;
      const m = new DOMMatrixReadOnly(getComputedStyle(img).transform);
      originX = m.m41; originY = m.m42;
      img.setPointerCapture(e.pointerId);
      e.preventDefault();
    });
    img.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      img.style.transform = `translate(${originX + e.clientX - startX}px, ${originY + e.clientY - startY}px)`;
    });
    const end = () => { dragging = false; };
    img.addEventListener('pointerup', end);
    img.addEventListener('pointercancel', end);
  }

  // Levers playground — compute border + box-shadow from each panel's controls.
  // Per elevation step: ring/contact alpha + ambient alpha (a single scale).
  const RING = { 0: 0.03, 1: 0.04, 2: 0.06, 3: 0.08, 4: 0.10, 5: 0.12 };
  const AMB  = { 0: 0.015, 1: 0.02, 2: 0.04, 3: 0.06, 4: 0.08, 5: 0.10 };
  function pgCompute(cfg) {
    const ringA = RING[+cfg.elevation], ambA = AMB[+cfg.elevation];
    let border = 'none';
    const shadow = [];
    if (cfg.edge === 'border') {
      const n = +cfg.elevation;
      // Rung by elevation: 0–1 light, 2–3 normal, 4–5 strong.
      const rung = n <= 1 ? 'light' : n <= 3 ? 'normal' : 'strong';
      const base = rung === 'normal' ? '--color-border' : `--color-border-${rung}`;
      // Same step, rendered as the solid token or the alpha token of that step.
      const varName = cfg.borderColor === 'alpha' ? `${base}-a` : base;
      border = `1px solid var(${varName})`;
    } else if (cfg.edge === 'ring') {
      shadow.push(`0px 0px 0px 1px rgba(0, 0, 0, ${ringA})`);
    }
    if (cfg.lift === 'single') {
      shadow.push(`0px 2px 8px 0px rgba(0, 0, 0, ${ambA})`);
    } else if (cfg.lift === 'layered') {
      shadow.push(`0px 1px 2px -1px rgba(0, 0, 0, ${ringA})`, `0px 2px 4px 0px rgba(0, 0, 0, ${ambA})`);
    }
    return { border, boxShadow: shadow.length ? shadow.join(', ') : 'none' };
  }
  for (const panel of document.querySelectorAll('.pg-panel')) {
    const preview = panel.querySelector('[data-preview]');
    const readout = panel.querySelector('[data-readout]');
    const apply = () => {
      const cfg = {};
      for (const input of panel.querySelectorAll('input[type="radio"]:checked')) {
        cfg[input.name.split('-').slice(1).join('-')] = input.value;
      }
      const { border, boxShadow } = pgCompute(cfg);
      preview.style.border = border;
      preview.style.boxShadow = boxShadow;
      const edgeNote = cfg.edge === 'border' ? ` (${cfg.borderColor})` : '';
      readout.textContent =
        `elevation ${cfg.elevation} · edge ${cfg.edge}${edgeNote} · lift ${cfg.lift}\n` +
        `border: ${border};\nbox-shadow: ${boxShadow};`;
    };
    panel.addEventListener('change', apply);
    apply();
  }
  const pg = document.querySelector('.pg');
  if (pg) {
    const setActive = (btn) => {
      for (const b of btn.closest('.pg-backdrops').querySelectorAll('button')) b.classList.toggle('is-active', b === btn);
    };
    const colorpick = pg.querySelector('[data-colorpick]');
    const bordertokens = [...pg.querySelectorAll('[data-bordertoken]')];
    // Card/backdrop color steps use the picked hue. The border-token ladder uses
    // that same hue — except when the card is white, where it uses the gray ramp.
    const syncColors = () => {
      const hue = colorpick ? colorpick.value : 'grass';
      for (const step of [1, 2, 3, 4, 5, 9, 10]) pg.style.setProperty(`--pg-c${step}`, `var(--color-${hue}-${step})`);
      const borderHue = pg.dataset.card === 'white' ? 'gray' : hue;
      for (const sel of bordertokens) {
        const base = sel.dataset.bordertoken === 'normal' ? '--color-border' : `--color-border-${sel.dataset.bordertoken}`;
        // Solid + alpha companion of the SAME step (Radix ships both: -N and -a-N).
        pg.style.setProperty(base, `var(--color-${borderHue}-${sel.value})`);
        pg.style.setProperty(`${base}-a`, `var(--color-${borderHue}-a-${sel.value})`);
      }
    };
    // On a saturated card fill (color-9/10) an alpha edge is meaningless — disable
    // the border + ring edge options and fall back to 'none'.
    const syncEdgeOptions = () => {
      const filled = pg.dataset.card === 'color-9' || pg.dataset.card === 'color-10';
      for (const panel of pg.querySelectorAll('.pg-panel')) {
        const name = `${panel.dataset.panel}-edge`;
        let bumped = false;
        for (const val of ['border', 'ring']) {
          const input = panel.querySelector(`input[name="${name}"][value="${val}"]`);
          if (!input) continue;
          input.disabled = filled;
          if (filled && input.checked) {
            panel.querySelector(`input[name="${name}"][value="none"]`).checked = true;
            bumped = true;
          }
        }
        if (bumped) panel.dispatchEvent(new Event('change', { bubbles: true }));
      }
    };
    for (const btn of pg.querySelectorAll('.pg-backdrops button[data-bg]')) {
      btn.addEventListener('click', () => { pg.dataset.bg = btn.dataset.bg; setActive(btn); });
    }
    for (const btn of pg.querySelectorAll('.pg-backdrops button[data-card]')) {
      btn.addEventListener('click', () => { pg.dataset.card = btn.dataset.card; setActive(btn); syncEdgeOptions(); syncColors(); });
    }
    if (colorpick) colorpick.addEventListener('change', syncColors);
    for (const sel of bordertokens) sel.addEventListener('change', syncColors);
    syncEdgeOptions();
    syncColors();
  }
</script>
