---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { withBase } from '@esa/docs/base';
import Section from '@esa/docs/Section.astro';

const elevation = [
  { token: '--elevation-1', primitive: '--shadow-50',  role: 'Resting lift — always-visible surfaces' },
  { token: '--elevation-2', primitive: '--shadow-100', role: 'Cards, list items' },
  { token: '--elevation-3', primitive: '--shadow-200', role: 'Raised cards, hover state' },
  { token: '--elevation-4', primitive: '--shadow-300', role: 'Dropdowns, popovers, menus' },
  { token: '--elevation-5', primitive: '--shadow-400', role: 'Modals, dialogs' },
];


const zIndex = [
  { token: '--z-dropdown', value: '50', role: 'Menus, comboboxes' },
  { token: '--z-sidebar', value: '100', role: 'App sidebar' },
  { token: '--z-header', value: '200', role: 'Sticky header / topbar' },
  { token: '--z-modal-backdrop', value: '300', role: 'Dialog scrim' },
  { token: '--z-modal', value: '400', role: 'Dialog surface' },
  { token: '--z-toast', value: '500', role: 'Toasts / notifications' },
  { token: '--z-tooltip', value: '600', role: 'Tooltips (always on top)' },
];
---
<DocsLayout title="Elevation — Ecology" activeHref="/foundations/elevation">
  <nav class="crumbs"><a href={withBase('/')}>Ecology</a> <span>/</span> <span>Foundations</span> <span>/</span> <span>Elevation</span></nav>
  <h1>Elevation</h1>
  <p class="lede">Two systems work together to build depth: soft <strong>shadows</strong> imply lift off the surface, and a fixed <strong>z-index</strong> ladder keeps overlapping layers in a predictable stacking order.</p>

  <Section id="shadows" title="Shadows">
    <p>Deliberately soft and low-contrast — elevation should be felt, not seen. Use the semantic <code>--elevation-*</code> tokens in components; the <code>--shadow-*</code> primitives are the raw ramp underneath.</p>
    <div class="cards">
      {elevation.map((s) => (
        <div class="card" style={`box-shadow: var(${s.primitive})`}>
          <code>{s.token}</code>
          <span class="card__primitive">{s.primitive}</span>
          <span class="card__role">{s.role}</span>
        </div>
      ))}
    </div>
  </Section>

  <Section id="shadow-ramp" title="Shadow ramp">
    <p>The primitive ramp that the elevation tokens alias. Prefer <code>--elevation-*</code> in components; reference <code>--shadow-*</code> only when you need a specific step not covered by the semantic scale.</p>
    <div class="cards">
      {elevation.map((s) => (
        <div class="card" style={`box-shadow: var(${s.primitive})`}>
          <code>{s.primitive}</code>
        </div>
      ))}
    </div>
  </Section>

  <Section id="z-index" title="Z-index">
    <p>Overlay layers reference these tokens instead of ad-hoc numbers, so stacking conflicts can't happen. The order is canonical — tooltips always win.</p>
    <table class="z-table">
      <thead>
        <tr><th>Token</th><th>Value</th><th>Layer</th></tr>
      </thead>
      <tbody>
        {zIndex.map((z) => (
          <tr>
            <td><code>{z.token}</code></td>
            <td class="z-table__val">{z.value}</td>
            <td class="z-table__role">{z.role}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </Section>
</DocsLayout>

<style>
  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--spacing-500); padding: var(--spacing-300) var(--spacing-100) var(--spacing-500); }
  .card { display: flex; flex-direction: column; gap: 3px; background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-400); padding: var(--spacing-400); min-height: 96px; }
  .card code { font-family: var(--font-mono); font-size: 12.5px; color: var(--color-text-primary); }
  .card__primitive { font-family: var(--font-mono); font-size: 11.5px; color: var(--color-text-muted); }
.card__role { font-size: 12.5px; color: var(--color-text-muted); }

  .z-table { width: 100%; border-collapse: collapse; border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; }
  .z-table th { text-align: left; font-size: 13px; font-weight: 600; color: var(--color-text-secondary); padding: var(--spacing-250) var(--spacing-400); background: var(--color-surface-sunken); border-bottom: 1px solid var(--color-border); }
  .z-table td { padding: var(--spacing-250) var(--spacing-400); border-bottom: 1px solid var(--color-border-light); font-size: 14px; }
  .z-table tr:last-child td { border-bottom: none; }
  .z-table td code { font-family: var(--font-mono); font-size: 12.5px; color: var(--color-text-primary); }
  .z-table__val { font-family: var(--font-mono); color: var(--color-text-secondary); }
  .z-table__role { color: var(--color-text-muted); }
</style>
