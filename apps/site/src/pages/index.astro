---
import BaseLayout from '../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
import Button from '@esa/ecology/Button.astro';
import Badge from '@esa/ecology/esa-badge.astro';

const semanticSwatches = [
  'primary', 'secondary', 'accent', 'surface-sunken', 'border', 'text-primary', 'text-muted', 'success', 'danger', 'warning'
];

// Auto-discover every component specimen page so the index never goes stale.
const pageModules = import.meta.glob('./components/*.astro', { eager: true });
const components = Object.keys(pageModules)
  .map((p) => p.split('/').pop().replace('.astro', ''))
  .filter((name) => name !== 'button') // legacy placeholder page, superseded by esa-button
  .sort();
---
<BaseLayout title="Ecology — Design System Hub">
  <Stack gap="500">
    <Stack gap="200">
      <h1>Ecology</h1>
      <p>
        The framework-agnostic design system hub. Tokens and specimens live here;
        spoke repos pull <code>@esa/tokens</code> + <code>@esa/ecology</code> and
        re-skin via the semantic layer. Flip the theme switcher (top-right) to see
        the same components wear a different project's brand.
      </p>
    </Stack>

    <Stack gap="300">
      <h2>Presentational (.astro) + interactive (Web Component)</h2>
      <p>Buttons and badges are <code>.astro</code>. The toggle is a framework-agnostic Lit Web Component — fully functional, works in any stack.</p>
      <Stack gap="300" direction="row" align="center" wrap={true}>
        <Button>Primary</Button>
        <Button variant="secondary">Secondary</Button>
        <Badge value="3" />
        <Badge value="New" variant="success" />
        <Badge value="!" variant="danger" />
        <esa-switch-toggle label="Notifications"></esa-switch-toggle>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Semantic tokens</h2>
      <p>The override surface a spoke theme touches. Primitives (teal/orange/copper ramps) stay fixed underneath.</p>
      <div class="swatches">
        {semanticSwatches.map((name) => (
          <div class="swatch">
            <div class="chip" style={`background: var(--color-${name})`}></div>
            <div class="label">--color-{name}</div>
          </div>
        ))}
      </div>
    </Stack>

    <Stack gap="300">
      <h2>Components ({components.length})</h2>
      <p>Every component migrated from the Angular library. Presentational ones are <code>.astro</code>; interactive ones are framework-agnostic Lit Web Components.</p>
      <ul class="component-index">
        {components.map((name) => (
          <li><a href={`/components/${name}`}>{name}</a></li>
        ))}
      </ul>
    </Stack>
  </Stack>
</BaseLayout>

<style>
  .component-index {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: var(--spacing-200, 0.5rem);
  }
  .component-index a {
    display: block;
    padding: var(--spacing-250, 0.625rem) var(--spacing-300, 0.75rem);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--radius-200, 8px);
    color: var(--color-text-primary, #171717);
    text-decoration: none;
    font-size: var(--type-size-200, 1rem);
    transition: border-color var(--transition-fast, 150ms ease), background var(--transition-fast, 150ms ease);
  }
  .component-index a:hover {
    border-color: var(--color-primary, #005862);
    background: var(--color-surface-sunken, #efefef);
  }
</style>

<script>
  import '@esa/ecology/esa-switch-toggle';
</script>
