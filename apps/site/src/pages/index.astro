---
import DocsLayout from '../layouts/DocsLayout.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import { componentGroups } from '../data/nav';

const totalComponents = componentGroups.reduce((n, g) => n + g.items.length, 0);
---
<DocsLayout title="Ecology — Design System" activeHref="/">
  <section class="hero">
    <span class="eyebrow">ESA Data Technology · Design System</span>
    <h1>Ecology</h1>
    <p class="tagline">A framework-agnostic design system. Tokens, primitives, and patterns that travel from project to project — and re-skin to any brand without touching a component.</p>
    <div class="cta">
      <a href="/components/esa-button"><EsaButton size="lg">Browse components</EsaButton></a>
      <a href="/foundations/color"><EsaButton appearance="outline" size="lg">Foundations</EsaButton></a>
    </div>
  </section>

  <section class="stats">
    <div class="stat"><b>{totalComponents}</b><span>Components</span></div>
    <div class="stat"><b>3-tier</b><span>Token system</span></div>
    <div class="stat"><b>.astro + WC</b><span>Presentational + interactive</span></div>
    <div class="stat"><b>Any stack</b><span>Web Components everywhere</span></div>
  </section>

  <section class="how">
    <div class="card">
      <h3>Token-driven</h3>
      <p>Primitive → semantic → component. Authored in DTCG, compiled to CSS. Every value is a token; nothing is hard-coded.</p>
      <a href="/foundations/color">Foundations →</a>
    </div>
    <div class="card">
      <h3>Two kinds of component</h3>
      <p>Presentational primitives ship as <code>.astro</code>; interactive ones as framework-agnostic Lit Web Components that drop into any stack.</p>
      <a href="/components/esa-combobox">See an example →</a>
    </div>
    <div class="card">
      <h3>Theme, don't fork</h3>
      <p>A project re-skins by overriding the semantic layer under a <code>[data-theme]</code> scope. The brand changes everywhere at once.</p>
      <a href="/foundations/color">How theming works →</a>
    </div>
  </section>

  <section class="start">
    <h2 class="block-title">Get started</h2>
    <pre class="snippet"><code>npm install @esa/tokens @esa/ecology</code></pre>
    <p class="muted">Import the tokens once, then compose with Ecology components — or hand the rendered output to a dev team on any stack.</p>
  </section>

  <section class="explore">
    <h2 class="block-title">Explore components</h2>
    <div class="explore-grid">
      {componentGroups.map((g) => (
        <a class="group-card" href={g.items[0].href}>
          <span class="group-card__label">{g.label}</span>
          <span class="group-card__count">{g.items.length}</span>
        </a>
      ))}
    </div>
  </section>
</DocsLayout>

<style>
  .hero { padding: var(--spacing-600, 2rem) 0 var(--spacing-700, 3rem); }
  .eyebrow { font-size: 14px; font-weight: 500; color: var(--color-primary, #005862); }
  .hero h1 { font-size: 56px; font-weight: 700; letter-spacing: -0.03em; line-height: 1.05; margin: var(--spacing-300, 0.75rem) 0 var(--spacing-400, 1rem); }
  .tagline { font-size: 19px; line-height: 1.55; color: var(--color-text-secondary, #525252); max-width: 60ch; margin: 0 0 var(--spacing-500, 1.5rem); }
  .cta { display: flex; gap: var(--spacing-300, 0.75rem); flex-wrap: wrap; }
  .cta a { text-decoration: none; }

  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--spacing-300, 0.75rem); padding: var(--spacing-500, 1.5rem) 0; border-top: 1px solid var(--color-border, #e5e5e5); border-bottom: 1px solid var(--color-border, #e5e5e5); }
  .stat b { display: block; font-size: 22px; font-weight: 600; letter-spacing: -0.01em; }
  .stat span { font-size: 14px; color: var(--color-text-muted, #737373); }

  .how { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-400, 1rem); margin: var(--spacing-700, 3rem) 0; }
  .card { border: 1px solid var(--color-border, #e5e5e5); border-radius: 14px; padding: var(--spacing-500, 1.5rem); background: var(--color-surface, #fff); }
  .card h3 { margin: 0 0 var(--spacing-200, 0.5rem); font-size: 17px; font-weight: 600; }
  .card p { margin: 0 0 var(--spacing-300, 0.75rem); font-size: 15px; line-height: 1.6; color: var(--color-text-secondary, #525252); }
  .card a { font-size: 14.5px; font-weight: 500; color: var(--color-primary, #005862); }

  .block-title { font-size: 22px; font-weight: 600; letter-spacing: -0.01em; margin: 0 0 var(--spacing-300, 0.75rem); }
  .start { margin: var(--spacing-700, 3rem) 0; }
  .snippet { background: var(--color-surface-sunken, #f5f5f5); border: 1px solid var(--color-border, #e5e5e5); border-radius: 10px; padding: var(--spacing-400, 1rem) var(--spacing-500, 1.5rem); margin: 0 0 var(--spacing-250, 0.625rem); overflow-x: auto; }
  .snippet code { font-family: var(--font-mono, monospace); font-size: 14px; color: var(--color-text-primary, #171717); }
  .muted { font-size: 15px; color: var(--color-text-muted, #737373); }

  .explore { margin: var(--spacing-700, 3rem) 0; }
  .explore-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--spacing-250, 0.625rem); }
  .group-card { display: flex; align-items: center; justify-content: space-between; padding: var(--spacing-300, 0.75rem) var(--spacing-400, 1rem); border: 1px solid var(--color-border, #e5e5e5); border-radius: 11px; background: var(--color-surface, #fff); transition: border-color 120ms ease, background 120ms ease; }
  .group-card:hover { border-color: var(--color-primary, #005862); background: var(--color-surface-sunken, #f5f5f5); }
  .group-card__label { font-weight: 500; font-size: 15px; }
  .group-card__count { font-family: var(--font-mono, monospace); font-size: 13px; color: var(--color-text-muted, #737373); }

  @media (max-width: 720px) { .stats, .how, .explore-grid { grid-template-columns: 1fr 1fr; } .hero h1 { font-size: 40px; } }
</style>
