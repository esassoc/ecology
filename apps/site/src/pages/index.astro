---
import DocsLayout from '../layouts/DocsLayout.astro';
import { componentGroups } from '../data/nav';

const totalComponents = componentGroups.reduce((n, g) => n + g.items.length, 0);
---
<DocsLayout title="Ecology — Design System" activeHref="/">
  <section class="hero">
    <div class="hero__text">
      <span class="eyebrow">ESA · Data Technology</span>
      <h1>Ecology</h1>
      <p class="tagline">A framework-agnostic design system. Tokens, primitives, and patterns that travel from project to project — and re-skin to any brand without touching a component.</p>
      <div class="cta">
        <a class="btn btn--primary" href="/components/esa-button">Browse components</a>
        <a class="btn btn--ghost" href="/foundations/color">Foundations</a>
      </div>
    </div>
    <div class="hero__art" aria-hidden="true">
      <img src="/brand/ecology-mark.svg" alt="" width="260" height="260" />
    </div>
  </section>

  <section class="stats">
    <div class="stat"><b>{totalComponents}</b><span>Components</span></div>
    <div class="stat"><b>3-tier</b><span>Token system</span></div>
    <div class="stat"><b>.astro + WC</b><span>Presentational + interactive</span></div>
    <div class="stat"><b>Any stack</b><span>Web Components everywhere</span></div>
  </section>

  <section class="how">
    <article class="card">
      <h3>Token-driven</h3>
      <p>Primitive → semantic → component. Authored in DTCG, compiled to CSS. Every value is a token; nothing is hard-coded.</p>
      <a href="/foundations/color">Foundations →</a>
    </article>
    <article class="card">
      <h3>Two kinds of component</h3>
      <p>Presentational primitives ship as <code>.astro</code>; interactive ones as framework-agnostic Lit Web Components that drop into any stack.</p>
      <a href="/components/esa-combobox">See an example →</a>
    </article>
    <article class="card">
      <h3>Theme, don't fork</h3>
      <p>A project re-skins by overriding the semantic layer under a <code>[data-theme]</code> scope. The brand changes everywhere at once.</p>
      <a href="/foundations/color">How theming works →</a>
    </article>
  </section>

  <section class="rail">
    <a class="rail__card rail__card--live" href="/components/esa-button">
      <span class="rail__eyebrow">Components</span>
      <h2>Component library</h2>
      <p>{totalComponents} documented components across foundations, forms, overlays, and more — each with live specimens and an API.</p>
      <span class="rail__go">Explore the library →</span>
    </a>
    <div class="rail__card rail__card--soon">
      <span class="rail__eyebrow">Coming soon</span>
      <h2>Pattern library</h2>
      <p>Composed, multi-component patterns — page shells, data views, form flows — assembled from the primitives. In the works.</p>
      <a class="rail__go" href="/patterns">Preview →</a>
    </div>
  </section>

  <section class="explore">
    <h2 class="block-title">Explore components</h2>
    <div class="explore-grid">
      {componentGroups.map((g) => (
        <a class="group-card" href={g.items[0].href}>
          <span class="group-card__label">{g.label}</span>
          <span class="group-card__count">{g.items.length}</span>
        </a>
      ))}
    </div>
  </section>
</DocsLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--spacing-700, 3rem);
    padding: var(--spacing-500, 1.5rem) 0 var(--spacing-800, 4rem);
  }
  .eyebrow {
    font-family: var(--meta-mono, monospace);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--meta-clay, #b85c38);
  }
  .hero h1 {
    font-size: clamp(56px, 5vw + 1rem, 88px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: var(--spacing-300, 0.75rem) 0 var(--spacing-400, 1rem);
    color: var(--meta-ink, #141413);
  }
  .tagline {
    font-family: var(--meta-serif, Georgia, serif);
    font-size: 20px;
    line-height: 1.5;
    color: var(--meta-ink-2, #4d4c49);
    max-width: 52ch;
    margin: 0 0 var(--spacing-500, 1.5rem);
  }
  .hero__art img { width: 260px; height: 260px; display: block; }

  .cta { display: flex; gap: var(--spacing-300, 0.75rem); flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center;
    padding: 11px 22px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    border: 1px solid transparent;
    transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
  }
  .btn--primary { background: var(--meta-ink, #141413); color: #faf9f6; }
  .btn--primary:hover { background: var(--meta-clay, #b85c38); }
  .btn--ghost { border-color: var(--meta-line, #e7e5dc); color: var(--meta-ink, #141413); background: #fff; }
  .btn--ghost:hover { border-color: var(--meta-ink, #141413); }

  /* ---- Stats ---- */
  .stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-300, 0.75rem);
    padding: var(--spacing-500, 1.5rem) 0;
    border-top: 1px solid var(--meta-line, #e7e5dc);
    border-bottom: 1px solid var(--meta-line, #e7e5dc);
  }
  .stat b { display: block; font-family: var(--meta-serif, serif); font-size: 26px; font-weight: 400; letter-spacing: -0.01em; color: var(--meta-ink, #141413); }
  .stat span { font-size: 13px; color: var(--meta-ink-3, #8d949b); }

  /* ---- How ---- */
  .how { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-400, 1rem); margin: var(--spacing-800, 4rem) 0; }
  .card { border: 1px solid var(--meta-line, #e7e5dc); border-radius: 8px; padding: var(--spacing-500, 1.5rem); background: var(--meta-card, #fff); }
  .card h3 { font-family: var(--meta-serif, serif); font-weight: 400; margin: 0 0 var(--spacing-200, 0.5rem); font-size: 21px; color: var(--meta-ink, #141413); }
  .card p { margin: 0 0 var(--spacing-300, 0.75rem); font-size: 15px; line-height: 1.6; color: var(--meta-ink-2, #4d4c49); }
  .card a { font-size: 14.5px; font-weight: 500; color: var(--meta-clay, #b85c38); }
  .card code { font-family: var(--meta-mono, monospace); font-size: 0.9em; background: rgba(20,20,19,0.05); padding: 1px 5px; border-radius: 4px; }

  /* ---- Rail: library + coming-soon ---- */
  .rail { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-400, 1rem); margin: var(--spacing-800, 4rem) 0; }
  .rail__card { border: 1px solid var(--meta-line, #e7e5dc); border-radius: 10px; padding: var(--spacing-600, 2rem); background: var(--meta-card, #fff); display: flex; flex-direction: column; gap: var(--spacing-200, 0.5rem); }
  .rail__card--live { transition: border-color 140ms ease; }
  .rail__card--live:hover { border-color: var(--meta-clay, #b85c38); }
  .rail__card--soon { background: #f0f5f9; border-color: #e2ecf3; }
  .rail__eyebrow { font-family: var(--meta-mono, monospace); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--meta-ink-3, #8d949b); }
  .rail__card h2 { font-family: var(--meta-serif, serif); font-weight: 400; font-size: 26px; letter-spacing: -0.01em; margin: 0; color: var(--meta-ink, #141413); }
  .rail__card p { margin: 0; font-size: 15px; line-height: 1.6; color: var(--meta-ink-2, #4d4c49); }
  .rail__go { margin-top: auto; padding-top: var(--spacing-300, 0.75rem); font-size: 14.5px; font-weight: 500; color: var(--meta-clay, #b85c38); }

  /* ---- Explore ---- */
  .explore { margin: var(--spacing-800, 4rem) 0 var(--spacing-600, 2rem); }
  .block-title { font-size: 24px; font-weight: 400; letter-spacing: -0.01em; margin: 0 0 var(--spacing-400, 1rem); color: var(--meta-ink, #141413); }
  .explore-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--spacing-250, 0.625rem); }
  .group-card { display: flex; align-items: center; justify-content: space-between; padding: var(--spacing-300, 0.75rem) var(--spacing-400, 1rem); border: 1px solid var(--meta-line, #e7e5dc); border-radius: 8px; background: var(--meta-card, #fff); transition: border-color 120ms ease; }
  .group-card:hover { border-color: var(--meta-clay, #b85c38); }
  .group-card__label { font-weight: 500; font-size: 15px; color: var(--meta-ink, #141413); }
  .group-card__count { font-family: var(--meta-mono, monospace); font-size: 13px; color: var(--meta-ink-3, #8d949b); }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; }
    .hero__art { order: -1; }
    .hero__art img { width: 180px; height: 180px; }
    .stats, .how, .rail, .explore-grid { grid-template-columns: 1fr 1fr; }
    .how { grid-template-columns: 1fr; }
  }
</style>
