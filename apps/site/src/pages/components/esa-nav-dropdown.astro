---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import EsaAppBar from '@esa/ecology/esa-app-bar.astro';
import EsaNavDropdown from '@esa/ecology/esa-nav-dropdown.astro';
import EsaLinkColumn from '@esa/ecology/esa-link-column.astro';

const props = [
  { name: 'label', type: 'string', description: 'Trigger label.' },
  { name: 'icon', type: 'string', description: 'Leading icon on the trigger.' },
  { name: 'size', type: "'sm' | 'md'", default: "'md'", description: 'Trigger size (matches esa-icon-link).' },
  { name: 'align', type: "'start' | 'end'", default: "'start'", description: 'Which edge of the trigger the panel aligns to.' },
];
---
<ComponentDoc name="Nav Dropdown" category="Navigation" slug="esa-nav-dropdown" type=".astro" status="stable"
  summary="An <a href='/components/esa-icon-link'>Icon Link</a> trigger paired with a floating panel via a native <code>&amp;lt;details&amp;gt;</code> disclosure — zero runtime JS. The panel is slotted, so it holds any menu; the chevron rotates when open. Compose it inside an <a href='/components/esa-app-bar'>App Bar</a> for chrome nav.">

  <Section id="preview" title="Preview (click to open)">
    <Preview align="start" code={`<EsaAppBar tone="brand" as="header">
  <EsaNavDropdown icon="trees" label="Mitigation work">
    <EsaLinkColumn heading="View all topics" links={[…]} />
  </EsaNavDropdown>
</EsaAppBar>`}>
      <EsaAppBar tone="brand" as="header">
        <EsaNavDropdown icon="trees" label="Mitigation work">
          <EsaLinkColumn heading="Mitigation work" links={[
            { label: 'Projects' }, { label: 'Contracts' }, { label: 'Portfolios' }, { label: 'Work elements' },
          ]} />
        </EsaNavDropdown>
        <EsaNavDropdown icon="trending-up" label="Reporting">
          <EsaLinkColumn heading="Reporting" links={[
            { label: 'Report Center' }, { label: 'Maps' }, { label: 'Publications' },
          ]} />
        </EsaNavDropdown>
        <EsaNavDropdown slot="end" align="end" icon="circle-user" label="Angela Zhao">
          <EsaLinkColumn heading="Account" links={[{ label: 'Dashboard' }, { label: 'Sign out' }]} />
        </EsaNavDropdown>
      </EsaAppBar>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>
</ComponentDoc>
