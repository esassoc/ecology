---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';

const props = [
  { name: 'tabs', type: 'EsaTab[]', default: '[]', description: 'Tab definitions (property, set via JS). Each is { label; icon?; badge?; disabled? }.' },
  { name: 'active-index', type: 'number', default: '0', description: 'Index of the selected tab.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Tab height and type scale. Reflected as an attribute.' },
  { name: 'appearance', type: "'underline' | 'segmented'", default: "'underline'", description: 'Tab style (aligned to Beacon): underlined indicator or a segmented control on a sunken track. Reflected as an attribute.' },
  { name: 'variant', type: "'underline' | 'pill'", default: "'underline'", description: 'Legacy alias for appearance — pill maps to segmented. Prefer appearance.' },
];

const events = [
  { name: 'tabchange', type: 'CustomEvent', description: 'Fired when the active tab changes. detail: { index: number }. Bubbles and composed.' },
];

const slots = [
  { name: 'panel-{index}', type: 'slot', description: 'Content for the matching tab; the active panel is shown. Falls back to the default slot.' },
];
---
<ComponentDoc name="Tab Layout" category="Navigation" slug="esa-tab-layout" type="wc" status="stable"
  summary="An ARIA tablist with active-tab state, roving keyboard navigation (Arrow / Home / End, skipping disabled tabs), badges, and a swapping panel. A Lit web component.">

  <Section id="preview" title="Preview">
    <Preview align="start" lang="html" code={`<esa-tab-layout id="tabs">
  <div slot="panel-0">Overview content — summary metrics and status.</div>
  <div slot="panel-1">Activity content — recent events log.</div>
  <div slot="panel-2">Settings content — configuration form.</div>
</esa-tab-layout>

<script>
  document.getElementById('tabs').tabs = [
    { label: 'Overview' }, { label: 'Activity' }, { label: 'Settings' },
  ];
</script>`}>
      <div style="width: 100%;">
        <esa-tab-layout id="t1">
          <div slot="panel-0">Overview content — summary metrics and status.</div>
          <div slot="panel-1">Activity content — recent events log.</div>
          <div slot="panel-2">Settings content — configuration form.</div>
        </esa-tab-layout>
      </div>
    </Preview>
  </Section>

  <Section id="appearance" title="Appearance">
    <p>Two appearances, aligned to Beacon's <code>UiTabsAppearance</code>. <code>underline</code> (default) shows an underlined indicator on the active tab; <code>segmented</code> renders a segmented control — a sunken, bordered track with a filled selected segment and no indicator. (<code>variant="pill"</code> is the legacy alias for <code>segmented</code>.)</p>
    <Preview align="start" lang="html" code={`<esa-tab-layout appearance="underline">…</esa-tab-layout>
<esa-tab-layout appearance="segmented">…</esa-tab-layout>`}>
      <div style="width: 100%; display: flex; flex-direction: column; gap: var(--spacing-500, 1.5rem);">
        <esa-tab-layout id="t2a" appearance="underline">
          <div slot="panel-0">Underline appearance.</div>
          <div slot="panel-1">Second panel.</div>
          <div slot="panel-2">Third panel.</div>
        </esa-tab-layout>
        <esa-tab-layout id="t2" appearance="segmented">
          <div slot="panel-0">Segmented appearance.</div>
          <div slot="panel-1">Second panel.</div>
          <div slot="panel-2">Third panel.</div>
        </esa-tab-layout>
      </div>
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview align="start" lang="html" code={`<esa-tab-layout size="xs">…</esa-tab-layout>
<esa-tab-layout size="sm">…</esa-tab-layout>
<esa-tab-layout size="md">…</esa-tab-layout>
<esa-tab-layout size="lg">…</esa-tab-layout>`}>
      <div style="width: 100%; display: flex; flex-direction: column; gap: var(--spacing-400, 1rem);">
        <esa-tab-layout id="t6" size="xs"><div slot="panel-0">Extra small.</div><div slot="panel-1">Two.</div></esa-tab-layout>
        <esa-tab-layout id="t3" size="sm"><div slot="panel-0">Small.</div><div slot="panel-1">Two.</div></esa-tab-layout>
        <esa-tab-layout id="t7" size="md"><div slot="panel-0">Medium.</div><div slot="panel-1">Two.</div></esa-tab-layout>
        <esa-tab-layout id="t4" size="lg"><div slot="panel-0">Large.</div><div slot="panel-1">Two.</div></esa-tab-layout>
      </div>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Tabs accept badges, and any tab can be disabled — keyboard navigation skips disabled tabs.</p>
    <Preview align="start" lang="html" code={`<script>
  el.tabs = [
    { label: 'Inbox', badge: 4 },
    { label: 'Drafts', disabled: true },
    { label: 'Archive', badge: 128 },
  ];
</script>`}>
      <div style="width: 100%;">
        <esa-tab-layout id="t5">
          <div slot="panel-0">Inbox.</div>
          <div slot="panel-2">Archive (tab 2 is disabled).</div>
        </esa-tab-layout>
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} events={events} />
    <p><code>tabs</code> is an array property — set it in JS, not as an attribute. Each <code>EsaTab.icon</code> is a raw inline SVG string.</p>
    <h3>Slots</h3>
    <PropsTable rows={slots} />
    <p>The routed-tabs (RouterOutlet) branch of the Angular component is replaced here by content panels via the named slots above.</p>
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Follows the ARIA tablist pattern: <code>role="tablist"</code> / <code>role="tab"</code> / <code>role="tabpanel"</code> with <code>aria-selected</code>.</li>
      <li>Roving <code>tabindex</code> — only the active tab is in the tab order; ArrowLeft / ArrowRight / Home / End move focus and selection, skipping disabled tabs.</li>
      <li>Disabled tabs are non-interactive and excluded from keyboard traversal.</li>
    </ul>
  </Section>

  <Section id="tokens" title="Tokens">
    <p>Override these to re-skin without touching the component:</p>
    <ul class="tokens">
      <li><code>--color-text-secondary</code> / <code>--color-text-primary</code> · <code>--color-primary</code> (active + indicator + badge)</li>
      <li><code>--color-surface-sunken</code> (hover, pill track) · <code>--color-surface</code> (active pill) · <code>--color-border</code> · <code>--shadow-50</code></li>
      <li><code>--type-size-150</code> / <code>--type-size-200</code> / <code>--type-size-300</code> · <code>--spacing-*</code> · <code>--radius-100</code> / <code>--radius-200</code> / <code>--radius-full</code></li>
    </ul>
  </Section>
</ComponentDoc>

<script>
  import '@esa/ecology/esa-tab-layout';

  const basic = [
    { label: 'Overview' },
    { label: 'Activity' },
    { label: 'Settings' },
  ];
  (['t1', 't2', 't2a'] as const).forEach((id) => {
    const el = document.getElementById(id) as any;
    if (el) el.tabs = basic;
  });

  (['t6', 't3', 't7', 't4'] as const).forEach((id) => {
    const el = document.getElementById(id) as any;
    if (el) el.tabs = [{ label: 'One' }, { label: 'Two' }];
  });

  const t5 = document.getElementById('t5') as any;
  if (t5)
    t5.tabs = [
      { label: 'Inbox', badge: 4 },
      { label: 'Drafts', disabled: true },
      { label: 'Archive', badge: 128 },
    ];
</script>
