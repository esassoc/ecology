---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '../../components/docs/Section.astro';
import Preview from '../../components/docs/Preview.astro';
import Api from '../../components/docs/Api.astro';
import EsaButton from '@esa/ecology/esa-button.astro';

const props = [
  { name: 'color', type: "'primary' | 'secondary' | 'danger' | 'success' | 'warning' | 'info' | 'ai' | 'ghost'", default: "'primary'", description: 'Semantic color. `ai` uses the copper AI-context palette; `ghost` is neutral/transparent.' },
  { name: 'appearance', type: "'fill' | 'outline' | 'dashed'", default: "'fill'", description: 'How the color renders — solid fill, bordered, or dashed border.' },
  { name: 'active', type: 'boolean', default: 'false', description: 'Pressed/selected state (sets aria-pressed) — for toggle buttons.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Control size (shared form scale).' },
  { name: 'icon', type: 'string', description: 'Lucide icon name, rendered left of the label.' },
  { name: 'iconOnly', type: 'boolean', default: 'false', description: 'Square icon-only button with no text.' },
  { name: 'loading', type: 'boolean', default: 'false', description: 'Shows a spinner; label is held in place but hidden.' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables interaction.' },
  { name: 'type', type: "'button' | 'submit' | 'reset'", default: "'button'", description: 'Native button type.' },
];
---
<ComponentDoc name="Button" category="Core" slug="esa-button" type=".astro" status="stable"
  summary="Triggers an action or event. A two-axis model — 8 semantic <strong>colors</strong> × 3 <strong>appearances</strong> (fill/outline/dashed) — plus a toggle, four sizes, and icon/loading affordances.">

  <Section id="preview" title="Preview">
    <Preview code={`<EsaButton>Get started</EsaButton>`}>
      <EsaButton>Get started</EsaButton>
    </Preview>
  </Section>

  <Section id="colors" title="Colors">
    <p>Eight semantic colors. <code>ai</code> maps to the copper AI-context palette; <code>ghost</code> is neutral and transparent.</p>
    <Preview code={`<EsaButton color="primary">Primary</EsaButton>
<EsaButton color="secondary">Secondary</EsaButton>
<EsaButton color="danger">Danger</EsaButton>
<EsaButton color="success">Success</EsaButton>
<EsaButton color="warning">Warning</EsaButton>
<EsaButton color="info">Info</EsaButton>
<EsaButton color="ai">AI</EsaButton>
<EsaButton color="ghost">Ghost</EsaButton>`}>
      <EsaButton color="primary">Primary</EsaButton>
      <EsaButton color="secondary">Secondary</EsaButton>
      <EsaButton color="danger">Danger</EsaButton>
      <EsaButton color="success">Success</EsaButton>
      <EsaButton color="warning">Warning</EsaButton>
      <EsaButton color="info">Info</EsaButton>
      <EsaButton color="ai">AI</EsaButton>
      <EsaButton color="ghost">Ghost</EsaButton>
    </Preview>
  </Section>

  <Section id="appearances" title="Appearances">
    <p>The appearance axis is independent of color — any color renders as <code>fill</code>, <code>outline</code>, or <code>dashed</code>.</p>
    <Preview code={`<EsaButton color="danger" appearance="fill">Fill</EsaButton>
<EsaButton color="danger" appearance="outline">Outline</EsaButton>
<EsaButton color="danger" appearance="dashed">Dashed</EsaButton>`}>
      <EsaButton color="danger" appearance="fill">Fill</EsaButton>
      <EsaButton color="danger" appearance="outline">Outline</EsaButton>
      <EsaButton color="danger" appearance="dashed">Dashed</EsaButton>
    </Preview>
  </Section>

  <Section id="active" title="Active (toggle)">
    <p>Set <code>active</code> for a pressed/selected look (and <code>aria-pressed</code>) — the basis for toggle buttons.</p>
    <Preview code={`<EsaButton appearance="outline">Default</EsaButton>
<EsaButton appearance="outline" active>Active</EsaButton>`}>
      <EsaButton appearance="outline">Default</EsaButton>
      <EsaButton appearance="outline" active>Active</EsaButton>
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview code={`<EsaButton size="xs">Extra small</EsaButton>
<EsaButton size="sm">Small</EsaButton>
<EsaButton size="md">Medium</EsaButton>
<EsaButton size="lg">Large</EsaButton>`}>
      <EsaButton size="xs">Extra small</EsaButton>
      <EsaButton size="sm">Small</EsaButton>
      <EsaButton size="md">Medium</EsaButton>
      <EsaButton size="lg">Large</EsaButton>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <Preview code={`<EsaButton icon="arrow-right">With icon</EsaButton>
<EsaButton loading>Loading</EsaButton>
<EsaButton disabled>Disabled</EsaButton>
<EsaButton iconOnly icon="plus" aria-label="Add" />`}>
      <EsaButton icon="arrow-right">With icon</EsaButton>
      <EsaButton loading>Loading</EsaButton>
      <EsaButton disabled>Disabled</EsaButton>
      <EsaButton iconOnly icon="plus" />
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Renders a native <code>&lt;button&gt;</code> — keyboard and screen-reader behavior come for free.</li>
      <li>Visible focus ring via <code>--focus-ring-*</code> tokens (2px, offset).</li>
      <li><code>active</code> sets <code>aria-pressed</code>; <code>iconOnly</code> buttons require an <code>aria-label</code>.</li>
      <li><code>loading</code> keeps the label in the DOM (visually hidden) so width doesn't jump and the name persists.</li>
      <li><code>warning</code> fill uses dark text for contrast on the amber background.</li>
    </ul>
  </Section>

  <Section id="tokens" title="Tokens">
    <p>Each color reads its semantic token; appearance derives borders/tints from it. Override to re-skin:</p>
    <ul class="tokens">
      <li><code>--color-primary</code> · <code>--color-secondary</code> · <code>--color-danger</code> / <code>success</code> / <code>warning</code> / <code>info</code></li>
      <li><code>--color-ai</code> / <code>--color-ai-hover</code> (copper) · <code>--color-text-primary</code> (ghost)</li>
      <li><code>{'--form-{height,padding-x,font-size,radius}-{xs,sm,md,lg}'}</code> (size scale)</li>
      <li><code>--focus-ring-*</code> · <code>--color-text-inverse</code> (text on fill)</li>
    </ul>
  </Section>
</ComponentDoc>
