---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import Badge from '@esa/ecology/esa-badge.astro';

const props = [
  { name: 'value', type: 'string | number', description: 'Text or count shown inside the badge. Ignored in dot mode.' },
  { name: 'color', type: "hue | semantic", default: "'primary'", description: 'Any accent hue (gray · blue · copper · gold · grass · green · lime · orange · red · teal · yellow) or a semantic tone (primary · secondary · success · warning · danger · info). Sets data-accent so the solid fill (accent-9) and contrast text track the hue.' },
  { name: 'variant', type: "same as color", description: 'Deprecated alias for color — kept so existing markup keeps working.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Badge height and text size.' },
  { name: 'dot', type: 'boolean', default: 'false', description: 'Renders a small status dot with no text.' },
];
---
<ComponentDoc name="Badge" category="Display" slug="esa-badge" type=".astro" status="stable"
  summary="A small pill for counts, statuses, and labels. Six color intents, three sizes, plus a dot mode for compact status indicators.">

  <Section id="preview" title="Preview">
    <Preview code={`<Badge value="New" />`}>
      <Badge value="New" />
    </Preview>
  </Section>

  <Section id="variants" title="Semantic tones">
    <Preview code={`<Badge value="Primary" color="primary" />
<Badge value="Secondary" color="secondary" />
<Badge value="Success" color="success" />
<Badge value="Warning" color="warning" />
<Badge value="Danger" color="danger" />
<Badge value="Info" color="info" />`}>
      <Badge value="Primary" color="primary" />
      <Badge value="Secondary" color="secondary" />
      <Badge value="Success" color="success" />
      <Badge value="Warning" color="warning" />
      <Badge value="Danger" color="danger" />
      <Badge value="Info" color="info" />
    </Preview>
  </Section>

  <Section id="hues" title="Any hue">
    <p>Solid fill from <code>accent-9</code> with contrast text — pass any accent hue and both track it. Bright hues (lime, yellow, gold) automatically get dark text via <code>--color-accent-contrast</code>.</p>
    <Preview code={`<Badge value="gray" color="gray" />
<Badge value="blue" color="blue" />
<Badge value="teal" color="teal" />
<Badge value="grass" color="grass" />
<Badge value="lime" color="lime" />
<Badge value="yellow" color="yellow" />
<Badge value="gold" color="gold" />
<Badge value="orange" color="orange" />
<Badge value="copper" color="copper" />
<Badge value="red" color="red" />`}>
      <Badge value="gray" color="gray" />
      <Badge value="blue" color="blue" />
      <Badge value="teal" color="teal" />
      <Badge value="grass" color="grass" />
      <Badge value="lime" color="lime" />
      <Badge value="yellow" color="yellow" />
      <Badge value="gold" color="gold" />
      <Badge value="orange" color="orange" />
      <Badge value="copper" color="copper" />
      <Badge value="red" color="red" />
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview code={`<Badge value="3" size="xs" />
<Badge value="9" size="sm" />
<Badge value="42" size="md" />
<Badge value="128" size="lg" />`}>
      <Badge value="3" size="xs" />
      <Badge value="9" size="sm" />
      <Badge value="42" size="md" />
      <Badge value="128" size="lg" />
    </Preview>
  </Section>

  <Section id="states" title="Dot mode">
    <p>With <code>dot</code>, the badge collapses to an 8px circle — useful as an inline status indicator next to a label.</p>
    <Preview code={`<Badge dot color="success" />
<Badge dot color="warning" />
<Badge dot color="danger" />`}>
      <Badge dot color="success" />
      <Badge dot color="warning" />
      <Badge dot color="danger" />
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Purely presentational — pair with adjacent visible text so the count or status has a label.</li>
      <li>Dot mode has no text content; convey its meaning through surrounding copy or an <code>aria-label</code> on the wrapper.</li>
      <li>Color is not the only signal where possible — prefer text counts over color alone.</li>
    </ul>
  </Section>

</ComponentDoc>
