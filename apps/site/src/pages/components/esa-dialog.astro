---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
---
<BaseLayout title="Dialog — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>Dialog <code>[wc]</code></h1>
      <p>Modal dialog with backdrop, focus trap, Esc-to-close, and focus restore. Themes via <code>--z-modal</code> / <code>--z-modal-backdrop</code> and surface/border tokens.</p>
    </Stack>

    <Stack gap="300">
      <h2>Sizes</h2>
      <Stack gap="300" direction="row" wrap={true}>
        <button class="trigger" data-target="dlg-small">Open small</button>
        <button class="trigger" data-target="dlg-medium">Open medium</button>
        <button class="trigger" data-target="dlg-large">Open large</button>
        <button class="trigger" data-target="dlg-fullscreen">Open fullscreen</button>
      </Stack>
    </Stack>

    <esa-dialog id="dlg-small" size="small" heading="Small dialog">
      <p>A compact dialog (360px). Tab cycles within; Esc closes.</p>
      <button slot="footer" class="trigger-close" data-target="dlg-small">Close</button>
    </esa-dialog>

    <esa-dialog id="dlg-medium" heading="Medium dialog">
      <p>The default medium dialog (480px). The close button, backdrop click, and Esc all dismiss it.</p>
      <button slot="footer" class="trigger-close" data-target="dlg-medium">Close</button>
    </esa-dialog>

    <esa-dialog id="dlg-large" size="large" heading="Large dialog">
      <p>A large dialog (640px) for richer content.</p>
      <button slot="footer" class="trigger-close" data-target="dlg-large">Close</button>
    </esa-dialog>

    <esa-dialog id="dlg-fullscreen" size="fullscreen" heading="Fullscreen dialog">
      <p>Edge-to-edge dialog for immersive flows.</p>
      <button slot="footer" class="trigger-close" data-target="dlg-fullscreen">Close</button>
    </esa-dialog>
  </Stack>
</BaseLayout>

<script>
  import '@esa/ecology/esa-dialog';
  document.querySelectorAll('.trigger').forEach((btn) =>
    btn.addEventListener('click', () => {
      const el = document.getElementById((btn as HTMLElement).dataset.target!) as any;
      el?.show();
    }),
  );
  document.querySelectorAll('.trigger-close').forEach((btn) =>
    btn.addEventListener('click', () => {
      const el = document.getElementById((btn as HTMLElement).dataset.target!) as any;
      el?.close();
    }),
  );
</script>

<style>
  .trigger, .trigger-close {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-200, 0.5rem);
    border: 1px solid var(--color-border-strong, #d4d4d4);
    background: var(--color-primary, #005862);
    color: var(--color-text-inverse, #fff);
    font-family: inherit;
    font-size: var(--type-size-200, 0.9375rem);
    cursor: pointer;
  }
  .trigger-close { background: transparent; color: var(--color-text-primary, #171717); }
</style>
