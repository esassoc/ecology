---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '../../components/docs/Section.astro';
import Preview from '../../components/docs/Preview.astro';
import Api from '../../components/docs/Api.astro';
import FilterClearButton from '@esa/ecology/esa-filter-clear-button.astro';

const props = [
  { name: 'label', type: 'string', default: "'Clear all'", description: 'Visible button text.' },
  { name: 'showIcon', type: 'boolean', default: 'true', description: 'Show the leading filter-x icon.' },
  { name: 'hidden', type: 'boolean', default: 'false', description: 'Suppress rendering entirely (renders no DOM).' },
];

const events = [
  { name: 'esa-filter-clear', type: '(no detail)', description: 'Bubbling/composed. Fires on click so a parent container can clear all active filters.' },
];
---
<ComponentDoc name="Filter Clear Button" category="Filters" slug="esa-filter-clear-button" type=".astro" status="stable"
  summary="Ghost/link-style button that clears all active filters. Optional leading <code>filter-x</code> icon, customizable label, and a bubbling <code>esa-filter-clear</code> event on click.">

  <Section id="preview" title="Preview">
    <Preview code={`<FilterClearButton />`}>
      <FilterClearButton />
    </Preview>
  </Section>

  <Section id="variants" title="Variants">
    <p>Override the label, and drop the icon for a plain link-style action.</p>
    <Preview code={`<FilterClearButton label="Reset filters" />
<FilterClearButton label="Clear all" showIcon={false} />`}>
      <FilterClearButton label="Reset filters" />
      <FilterClearButton label="Clear all" showIcon={false} />
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="events" title="Events">
    <Api props={events} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Renders a native <code>&lt;button&gt;</code> with a fixed <code>aria-label="Clear all filters"</code>, so the name is stable even when <code>label</code> changes.</li>
      <li>The leading icon is <code>aria-hidden</code> — decorative only.</li>
      <li>Hover applies a subtle overlay; focus-visible shows a 2px primary outline via <code>--focus-ring-*</code> tokens.</li>
    </ul>
  </Section>

  <Section id="tokens" title="Tokens">
    <p>Override the clear-button tokens to restyle the link treatment:</p>
    <ul class="tokens">
      <li><code>--filter-clear-color</code> / <code>--filter-clear-color-hover</code> · <code>--color-primary</code> / <code>--color-primary-hover</code></li>
      <li><code>--color-hover-overlay</code> (hover background) · <code>--radius-100</code> · <code>--spacing-*</code></li>
      <li><code>--type-size-150</code> · <code>--font-weight-medium</code></li>
      <li><code>--focus-ring-width</code> / <code>--focus-ring-color</code> / <code>--focus-ring-offset</code></li>
    </ul>
  </Section>
</ComponentDoc>
