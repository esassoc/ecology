---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
import FormField from '@esa/ecology/esa-form-field.astro';
---
<BaseLayout title="Form Field — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>Form Field</h1>
      <p>Presentational layout wrapper: label row + control slot + hint/error text. Pure <code>.astro</code> — no JS at runtime. Error text replaces help text when present.</p>
    </Stack>

    <Stack gap="300">
      <h2>With help text</h2>
      <FormField label="Email" helpText="We will never share your email.">
        <input type="email" style="width:100%;height:40px;padding:0 .75rem;border:1px solid var(--color-border);border-radius:var(--radius-200);font:inherit;" placeholder="you@example.com" />
      </FormField>
    </Stack>

    <Stack gap="300">
      <h2>Required</h2>
      <FormField label="Project name" required={true}>
        <input type="text" style="width:100%;height:40px;padding:0 .75rem;border:1px solid var(--color-border);border-radius:var(--radius-200);font:inherit;" />
      </FormField>
    </Stack>

    <Stack gap="300">
      <h2>Error state</h2>
      <FormField label="Permit ID" errorText="Permit ID is required." required={true}>
        <input type="text" aria-invalid="true" style="width:100%;height:40px;padding:0 .75rem;border:1px solid var(--color-danger);border-radius:var(--radius-200);font:inherit;" />
      </FormField>
    </Stack>

    <Stack gap="300">
      <h2>Disabled</h2>
      <FormField label="Locked field" helpText="This field cannot be edited." disabled={true}>
        <input type="text" disabled value="Read only" style="width:100%;height:40px;padding:0 .75rem;border:1px solid var(--color-border);border-radius:var(--radius-200);font:inherit;background:var(--color-disabled-bg);" />
      </FormField>
    </Stack>

    <Stack gap="300">
      <h2>Sizes (label scales)</h2>
      <FormField label="Small label" size="small">
        <input type="text" style="width:100%;height:32px;padding:0 .5rem;border:1px solid var(--color-border);border-radius:var(--radius-100);font:inherit;" />
      </FormField>
      <FormField label="Medium label" size="medium">
        <input type="text" style="width:100%;height:40px;padding:0 .75rem;border:1px solid var(--color-border);border-radius:var(--radius-200);font:inherit;" />
      </FormField>
      <FormField label="Large label" size="large">
        <input type="text" style="width:100%;height:48px;padding:0 1rem;border:1px solid var(--color-border);border-radius:var(--radius-300);font:inherit;" />
      </FormField>
    </Stack>
  </Stack>
</BaseLayout>
