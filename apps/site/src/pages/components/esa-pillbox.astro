---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';
import Pillbox from '@esa/ecology/esa-pillbox.astro';
import Pill from '@esa/ecology/esa-pill.astro';

const props = [
  { name: 'gap', type: "'small' | 'medium' | 'large'", default: "'small'", description: 'Spacing between pills.' },
];

const slots = [
  { name: 'default', type: 'slot', description: 'Any number of pills (or other inline tags) to lay out.' },
];
---
<ComponentDoc name="Pillbox" category="Display" slug="esa-pillbox" type=".astro" status="stable"
  summary="A flex-wrap container that lays out a collection of pills with a configurable gap. Purely presentational — it owns layout, the pills own their appearance and behavior.">

  <Section id="preview" title="Preview">
    <Preview align="start" code={`<Pillbox gap="small">
  <Pill label="Wetlands" variant="success" removable={false} />
  <Pill label="Air quality" variant="info" removable={false} />
  <Pill label="Overdue" variant="danger" removable={false} />
</Pillbox>`}>
      <Pillbox gap="small">
        <Pill label="Wetlands" variant="success" removable={false} />
        <Pill label="Air quality" variant="info" removable={false} />
        <Pill label="Overdue" variant="danger" removable={false} />
        <Pill label="Permitting" variant="primary" removable={false} />
        <Pill label="Stormwater" removable={false} />
      </Pillbox>
    </Preview>
  </Section>

  <Section id="gaps" title="Gaps">
    <Preview align="start" code={`<Pillbox gap="small">…</Pillbox>
<Pillbox gap="medium">…</Pillbox>
<Pillbox gap="large">…</Pillbox>`}>
      <div style="display: flex; flex-direction: column; gap: 20px; width: 100%;">
        <Pillbox gap="small">
          <Pill label="Small gap" variant="success" removable={false} />
          <Pill label="Air quality" variant="info" removable={false} />
          <Pill label="Overdue" variant="danger" removable={false} />
        </Pillbox>
        <Pillbox gap="medium">
          <Pill label="Medium gap" variant="success" removable={false} />
          <Pill label="Air quality" variant="info" removable={false} />
          <Pill label="Overdue" variant="danger" removable={false} />
        </Pillbox>
        <Pillbox gap="large">
          <Pill label="Large gap" variant="success" removable={false} />
          <Pill label="Air quality" variant="info" removable={false} />
          <Pill label="Overdue" variant="danger" removable={false} />
        </Pillbox>
      </div>
    </Preview>
  </Section>

  <Section id="states" title="Wrapping">
    <p>Pills wrap to a new row when they exceed the container width. Pillbox is agnostic to pill behavior — removable pills work as-is.</p>
    <Preview align="start" code={`<div style="max-width: 360px;">
  <Pillbox gap="small">…many pills…</Pillbox>
</div>`}>
      <div style="max-width: 360px;">
        <Pillbox gap="small">
          <Pill label="Endangered species" variant="warning" removable={false} />
          <Pill label="Water rights" variant="info" removable={false} />
          <Pill label="Coastal" variant="success" removable={false} />
          <Pill label="NEPA review" variant="primary" removable={false} />
          <Pill label="Habitat restoration" removable={false} />
          <Pill label="Discharge permit" variant="danger" removable={false} />
        </Pillbox>
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
    <h3 style="margin-top: 1.5rem;">Slots</h3>
    <PropsTable rows={slots} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>A layout primitive only — adds no roles or semantics of its own.</li>
      <li>If the pills represent a set of filters or selections, give the wrapper an <code>aria-label</code> or group role at the call site.</li>
    </ul>
  </Section>

  <Section id="tokens" title="Tokens">
    <ul class="tokens">
      <li><code>--spacing-100</code> (small) · <code>--spacing-200</code> (medium) · <code>--spacing-300</code> (large) — via the private <code>--_pillbox-gap</code> token</li>
    </ul>
  </Section>
</ComponentDoc>
