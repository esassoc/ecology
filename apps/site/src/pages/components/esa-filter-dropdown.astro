---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';

const props = [
  { name: 'name', type: 'string', default: "''", description: 'Filter key carried in emitted events.' },
  { name: 'label', type: 'string', default: "''", description: 'Trigger label; selection appends "label: value".' },
  { name: 'options', type: '{ label, value, disabled? }[]', default: '[]', description: 'Selectable options (set as a property, not an attribute).' },
  { name: 'multiple', type: 'boolean', default: 'false', description: 'Allow multiple selections; trigger shows "first +N".' },
  { name: 'placeholder', type: 'string', default: "''", description: 'Search-input placeholder (defaults to "Search…").' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Trigger height, padding, font size, and radius.' },
];

const events = [
  { name: 'selection-change', type: '{ value: string | string[] }', description: 'Fires on every selection change. value is a string in single mode, an array in multiple mode.' },
  { name: 'esa-filter-change', type: '{ name, filters: ActiveFilter[] }', description: 'Bubbling/composed. Carries the filter name plus the full active-filter list for a parent container to coordinate state.' },
];
---
<ComponentDoc name="Filter Dropdown" category="Filters" slug="esa-filter-dropdown" type="wc" status="stable"
  summary="Interactive dropdown filter (Lit web component) with a searchable panel, full keyboard navigation, and single or multi select. The trigger fills with the primary color when active and shows an inline clear control.">

  <Section id="preview" title="Preview">
    <p>Click the trigger to open the panel, type to filter, and use Arrow/Enter/Escape to navigate. Outside-click and Escape close it. Options are set as a property in a small init script.</p>
    <Preview code={`<esa-filter-dropdown name="status" label="Status"></esa-filter-dropdown>

<script>
  import '@esa/ecology/esa-filter-dropdown';
  customElements.whenDefined('esa-filter-dropdown').then(() => {
    document.querySelector('esa-filter-dropdown').options = [
      { label: 'Open', value: 'open' },
      { label: 'In review', value: 'review' },
      { label: 'Closed', value: 'closed' },
    ];
  });
<\/script>`}>
      <esa-filter-dropdown data-opts="status" name="status" label="Status"></esa-filter-dropdown>
    </Preview>
  </Section>

  <Section id="select-modes" title="Select modes">
    <p>Single select closes on choice; <code>multiple</code> keeps the panel open, shows checkmarks, and renders "first +N" in the trigger.</p>
    <Preview code={`<esa-filter-dropdown name="status" label="Status"></esa-filter-dropdown>
<esa-filter-dropdown name="dept" label="Department" multiple></esa-filter-dropdown>`}>
      <esa-filter-dropdown data-opts="status" name="status" label="Status"></esa-filter-dropdown>
      <esa-filter-dropdown data-opts="dept" name="dept" label="Department" multiple></esa-filter-dropdown>
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview code={`<esa-filter-dropdown label="XS" size="xs"></esa-filter-dropdown>
<esa-filter-dropdown label="Small" size="sm"></esa-filter-dropdown>
<esa-filter-dropdown label="Medium" size="md"></esa-filter-dropdown>
<esa-filter-dropdown label="Large" size="lg"></esa-filter-dropdown>`}>
      <esa-filter-dropdown data-opts="status" name="s0" label="XS" size="xs"></esa-filter-dropdown>
      <esa-filter-dropdown data-opts="status" name="s1" label="Small" size="sm"></esa-filter-dropdown>
      <esa-filter-dropdown data-opts="status" name="s2" label="Medium" size="md"></esa-filter-dropdown>
      <esa-filter-dropdown data-opts="status" name="s3" label="Large" size="lg"></esa-filter-dropdown>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Disabled options are dimmed, skipped by keyboard navigation, and not selectable.</p>
    <Preview code={`<esa-filter-dropdown name="priority" label="Priority"></esa-filter-dropdown>
<!-- options include { label: 'High', value: 'high', disabled: true } -->`}>
      <esa-filter-dropdown data-opts="withDisabled" name="priority" label="Priority"></esa-filter-dropdown>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="events" title="Events">
    <Api props={events} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Trigger is a native <code>&lt;button&gt;</code> with <code>aria-haspopup="listbox"</code> and <code>aria-expanded</code> reflecting open state.</li>
      <li>Panel is a <code>role="listbox"</code>; each option is <code>role="option"</code> with <code>aria-selected</code> and <code>aria-disabled</code>.</li>
      <li>Keyboard: ArrowUp/Down highlight (skipping disabled), Enter selects, Escape closes. Opening focuses the search input.</li>
      <li>Visible focus ring on the trigger via <code>--focus-ring-*</code> tokens.</li>
    </ul>
  </Section>

  <Section id="tokens" title="Tokens">
    <p>Override the component-scoped tokens to re-skin the trigger and panel without forking the element:</p>
    <ul class="tokens">
      <li><code>--color-primary</code> — active trigger fill, selected option, search focus</li>
      <li><code>--color-surface</code> · <code>--color-border</code> · <code>--color-text-primary</code> / <code>--color-text-inverse</code></li>
      <li><code>--filter-dropdown-bg</code> / <code>--filter-dropdown-border</code> / <code>--filter-dropdown-radius</code> / <code>--filter-dropdown-shadow</code> / <code>--filter-dropdown-min-width</code></li>
      <li><code>--radius-*</code> · <code>--spacing-*</code> · <code>--type-size-*</code> · <code>--z-dropdown</code></li>
      <li><code>--focus-ring-width</code> / <code>--focus-ring-color</code> / <code>--focus-ring-offset</code></li>
    </ul>
  </Section>

  <script>
    import '@esa/ecology/esa-filter-dropdown';
    const sets: Record<string, { label: string; value: string; disabled?: boolean }[]> = {
      status: [
        { label: 'Open', value: 'open' },
        { label: 'In review', value: 'review' },
        { label: 'Closed', value: 'closed' },
        { label: 'Archived', value: 'archived' },
      ],
      dept: [
        { label: 'Water Quality', value: 'water' },
        { label: 'Air Quality', value: 'air' },
        { label: 'Toxics Cleanup', value: 'toxics' },
        { label: 'Waste Management', value: 'waste' },
      ],
      withDisabled: [
        { label: 'Low', value: 'low' },
        { label: 'Medium', value: 'medium' },
        { label: 'High', value: 'high', disabled: true },
        { label: 'Critical', value: 'critical' },
      ],
    };
    customElements.whenDefined('esa-filter-dropdown').then(() => {
      document.querySelectorAll('esa-filter-dropdown').forEach((el) => {
        const key = el.getAttribute('data-opts');
        if (key && sets[key]) (el as any).options = sets[key];
      });
    });
  </script>
</ComponentDoc>
