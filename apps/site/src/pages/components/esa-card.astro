---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
import Card from '@esa/ecology/esa-card.astro';
---
<BaseLayout title="Card — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>Card</h1>
      <p>Surface container with optional header (icon, title, subtitle, actions), body, and footer. Variants, header tints, and padding scales.</p>
    </Stack>

    <Stack gap="300">
      <h2>Variants</h2>
      <Stack gap="300" direction="row" wrap={true}>
        <div style="width: 260px;">
          <Card title="Default" subtitle="Bordered surface">
            <p>Body content for the default card.</p>
          </Card>
        </div>
        <div style="width: 260px;">
          <Card variant="elevated" title="Elevated" subtitle="Shadow, no border">
            <p>Body content for the elevated card.</p>
          </Card>
        </div>
        <div style="width: 260px;">
          <Card variant="filled" title="Filled" subtitle="Sunken background">
            <p>Body content for the filled card.</p>
          </Card>
        </div>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Header variants</h2>
      <Stack gap="300" direction="row" wrap={true}>
        <div style="width: 260px;">
          <Card headerVariant="primary" title="Primary header" subtitle="Inverted text">
            <p>Tinted header band.</p>
          </Card>
        </div>
        <div style="width: 260px;">
          <Card headerVariant="muted" title="Muted header">
            <p>Subtle sunken header.</p>
          </Card>
        </div>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Padding</h2>
      <Stack gap="300" direction="row" wrap={true}>
        <div style="width: 220px;">
          <Card padding="compact" title="Compact"><p>Tighter body.</p></Card>
        </div>
        <div style="width: 220px;">
          <Card padding="default" title="Default"><p>Standard body.</p></Card>
        </div>
        <div style="width: 220px;">
          <Card padding="spacious" title="Spacious"><p>Roomy body.</p></Card>
        </div>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>With actions &amp; footer slots</h2>
      <div style="max-width: 420px;">
        <Card title="Report" subtitle="Q3 summary" icon="info">
          <button slot="actions" type="button">Edit</button>
          <p>The actions slot sits at the right of the header; the footer slot renders a bottom band.</p>
          <span slot="footer">Last updated 2 hours ago</span>
        </Card>
      </div>
    </Stack>

    <Stack gap="300">
      <h2>Anatomy &amp; behavior</h2>
      <ul>
        <li><strong>Slots:</strong> default → body, <code>header</code> (replaces title block), <code>actions</code>, <code>footer</code>.</li>
        <li><strong>Tokens consumed:</strong> surface / surface-sunken / border / border-light / primary / text-inverse, radius-300, shadow-100, spacing scale.</li>
      </ul>
    </Stack>
  </Stack>
</BaseLayout>
