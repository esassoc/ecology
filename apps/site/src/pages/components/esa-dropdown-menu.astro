---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';

const props = [
  { name: 'items', type: 'EsaMenuItem[]', default: '[]', description: 'Menu items, set as a property. Each: { label, icon?, action?, disabled?, divider?, variant? }.' },
  { name: 'position', type: "'below-start' | 'below-end' | 'above-start' | 'above-end'", default: "'below-start'", description: 'Corner the panel anchors to.' },
  { name: 'width', type: "'auto' | 'trigger'", default: "'auto'", description: "'trigger' matches the panel min-width to the trigger." },
  { name: 'open', type: 'boolean', default: 'false', description: 'Reflected open state.' },
];

const methods = [
  { name: 'close()', type: 'method', description: 'Closes the menu programmatically.' },
];

const events = [
  { name: 'menu-action', type: 'CustomEvent<string>', description: "Fired when a non-disabled item with an action is selected; detail is the item's action string." },
];
---
<ComponentDoc name="Dropdown Menu" category="Overlays" slug="esa-dropdown-menu" type="wc" status="stable"
  summary="Click-toggled menu. The trigger is slotted and items are set via the <code>items</code> property. Selecting emits a <code>menu-action</code> event; outside-click and Esc close it.">

  <Section id="preview" title="Preview">
    <p>Items are set in a script: <code>el.items = [{'{ label: "Edit", action: "edit" }'}, …]</code>.</p>
    <Preview code={`<esa-dropdown-menu id="dd-start" position="below-start">
  <button>Actions ▾</button>
</esa-dropdown-menu>`}>
      <esa-dropdown-menu id="dd-start" position="below-start">
        <button class="trigger">Actions ▾</button>
      </esa-dropdown-menu>
      <p id="result" class="result"></p>
    </Preview>
  </Section>

  <Section id="positions" title="Positions">
    <Preview code={`<esa-dropdown-menu position="below-start">…</esa-dropdown-menu>
<esa-dropdown-menu position="below-end">…</esa-dropdown-menu>`}>
      <esa-dropdown-menu id="dd-end" position="below-end">
        <button class="trigger">below-end ▾</button>
      </esa-dropdown-menu>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
    <h3>Methods</h3>
    <PropsTable rows={methods} />
    <Api events={events} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>The panel is <code>role="menu"</code> and each item is <code>role="menuitem"</code>; dividers are <code>role="separator"</code>.</li>
      <li>Disabled items set the native <code>disabled</code> attribute and are skipped on activation.</li>
      <li><code>Escape</code> and any outside click close the menu.</li>
    </ul>
  </Section>

</ComponentDoc>

<script>
  import '@esa/ecology/esa-dropdown-menu';

  const items = [
    { label: 'Edit', icon: 'pencil', action: 'edit' },
    { label: 'Duplicate', icon: 'copy', action: 'duplicate' },
    { divider: true },
    { label: 'Archive', icon: 'archive', action: 'archive', disabled: true },
    { label: 'Delete', icon: 'trash', action: 'delete', variant: 'danger' },
  ];

  const result = document.getElementById('result')!;
  document.querySelectorAll('esa-dropdown-menu').forEach((el: any) => {
    el.items = items;
    el.addEventListener('menu-action', (e: Event) => {
      result.textContent = `Selected: ${(e as CustomEvent).detail}`;
    });
  });
</script>

<style>
  .trigger {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-200);
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    color: var(--color-text-primary);
    font-family: inherit;
    font-size: var(--type-size-200);
    cursor: pointer;
  }
  .result { color: var(--color-text-muted); min-height: 1.5em; width: 100%; }
</style>
