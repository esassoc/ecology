---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';
import EsaHeaderNav from '@esa/ecology/esa-header-nav.astro';

const items = [
  { label: 'Dashboard', href: '/dashboard' },
  { label: 'Projects', href: '/projects' },
  {
    label: 'Reports',
    children: [
      { label: 'Monthly', href: '/reports/monthly' },
      { label: 'Quarterly', href: '/reports/quarterly' },
      { label: 'Annual', href: '/reports/annual' },
    ],
  },
  { label: 'Settings', href: '/settings' },
];

const user = { name: 'Jordan Rivers', email: 'jordan@esassoc.com' };

const props = [
  { name: 'items', type: 'EsaHeaderNavItem[]', default: '[]', description: 'Primary nav links. Each is { label; href?; icon?; children? }; an item with children renders a dropdown.' },
  { name: 'user', type: 'EsaHeaderNavUser', description: 'Optional signed-in user { name; email?; avatarUrl?; initials? }. When present, renders the avatar + user menu.' },
];

const slots = [
  { name: 'brand', type: 'slot', description: 'Left-aligned logo / wordmark area.' },
  { name: 'actions', type: 'slot', description: 'Right-aligned controls placed before the user menu (e.g. search, notifications).' },
];
---
<ComponentDoc name="Header Nav" category="Navigation" slug="esa-header-nav" type=".astro" status="stable"
  summary="A batteries-included top app bar composed from the chrome bricks (esa-app-bar + esa-icon-link + esa-nav-dropdown): brand slot, data-driven primary nav with dropdowns, an actions slot, and a user menu. Disclosures are native details/summary, so it needs zero runtime JS. For full control, compose the bricks directly.">

  <Section id="preview" title="Preview">
    <p>Open <strong>Reports</strong> or the avatar to expand the native disclosures.</p>
    <Preview align="start" code={`<EsaHeaderNav items={items} user={user}>
  <strong slot="brand">ESA</strong>
</EsaHeaderNav>`}>
      <div style="width: 100%; border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-200, 8px); overflow: visible;">
        <EsaHeaderNav items={items} user={user}>
          <strong slot="brand" style="color: var(--color-primary, #43608a); font-size: var(--type-size-300, 1.125rem);">ESA</strong>
        </EsaHeaderNav>
      </div>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Brand only, no signed-in user — the avatar / user menu is omitted when <code>user</code> is absent.</p>
    <Preview align="start" code={`<EsaHeaderNav items={items}>
  <strong slot="brand">Beacon</strong>
</EsaHeaderNav>`}>
      <div style="width: 100%; border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-200, 8px); overflow: visible;">
        <EsaHeaderNav items={items}>
          <strong slot="brand" style="color: var(--color-primary, #43608a); font-size: var(--type-size-300, 1.125rem);">Beacon</strong>
        </EsaHeaderNav>
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
    <h3>Slots</h3>
    <PropsTable rows={slots} />
    <p>Nav dropdowns and the user menu are native details/summary disclosures (via esa-nav-dropdown) — no JavaScript required.</p>
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Each item with children renders an <code>esa-nav-dropdown</code> disclosure; plain items render an <code>esa-icon-link</code>.</li>
      <li>Disclosures are native details/summary — keyboard toggling and the expanded state come for free.</li>
      <li>The avatar button carries an <code>aria-label</code> naming the user (<code>User menu for …</code>).</li>
      <li>Decorative chevrons and glyph SVGs are <code>aria-hidden</code>.</li>
    </ul>
  </Section>

</ComponentDoc>
