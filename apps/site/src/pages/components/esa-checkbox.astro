---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';

const props = [
  { name: 'label', type: 'string', default: "''", description: 'Text rendered beside the box.' },
  { name: 'checked', type: 'boolean', default: 'false', description: 'Whether the box is checked.' },
  { name: 'indeterminate', type: 'boolean', default: 'false', description: 'Renders the mixed/partial state with a dash.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Box and label size.' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables interaction.' },
];

const events = [
  { name: 'change', type: 'CustomEvent<{ checked: boolean }>', description: 'Fired when toggled. Composed and bubbling; detail.checked is the new state.' },
];
---
<ComponentDoc name="Checkbox" category="Forms" slug="esa-checkbox" type="wc" status="stable"
  summary="A custom box with checked, indeterminate, and disabled states, Space/Enter keyboard toggling, and an inlined Lucide check icon. Form-associated; emits a composed <code>change</code> event.">

  <Section id="preview" title="Preview">
    <Preview code={`<esa-checkbox label="Subscribe to updates" checked></esa-checkbox>`}>
      <esa-checkbox label="Subscribe to updates" checked></esa-checkbox>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <Preview align="start" code={`<esa-checkbox label="Unchecked"></esa-checkbox>
<esa-checkbox label="Checked" checked></esa-checkbox>
<esa-checkbox label="Indeterminate" indeterminate></esa-checkbox>
<esa-checkbox label="Disabled" disabled></esa-checkbox>
<esa-checkbox label="Disabled + checked" disabled checked></esa-checkbox>`}>
      <div class="col">
        <esa-checkbox label="Unchecked"></esa-checkbox>
        <esa-checkbox label="Checked" checked></esa-checkbox>
        <esa-checkbox label="Indeterminate" indeterminate></esa-checkbox>
        <esa-checkbox label="Disabled" disabled></esa-checkbox>
        <esa-checkbox label="Disabled + checked" disabled checked></esa-checkbox>
      </div>
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview code={`<esa-checkbox label="Extra small" size="xs" checked></esa-checkbox>
<esa-checkbox label="Small" size="sm" checked></esa-checkbox>
<esa-checkbox label="Medium" size="md" checked></esa-checkbox>
<esa-checkbox label="Large" size="lg" checked></esa-checkbox>`}>
      <esa-checkbox label="Extra small" size="xs" checked></esa-checkbox>
      <esa-checkbox label="Small" size="sm" checked></esa-checkbox>
      <esa-checkbox label="Medium" size="md" checked></esa-checkbox>
      <esa-checkbox label="Large" size="lg" checked></esa-checkbox>
    </Preview>
  </Section>

  <Section id="no-label" title="No label">
    <p>Omit <code>label</code> for a bare box — supply an <code>aria-label</code> for an accessible name.</p>
    <Preview code={`<esa-checkbox checked aria-label="Select row"></esa-checkbox>`}>
      <esa-checkbox checked aria-label="Select row"></esa-checkbox>
    </Preview>
  </Section>

  <Section id="form" title="Form participation">
    <p>Checked boxes submit <code>on</code> under their <code>name</code>; unchecked boxes submit nothing.</p>
    <Preview code={`<form>
  <esa-checkbox label="Subscribe" name="subscribe" checked></esa-checkbox>
  <button type="submit">Submit</button>
</form>`}>
      <form id="cb-form" class="form-demo">
        <esa-checkbox label="Subscribe" name="subscribe" checked></esa-checkbox>
        <button type="submit" class="demo-submit">Submit</button>
        <output id="cb-out" class="demo-out"></output>
      </form>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} events={events} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>The box has <code>role="checkbox"</code> with <code>aria-checked</code> reflecting checked or <code>mixed</code> (indeterminate).</li>
      <li>Focusable via <code>tabindex</code> and toggles on Space or Enter.</li>
      <li><code>aria-disabled</code> and a <code>-1</code> tabindex are applied when disabled.</li>
      <li>Without a <code>label</code>, provide an <code>aria-label</code> for an accessible name.</li>
    </ul>
  </Section>

</ComponentDoc>

<style>
  .col { display: flex; flex-direction: column; gap: var(--spacing-300); align-items: flex-start; }
  .form-demo { display: flex; flex-direction: column; gap: var(--spacing-300); align-items: flex-start; }
  .demo-submit {
    font: inherit;
    padding: var(--spacing-200) var(--spacing-400);
    border: 0;
    border-radius: var(--radius-200);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    cursor: pointer;
  }
  .demo-out { font-family: var(--font-mono); font-size: 14px; color: var(--color-text-secondary); }
</style>

<script>
  import '@esa/ecology/esa-checkbox';
  const form = document.getElementById('cb-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form as HTMLFormElement);
    document.getElementById('cb-out')!.textContent =
      'subscribe = ' + JSON.stringify(data.get('subscribe'));
  });
</script>
