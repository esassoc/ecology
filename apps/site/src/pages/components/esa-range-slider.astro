---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';

const props = [
  { name: 'label', type: 'string', default: "''", description: 'Field label above the track.' },
  { name: 'value', type: 'number', default: '0', description: 'Current value.' },
  { name: 'min', type: 'number', default: '0', description: 'Minimum value.' },
  { name: 'max', type: 'number', default: '100', description: 'Maximum value.' },
  { name: 'step', type: 'number', default: '1', description: 'Step increment.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Track/thumb size (reflected attribute).' },
  { name: 'show-value', type: 'boolean', default: 'true', description: 'Show the live value readout beside the track.' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables interaction (reflected attribute).' },
];

const events = [
  { name: 'change', type: 'CustomEvent<{ value: number }>', description: 'Fired on input as the thumb moves. Value is a number. Composed and bubbles.' },
];
---
<ComponentDoc name="Range Slider" category="Forms" slug="esa-range-slider" type="wc" status="stable"
  summary="Form-associated range slider with a token-driven fill gradient and live value readout. A Lit Web Component migrated from the Angular <code>esa-range-slider</code>.">

  <Section id="preview" title="Preview">
    <Preview code={`<esa-range-slider label="Volume" value="40"></esa-range-slider>`}>
      <esa-range-slider label="Volume" value="40"></esa-range-slider>
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview code={`<esa-range-slider label="Extra small" size="xs" value="15"></esa-range-slider>
<esa-range-slider label="Small" size="sm" value="25"></esa-range-slider>
<esa-range-slider label="Medium" size="md" value="50"></esa-range-slider>
<esa-range-slider label="Large" size="lg" value="75"></esa-range-slider>`}>
      <esa-range-slider label="Extra small" size="xs" value="15"></esa-range-slider>
      <esa-range-slider label="Small" size="sm" value="25"></esa-range-slider>
      <esa-range-slider label="Medium" size="md" value="50"></esa-range-slider>
      <esa-range-slider label="Large" size="lg" value="75"></esa-range-slider>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Set a custom <code>min</code>/<code>max</code>/<code>step</code>, hide the readout with <code>show-value={'{false}'}</code>, or disable the control.</p>
    <Preview code={`<esa-range-slider label="Temperature (°F)" min="60" max="90" step="5" value="72"></esa-range-slider>
<esa-range-slider label="Hidden value" value="60" show-value="false"></esa-range-slider>
<esa-range-slider label="Disabled" value="30" disabled></esa-range-slider>`}>
      <esa-range-slider label="Temperature (°F)" min="60" max="90" step="5" value="72"></esa-range-slider>
      <esa-range-slider label="Hidden value" value="60" show-value={false}></esa-range-slider>
      <esa-range-slider label="Disabled" value="30" disabled></esa-range-slider>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} events={events} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Renders a native <code>&lt;input type="range"&gt;</code> — Arrow keys step, Home/End jump to min/max, PageUp/Down move in large steps.</li>
      <li>Carries <code>aria-label</code> (falls back to "Range slider") plus <code>aria-valuemin</code> / <code>aria-valuemax</code> / <code>aria-valuenow</code>.</li>
      <li>Form-associated via <code>ElementInternals</code> — value submits with the enclosing form.</li>
    </ul>
  </Section>

</ComponentDoc>

<script>import '@esa/ecology/esa-range-slider';</script>

<style>
  h3 { font-size: 16px; font-weight: 600; margin: var(--spacing-500) 0 var(--spacing-200); }
</style>
