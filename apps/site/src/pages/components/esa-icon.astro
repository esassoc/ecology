---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';

// The names available in the inlined Lucide lookup (see esa-icon.astro).
const names = [
  'home', 'settings', 'plus', 'x', 'check',
  'chevron-down', 'chevron-up', 'chevron-left', 'chevron-right',
  'chevrons-left', 'chevrons-right', 'search', 'filter',
  'arrow-left', 'arrow-right', 'arrow-up', 'arrow-down',
  'circle-alert', 'circle-check', 'circle-x', 'info', 'eye',
  'pencil', 'trash-2', 'copy', 'download', 'upload', 'external-link',
  'calendar', 'user', 'users', 'star', 'loader', 'menu', 'bell',
  'triangle-alert', 'save', 'circle-question-mark',
];

const props = [
  { name: 'name', type: 'string', description: 'Lucide icon name (kebab-case), e.g. "chevron-down". Resolved against the inlined Lucide lookup; an unknown name renders an empty glyph.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg' | 'xl'", default: "'md'", description: 'Icon size — xs=14, sm=16, md=20, lg=24, xl=28.' },
  { name: 'label', type: 'string', description: 'Accessible label. When provided the icon becomes role="img"; when omitted the icon is decorative (aria-hidden).' },
];
---
<ComponentDoc name="Icon" category="Core" slug="esa-icon" type=".astro" status="stable"
  summary="The icon primitive across Ecology. It inlines the Lucide SVGs it needs (no icon dependency), inherits color via <code>currentColor</code>, and maps to five sizes — xs=14, sm=16, md=20, lg=24, xl=28.">

  <Section id="preview" title="Preview">
    <Preview code={`<EsaIcon name="star" size="md" />`}>
      <EsaIcon name="star" size="md" />
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <p>Three sizes map to fixed pixel boxes via the <code>--icon-size-*</code> tokens.</p>
    <Preview align="center" code={`<EsaIcon name="star" size="xs" />
<EsaIcon name="star" size="sm" />
<EsaIcon name="star" size="md" />
<EsaIcon name="star" size="lg" />
<EsaIcon name="star" size="xl" />`}>
      <EsaIcon name="star" size="xs" />
      <EsaIcon name="star" size="sm" />
      <EsaIcon name="star" size="md" />
      <EsaIcon name="star" size="lg" />
      <EsaIcon name="star" size="xl" />
    </Preview>
  </Section>

  <Section id="color" title="Color">
    <p>Icons inherit <code>currentColor</code>, so they take the text color of their context — set <code>color</code> on a wrapper to tint them.</p>
    <Preview align="center" code={`<span style="color: var(--color-primary)"><EsaIcon name="circle-check" size="lg" /></span>
<span style="color: var(--color-warning)"><EsaIcon name="triangle-alert" size="lg" /></span>
<span style="color: var(--color-danger)"><EsaIcon name="circle-x" size="lg" /></span>
<span style="color: var(--color-info)"><EsaIcon name="info" size="lg" /></span>`}>
      <span style="color: var(--color-primary, #43608a)"><EsaIcon name="circle-check" size="lg" /></span>
      <span style="color: var(--color-warning, #f59e0b)"><EsaIcon name="triangle-alert" size="lg" /></span>
      <span style="color: var(--color-danger, #ef4444)"><EsaIcon name="circle-x" size="lg" /></span>
      <span style="color: var(--color-info, #3b82f6)"><EsaIcon name="info" size="lg" /></span>
    </Preview>
  </Section>

  <Section id="gallery" title="Gallery">
    <p>The icons currently inlined in the lookup. Add entries to <code>esa-icon.astro</code> as new components need them.</p>
    <div class="icon-grid">
      {names.map((n) => (
        <div class="icon-cell">
          <EsaIcon name={n} size="md" />
          <code>{n}</code>
        </div>
      ))}
    </div>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li><strong>Decorative (default):</strong> no <code>label</code> → the icon is <code>aria-hidden="true"</code> and skipped by screen readers.</li>
      <li><strong>Meaningful:</strong> pass <code>label</code> → the icon gets <code>role="img"</code> + <code>aria-label</code>, e.g. <EsaIcon name="bell" label="Notifications" />.</li>
      <li>The inner <code>&lt;svg&gt;</code> is <code>focusable="false"</code> to keep it out of the tab order in legacy browsers.</li>
    </ul>
  </Section>

</ComponentDoc>

<style>
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: var(--spacing-300, 0.75rem);
  }
  .icon-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-200, 0.5rem);
    padding: var(--spacing-300, 0.75rem);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--radius-200, 8px);
    text-align: center;
  }
  .icon-cell code { font-size: var(--type-size-100, 0.75rem); background: none; }
</style>
