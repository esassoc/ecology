---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
---
<BaseLayout title="Search Panel — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>Search Panel <code>[wc]</code></h1>
      <p>A slide-in search overlay. Open it, type a query, and pick a result. It is form-associated — the current query is mirrored into the owning form — and also dispatches bubbling <code>search</code> and <code>result-select</code> events. Esc or the backdrop closes it.</p>
    </Stack>

    <Stack gap="300">
      <h2>From the right (default)</h2>
      <Stack gap="200" direction="row" align="center" wrap={true}>
        <button class="trigger" id="open-right">Open search</button>
      </Stack>
      <p id="status-right" class="result"></p>
    </Stack>

    <Stack gap="300">
      <h2>From the left</h2>
      <Stack gap="200" direction="row" align="center" wrap={true}>
        <button class="trigger" id="open-left">Open search (left)</button>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Loading state</h2>
      <Stack gap="200" direction="row" align="center" wrap={true}>
        <button class="trigger" id="open-loading">Open (loading)</button>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Usage</h2>
      <ul>
        <li><strong>Open/close:</strong> set the <code>open</code> property/attribute (reflected). Closing fires <code>open-change</code>.</li>
        <li><strong>Results:</strong> set the <code>results</code> property to an array of <code>{'{ id, title, subtitle?, icon?, category? }'}</code>. Items with the same <code>category</code> are grouped.</li>
        <li><strong>Events:</strong> <code>search</code> &rarr; <code>{'{ value }'}</code>; <code>result-select</code> &rarr; the selected result.</li>
        <li><strong>Form value:</strong> the live query participates in the enclosing <code>&lt;form&gt;</code>.</li>
      </ul>
    </Stack>

    <esa-search-panel id="sp-right" position="right"></esa-search-panel>
    <esa-search-panel id="sp-left" position="left"></esa-search-panel>
    <esa-search-panel id="sp-loading" position="right" loading></esa-search-panel>
  </Stack>
</BaseLayout>

<script>
  import '@esa/ecology/esa-search-panel';

  const sampleResults = [
    { id: 'r1', title: 'Wetland delineation report', subtitle: 'Project 2024-118', icon: 'file', category: 'Documents' },
    { id: 'r2', title: 'Air quality monitoring plan', subtitle: 'Draft', icon: 'file', category: 'Documents' },
    { id: 'r3', title: 'North watershed', subtitle: 'Region', icon: 'pin', category: 'Places' },
    { id: 'r4', title: 'Coastal zone', subtitle: 'Region', icon: 'pin', category: 'Places' },
    { id: 'r5', title: 'Jane Doe', subtitle: 'Compliance officer', category: 'People' },
  ];

  const status = document.getElementById('status-right')!;

  const right = document.getElementById('sp-right') as any;
  right.results = sampleResults;
  right.addEventListener('search', (e: any) => {
    status.textContent = e.detail.value ? `Searching: "${e.detail.value}"` : '';
  });
  right.addEventListener('result-select', (e: any) => {
    status.textContent = `Selected: ${e.detail.title}`;
    right.open = false;
  });
  document.getElementById('open-right')!.addEventListener('click', () => (right.open = true));

  const left = document.getElementById('sp-left') as any;
  left.results = sampleResults;
  left.addEventListener('result-select', () => (left.open = false));
  document.getElementById('open-left')!.addEventListener('click', () => (left.open = true));

  const loading = document.getElementById('sp-loading') as any;
  document.getElementById('open-loading')!.addEventListener('click', () => (loading.open = true));
</script>

<style>
  .trigger {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-200, 0.5rem);
    border: 1px solid var(--color-border-strong, #d4d4d4);
    background: var(--color-primary, #005862);
    color: var(--color-text-inverse, #fff);
    font-family: inherit;
    font-size: var(--type-size-200, 0.9375rem);
    cursor: pointer;
  }
  .result {
    color: var(--color-text-muted, #737373);
    min-height: 1.5em;
  }
</style>
