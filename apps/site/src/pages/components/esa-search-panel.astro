---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';

const props = [
  { name: 'open', type: 'boolean', default: 'false', description: 'Reflected attribute that drives visibility. Toggle by setting the property.' },
  { name: 'placeholder', type: 'string', default: "'Search...'", description: 'Input placeholder text.' },
  { name: 'results', type: 'EsaSearchResult[]', default: '[]', description: 'Results to render, set as a property. Each: { id, title, subtitle?, icon?, category? }. Same-category items are grouped.' },
  { name: 'loading', type: 'boolean', default: 'false', description: 'Reflected; shows a loading message instead of results.' },
  { name: 'position', type: "'right' | 'left'", default: "'right'", description: 'Side the panel slides in from.' },
];

const events = [
  { name: 'search', type: 'CustomEvent<{ value: string }>', description: 'Fired on each input change with the current query.' },
  { name: 'result-select', type: 'CustomEvent<EsaSearchResult>', description: 'Fired when a result is chosen.' },
  { name: 'open-change', type: 'CustomEvent<{ open: boolean }>', description: 'Fired when the panel closes (Esc or backdrop).' },
];
---
<ComponentDoc name="Search Panel" category="Overlays" slug="esa-search-panel" type="wc" status="stable"
  summary="A slide-in search overlay. Open it, type a query, and pick a result. It is form-associated — the live query is mirrored into the owning form — and also dispatches bubbling <code>search</code> and <code>result-select</code> events. Esc or the backdrop closes it.">

  <Section id="preview" title="Preview">
    <p>Set <code>el.results</code> in a script, then open with <code>el.open = true</code>.</p>
    <Preview code={`<button id="open-right">Open search</button>

<esa-search-panel id="sp-right" position="right"></esa-search-panel>`}>
      <button class="trigger" id="open-right">Open search</button>
      <esa-search-panel id="sp-right" position="right"></esa-search-panel>
      <p id="status-right" class="result"></p>
    </Preview>
  </Section>

  <Section id="positions" title="Positions">
    <p>The panel slides in from the <code>right</code> (default) or the <code>left</code>.</p>
    <Preview code={`<esa-search-panel position="right"></esa-search-panel>
<esa-search-panel position="left"></esa-search-panel>`}>
      <button class="trigger" id="open-left">Open search (left)</button>
      <esa-search-panel id="sp-left" position="left"></esa-search-panel>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Set <code>loading</code> to show a searching message while results are fetched.</p>
    <Preview code={`<esa-search-panel position="right" loading></esa-search-panel>`}>
      <button class="trigger" id="open-loading">Open (loading)</button>
      <esa-search-panel id="sp-loading" position="right" loading></esa-search-panel>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} events={events} />
    <p>The live query also participates in the enclosing <code>&lt;form&gt;</code> via <code>ElementInternals</code>.</p>
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>The panel is <code>role="search"</code>; the close button carries an <code>aria-label</code>.</li>
      <li>The input is focused automatically when the panel opens.</li>
      <li><code>Escape</code> and backdrop click both close the panel and fire <code>open-change</code>.</li>
    </ul>
  </Section>

</ComponentDoc>

<script>
  import '@esa/ecology/esa-search-panel';

  const sampleResults = [
    { id: 'r1', title: 'Wetland delineation report', subtitle: 'Project 2024-118', icon: 'file', category: 'Documents' },
    { id: 'r2', title: 'Air quality monitoring plan', subtitle: 'Draft', icon: 'file', category: 'Documents' },
    { id: 'r3', title: 'North watershed', subtitle: 'Region', icon: 'pin', category: 'Places' },
    { id: 'r4', title: 'Coastal zone', subtitle: 'Region', icon: 'pin', category: 'Places' },
    { id: 'r5', title: 'Jane Doe', subtitle: 'Compliance officer', category: 'People' },
  ];

  const status = document.getElementById('status-right')!;

  const right = document.getElementById('sp-right') as any;
  right.results = sampleResults;
  right.addEventListener('search', (e: any) => {
    status.textContent = e.detail.value ? `Searching: "${e.detail.value}"` : '';
  });
  right.addEventListener('result-select', (e: any) => {
    status.textContent = `Selected: ${e.detail.title}`;
    right.open = false;
  });
  document.getElementById('open-right')!.addEventListener('click', () => (right.open = true));

  const left = document.getElementById('sp-left') as any;
  left.results = sampleResults;
  left.addEventListener('result-select', () => (left.open = false));
  document.getElementById('open-left')!.addEventListener('click', () => (left.open = true));

  const loading = document.getElementById('sp-loading') as any;
  document.getElementById('open-loading')!.addEventListener('click', () => (loading.open = true));
</script>

<style>
  .trigger {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-200);
    border: 1px solid var(--color-border-strong);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    font-family: inherit;
    font-size: var(--type-size-200);
    cursor: pointer;
  }
  .result { color: var(--color-text-muted); min-height: 1.5em; width: 100%; }
</style>
