---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';

const props = [
  { name: 'items', type: 'EsaSidebarNavItem[]', default: '[]', description: 'Nav items (property, set via JS). Each is { label; href?; icon?; badge?; children?; disabled?; group?; active? }. Consecutive items sharing a group render under a group heading.' },
  { name: 'collapsed', type: 'boolean', default: 'false', description: 'Collapses to an icon rail. Reflected as an attribute.' },
  { name: 'collapsible', type: 'boolean', default: 'true', description: 'Shows the collapse toggle. Set false to lock the sidebar open.' },
];

const events = [
  { name: 'collapsedchange', type: 'CustomEvent', description: 'Fired when the collapse toggle is clicked. detail: { collapsed: boolean }. Bubbles and composed.' },
];

const slots = [
  { name: 'header', type: 'slot', description: 'Logo / brand area pinned above the nav list.' },
];
---
<ComponentDoc name="Sidebar Nav" category="Navigation" slug="esa-sidebar-nav" type="wc" status="stable"
  summary="Collapsible side navigation with grouped sections, accordion children, badges, and a collapse-to-rail toggle. A Lit web component, because the collapse and accordion states are real runtime behavior.">

  <Section id="preview" title="Preview">
    <p>Use the chevrons button at the top to collapse to an icon rail; click <strong>Reports</strong> to expand its children.</p>
    <Preview align="start" lang="html" code={`<esa-sidebar-nav id="demo"></esa-sidebar-nav>

<script>
  const el = document.getElementById('demo');
  el.items = [
    { label: 'Dashboard', href: '/dashboard', active: true, group: 'Main' },
    { label: 'Projects', href: '/projects', badge: 12, group: 'Main' },
    { label: 'Reports', group: 'Main', children: [
      { label: 'Monthly', href: '/reports/monthly' },
      { label: 'Quarterly', href: '/reports/quarterly' },
    ] },
    { label: 'Team', href: '/team', group: 'Admin' },
    { label: 'Billing', href: '/billing', group: 'Admin', disabled: true },
    { label: 'Settings', href: '/settings', group: 'Admin' },
  ];
</script>`}>
      <div style="width: 100%; height: 460px; display: flex; border: 1px solid var(--color-border); border-radius: var(--radius-200); overflow: hidden;">
        <esa-sidebar-nav id="demo"></esa-sidebar-nav>
      </div>
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Non-collapsible — set <code>collapsible="false"</code> to hide the toggle and lock the sidebar at full width.</p>
    <Preview align="start" lang="html" code={`<esa-sidebar-nav id="demo2" collapsible="false"></esa-sidebar-nav>`}>
      <div style="width: 100%; height: 320px; display: flex; border: 1px solid var(--color-border); border-radius: var(--radius-200); overflow: hidden;">
        <esa-sidebar-nav id="demo2" collapsible="false"></esa-sidebar-nav>
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} events={events} />
    <p><code>items</code> is an array property — set it in JS, not as an attribute. Each <code>EsaSidebarNavItem.icon</code> is a raw inline SVG string.</p>
    <h3>Slots</h3>
    <PropsTable rows={slots} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Renders a <code>&lt;nav aria-label="Sidebar navigation"&gt;</code> over a semantic list.</li>
      <li>Active leaf links carry <code>aria-current="page"</code>; parent accordions expose <code>aria-expanded</code>.</li>
      <li>The collapse toggle's <code>aria-label</code> flips between <code>Collapse sidebar</code> / <code>Expand sidebar</code>.</li>
      <li>Disabled items are removed from the tab order (<code>tabindex="-1"</code>, <code>pointer-events: none</code>).</li>
    </ul>
  </Section>

</ComponentDoc>

<script>
  import '@esa/ecology/esa-sidebar-nav';

  const dot = (c: string) =>
    `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="${c}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>`;

  const items = [
    { label: 'Dashboard', href: '/dashboard', icon: dot('#43608a'), active: true, group: 'Main' },
    { label: 'Projects', href: '/projects', icon: dot('#525252'), badge: 12, group: 'Main' },
    {
      label: 'Reports',
      icon: dot('#525252'),
      group: 'Main',
      children: [
        { label: 'Monthly', href: '/reports/monthly' },
        { label: 'Quarterly', href: '/reports/quarterly' },
      ],
    },
    { label: 'Team', href: '/team', icon: dot('#525252'), group: 'Admin' },
    { label: 'Billing', href: '/billing', icon: dot('#525252'), group: 'Admin', disabled: true },
    { label: 'Settings', href: '/settings', icon: dot('#525252'), group: 'Admin' },
  ];

  const el = document.getElementById('demo') as any;
  if (el) el.items = items;

  const el2 = document.getElementById('demo2') as any;
  if (el2) el2.items = items.slice(0, 4);
</script>
