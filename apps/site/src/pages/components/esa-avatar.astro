---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import Avatar from '@esa/ecology/esa-avatar.astro';

const props = [
  { name: 'name', type: 'string', default: "''", description: 'Used to derive initials and a deterministic background hue.' },
  { name: 'src', type: 'string', default: "''", description: 'Image URL. When set, renders the photo instead of initials.' },
  { name: 'icon', type: 'string', default: "''", description: 'Lucide icon name for an icon fallback (defaults to a user glyph).' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Avatar diameter (20 / 28 / 40 / 56px).' },
  { name: 'shape', type: "'circle' | 'square'", default: "'circle'", description: 'Fully rounded or rounded-square.' },
];
---
<ComponentDoc name="Avatar" category="Display" slug="esa-avatar" type=".astro" status="stable"
  summary="Compact identity marker. Falls back image → initials → user icon, with a deterministic background hue derived from the name.">

  <Section id="preview" title="Preview">
    <Preview code={`<Avatar name="Ada Lovelace" />`}>
      <Avatar name="Ada Lovelace" />
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview code={`<Avatar name="Ada Lovelace" size="xs" />
<Avatar name="Ada Lovelace" size="sm" />
<Avatar name="Ada Lovelace" size="md" />
<Avatar name="Ada Lovelace" size="lg" />`}>
      <Avatar name="Ada Lovelace" size="xs" />
      <Avatar name="Ada Lovelace" size="sm" />
      <Avatar name="Ada Lovelace" size="md" />
      <Avatar name="Ada Lovelace" size="lg" />
    </Preview>
  </Section>

  <Section id="shapes" title="Shapes">
    <Preview code={`<Avatar name="Grace Hopper" shape="circle" />
<Avatar name="Grace Hopper" shape="square" />`}>
      <Avatar name="Grace Hopper" shape="circle" />
      <Avatar name="Grace Hopper" shape="square" />
    </Preview>
  </Section>

  <Section id="states" title="Fallbacks">
    <p>The background hue is hashed from <code>name</code>, so each person gets a stable, distinct color. Resolution order is image → initials → user icon.</p>
    <Preview code={`<Avatar src="https://i.pravatar.cc/100?img=12" name="Photo User" />
<Avatar name="Alan Turing" />
<Avatar name="Single" />
<Avatar />`}>
      <Avatar src="https://i.pravatar.cc/100?img=12" name="Photo User" />
      <Avatar name="Alan Turing" />
      <Avatar name="Katherine Johnson" />
      <Avatar name="Single" />
      <Avatar />
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Image fallback uses <code>name</code> (or "Avatar") as its <code>alt</code> text.</li>
      <li>The icon fallback is <code>aria-hidden</code> — pair the avatar with a visible name nearby for screen readers.</li>
      <li>Content is non-selectable (<code>user-select: none</code>) so initials don't interfere with text selection.</li>
    </ul>
  </Section>

</ComponentDoc>
