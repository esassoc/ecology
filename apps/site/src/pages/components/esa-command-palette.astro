---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';

const props = [
  { name: 'commands', type: 'EsaCommand[]', default: '[]', description: 'Command registry, set as a property. Each: { id, label, description?, shortcut?, group?, keywords?, disabled?, action }.' },
  { name: 'open', type: 'boolean', default: 'false', description: 'Reflected open state.' },
  { name: 'hotkey', type: 'boolean', default: 'true', description: 'Registers the global Cmd/Ctrl+K toggle listener.' },
];

const methods = [
  { name: 'show()', type: 'method', description: 'Opens the palette, clears the query, and focuses the input.' },
  { name: 'close()', type: 'method', description: 'Closes the palette.' },
  { name: 'toggle()', type: 'method', description: 'Toggles open state — also bound to Cmd/Ctrl+K.' },
];
---
<ComponentDoc name="Command Palette" category="Overlays" slug="esa-command-palette" type="wc" status="stable"
  summary="Filterable command overlay. Set the <code>commands</code> property, then open with the button or <kbd>⌘/Ctrl + K</kbd>. Arrow keys navigate, Enter runs, Esc closes.">

  <Section id="preview" title="Preview">
    <p>Commands are set in a script: <code>el.commands = [{'{ id, label, group, action }'}, …]</code>.</p>
    <Preview code={`<button id="open-cmdk">Open command palette</button>

<esa-command-palette id="cmdk"></esa-command-palette>`}>
      <button class="trigger" id="open-cmdk">Open command palette</button>
      <esa-command-palette id="cmdk"></esa-command-palette>
      <p id="result" class="result"></p>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
    <h3>Methods</h3>
    <PropsTable rows={methods} />
    <p>Selecting a command runs its <code>action</code> callback, then closes the palette — there is no separate event.</p>
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>The overlay is <code>role="dialog"</code>; the results list is <code>role="listbox"</code> with <code>role="option"</code> items and <code>aria-selected</code>.</li>
      <li>ArrowUp / ArrowDown move the active option (wrapping), Enter executes, Esc closes.</li>
      <li>The search input is focused automatically when the palette opens.</li>
    </ul>
  </Section>

  <Section id="tokens" title="Tokens">
    <ul class="tokens">
      <li><code>--color-surface-elevated</code> · <code>--color-border</code> / <code>--color-border-light</code></li>
      <li><code>--color-text-primary</code> / <code>--color-text-muted</code> · <code>--color-surface-sunken</code> (active row + kbd)</li>
      <li><code>--color-backdrop</code> · <code>--z-modal</code> / <code>--z-modal-backdrop</code></li>
      <li><code>--radius-400</code> · <code>--spacing-200</code> – <code>--spacing-400</code> · <code>--focus-ring-*</code></li>
    </ul>
  </Section>
</ComponentDoc>

<script>
  import '@esa/ecology/esa-command-palette';

  const result = document.getElementById('result')!;
  const log = (m: string) => (result.textContent = `Ran: ${m}`);

  const cmdk = document.getElementById('cmdk') as any;
  cmdk.commands = [
    { id: 'new', label: 'New file', description: 'Create a blank file', shortcut: '⌘N', group: 'File', keywords: ['create'], action: () => log('New file') },
    { id: 'open', label: 'Open…', description: 'Open an existing file', shortcut: '⌘O', group: 'File', action: () => log('Open') },
    { id: 'save', label: 'Save', shortcut: '⌘S', group: 'File', action: () => log('Save') },
    { id: 'theme', label: 'Toggle theme', group: 'View', keywords: ['dark', 'light'], action: () => log('Toggle theme') },
    { id: 'settings', label: 'Open settings', group: 'View', disabled: true, action: () => log('Settings') },
  ];

  document.getElementById('open-cmdk')!.addEventListener('click', () => cmdk.show());
</script>

<style>
  .trigger {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-200, 0.5rem);
    border: 1px solid var(--color-border-strong, #d4d4d4);
    background: var(--color-primary, #43608a);
    color: var(--color-text-inverse, #fff);
    font-family: inherit;
    font-size: var(--type-size-200, 0.9375rem);
    cursor: pointer;
  }
  .result { color: var(--color-text-muted, #737373); min-height: 1.5em; width: 100%; }
  kbd {
    padding: 1px 5px;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--radius-100, 0.25rem);
    background: var(--color-surface-sunken, #efefef);
    font-size: 0.85em;
  }
</style>
