---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import FilterContainer from '@esa/ecology/esa-filter-container.astro';
import FilterPills from '@esa/ecology/esa-filter-pills.astro';
import FilterClearButton from '@esa/ecology/esa-filter-clear-button.astro';

const sampleFilters = [
  { name: 'status', label: 'Status', value: 'open', displayValue: 'Open' },
  { name: 'dept', label: 'Department', value: 'water', displayValue: 'Water Quality' },
];

const props = [
  { name: 'gap', type: 'string', default: "'300'", description: 'Spacing-token step for the horizontal (column) gap between children.' },
  { name: 'rowGap', type: 'string', default: "'200'", description: 'Spacing-token step for the vertical (row) gap when children wrap.' },
];
---
<ComponentDoc name="Filter Container" category="Filters" slug="esa-filter-container" type=".astro" status="stable"
  summary="Layout wrapper that lays out filter dropdowns, pills, and the clear button in a wrapping flex row with consistent gap. A pure layout primitive — it carries no runtime logic.">

  <Section id="preview" title="Preview">
    <p>Compose a dropdown, the active-filter pills, and the clear button inside one container. It owns spacing and wrapping; the children own their own behavior.</p>
    <Preview code={`<FilterContainer>
  <esa-filter-dropdown name="status" label="Status" multiple></esa-filter-dropdown>
  <FilterPills filters={filters} />
  <FilterClearButton />
</FilterContainer>`}>
      <FilterContainer>
        <esa-filter-dropdown name="status" label="Status" multiple></esa-filter-dropdown>
        <FilterPills filters={sampleFilters} />
        <FilterClearButton />
      </FilterContainer>
    </Preview>
  </Section>

  <Section id="spacing" title="Spacing">
    <p>Tune the column and row gaps with spacing-token steps via <code>gap</code> and <code>rowGap</code>.</p>
    <Preview code={`<FilterContainer gap="500" rowGap="300">
  <esa-filter-dropdown name="priority" label="Priority"></esa-filter-dropdown>
  <FilterClearButton label="Reset" />
</FilterContainer>`}>
      <FilterContainer gap="500" rowGap="300">
        <esa-filter-dropdown name="priority" label="Priority"></esa-filter-dropdown>
        <FilterClearButton label="Reset" />
      </FilterContainer>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>A presentational <code>&lt;div&gt;</code> wrapper — it adds no roles or ARIA of its own; each child carries its own semantics.</li>
      <li>Children flow left-to-right and wrap, preserving a natural reading and tab order.</li>
      <li>Token-driven gaps keep targets visually separated without relying on color alone.</li>
    </ul>
  </Section>

  <script>
    import '@esa/ecology/esa-filter-dropdown';
    const opts = [
      { label: 'Open', value: 'open' },
      { label: 'In review', value: 'review' },
      { label: 'Closed', value: 'closed' },
    ];
    customElements.whenDefined('esa-filter-dropdown').then(() => {
      document.querySelectorAll('esa-filter-dropdown').forEach((el) => {
        (el as any).options = opts;
      });
    });
  </script>
</ComponentDoc>
