---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import EsaBreadcrumbs from '@esa/ecology/esa-breadcrumbs.astro';

const homeIcon =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>';

const basic = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Wetland Survey' },
];
const withIcon = [
  { label: 'Home', href: '/', icon: homeIcon },
  { label: 'Compliance', href: '/compliance' },
  { label: 'Permits', href: '/compliance/permits' },
  { label: 'NPDES-2024-118' },
];

const props = [
  { name: 'items', type: 'EsaBreadcrumbItem[]', description: 'Trail of crumbs. Each item is { label; href?; icon? }. The last item is rendered as the current page.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Type scale of the trail.' },
];
---
<ComponentDoc name="Breadcrumbs" category="Navigation" slug="esa-breadcrumbs" type=".astro" status="stable"
  summary="Presentational breadcrumb trail showing the path to the current page. The last item is treated as the current page and is not a link.">

  <Section id="preview" title="Preview">
    <Preview code={`<EsaBreadcrumbs items={[
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Wetland Survey' },
]} />`}>
      <EsaBreadcrumbs items={basic} />
    </Preview>
  </Section>

  <Section id="states" title="States">
    <p>Crumbs accept an optional leading icon (raw inline SVG) on any item — useful for a home glyph.</p>
    <Preview code={`<EsaBreadcrumbs items={[
  { label: 'Home', href: '/', icon: homeIconSvg },
  { label: 'Compliance', href: '/compliance' },
  { label: 'Permits', href: '/compliance/permits' },
  { label: 'NPDES-2024-118' },
]} />`}>
      <EsaBreadcrumbs items={withIcon} />
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview align="start" code={`<EsaBreadcrumbs items={items} size="xs" />
<EsaBreadcrumbs items={items} size="sm" />
<EsaBreadcrumbs items={items} size="md" />
<EsaBreadcrumbs items={items} size="lg" />`}>
      <div style="display: flex; flex-direction: column; gap: var(--spacing-300, 0.75rem);">
        <EsaBreadcrumbs items={basic} size="xs" />
        <EsaBreadcrumbs items={basic} size="sm" />
        <EsaBreadcrumbs items={basic} size="md" />
        <EsaBreadcrumbs items={basic} size="lg" />
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
    <p>Each <code>EsaBreadcrumbItem</code> is <code>{'{ label: string; href?: string; icon?: string }'}</code>. Omit <code>href</code> on the final item; <code>icon</code> is a raw inline SVG string.</p>
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Wraps the trail in <code>&lt;nav aria-label="Breadcrumb"&gt;</code> with an ordered <code>&lt;ol&gt;</code>.</li>
      <li>The last crumb receives <code>aria-current="page"</code> and renders as plain text, not a link.</li>
      <li>The chevron separator is decorative — marked <code>aria-hidden="true"</code>.</li>
    </ul>
  </Section>

</ComponentDoc>
