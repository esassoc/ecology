---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
import EsaBreadcrumbs from '@esa/ecology/esa-breadcrumbs.astro';

const homeIcon =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>';

const basic = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Wetland Survey' },
];
const withIcon = [
  { label: 'Home', href: '/', icon: homeIcon },
  { label: 'Compliance', href: '/compliance' },
  { label: 'Permits', href: '/compliance/permits' },
  { label: 'NPDES-2024-118' },
];
---
<BaseLayout title="esa-breadcrumbs — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>esa-breadcrumbs <code>[.astro]</code></h1>
      <p>Presentational breadcrumb trail. The last item is treated as the current page. Migrated from the Angular <code>navigation</code> entry point.</p>
    </Stack>

    <Stack gap="300">
      <h2>Basic</h2>
      <EsaBreadcrumbs items={basic} />
    </Stack>

    <Stack gap="300">
      <h2>With a leading icon</h2>
      <EsaBreadcrumbs items={withIcon} />
    </Stack>

    <Stack gap="300">
      <h2>Sizes</h2>
      <Stack gap="300">
        <EsaBreadcrumbs items={basic} size="small" />
        <EsaBreadcrumbs items={basic} size="medium" />
        <EsaBreadcrumbs items={basic} size="large" />
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Anatomy &amp; behavior</h2>
      <ul>
        <li><strong>Props:</strong> <code>items</code> (label / optional href / optional icon SVG), <code>size</code>.</li>
        <li><strong>Separator:</strong> inline Lucide <code>chevron-right</code> SVG, <code>aria-hidden</code>.</li>
        <li><strong>A11y:</strong> <code>&lt;nav aria-label="Breadcrumb"&gt;</code>, last crumb gets <code>aria-current="page"</code>.</li>
        <li><strong>Tokens:</strong> text-link / text-link-hover / text-primary / text-muted, type-size scale, spacing.</li>
      </ul>
    </Stack>
  </Stack>
</BaseLayout>
