---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
import Button from '@esa/ecology/Button.astro';
---
<BaseLayout title="Button — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>Button</h1>
      <p>Primary action control. Themes via <code>--color-primary*</code> and <code>--radius-md</code>.</p>
    </Stack>

    <Stack gap="300">
      <h2>Variants</h2>
      <Stack gap="300" direction="row" wrap={true}>
        <Button variant="primary">Primary</Button>
        <Button variant="secondary">Secondary</Button>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Sizes</h2>
      <Stack gap="300" direction="row" align="center" wrap={true}>
        <Button size="small">Small</Button>
        <Button size="medium">Medium</Button>
        <Button size="large">Large</Button>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Anatomy &amp; behavior</h2>
      <ul>
        <li><strong>States:</strong> rest, hover (<code>--color-primary-hover</code>), focus-visible (2px primary outline).</li>
        <li><strong>Tokens consumed:</strong> primary / primary-hover / primary-contrast / border / surface-sunken, radius-md, space + font scale.</li>
        <li><strong>Handoff note:</strong> any stack can reproduce this from the rendered HTML + this token list + the spec above — no Astro required downstream.</li>
      </ul>
    </Stack>
  </Stack>
</BaseLayout>
