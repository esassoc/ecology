---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Preview from '@esa/docs/Preview.astro';
import Api from '@esa/docs/Api.astro';
import PropsTable from '@esa/docs/PropsTable.astro';
import EmptyState from '@esa/ecology/esa-empty-state.astro';

const props = [
  { name: 'title', type: 'string', description: 'Required. The primary heading of the empty state.' },
  { name: 'headingLevel', type: '2 | 3 | 4 | 5 | 6', default: '3', description: 'Heading level of the title. Match where the empty state sits in the outline so it doesn’t skip a level (WCAG 1.3.1). Visual size unchanged.' },
  { name: 'description', type: 'string', description: 'Optional supporting line below the title.' },
  { name: 'size', type: "'xs' | 'sm' | 'md' | 'lg'", default: "'md'", description: 'Scales icon, text, and padding.' },
];

const slots = [
  { name: 'icon', type: 'slot', description: 'Inline SVG, scaled to the size variant.' },
  { name: 'default', type: 'slot', description: 'Action buttons rendered below the description.' },
];
---
<ComponentDoc name="Empty State" category="Display" slug="esa-empty-state" type=".astro" status="stable"
  summary="Centered placeholder for empty lists or zero-result views: optional icon, required title, optional description, and slotted actions.">

  <Section id="preview" title="Preview">
    <Preview align="start" code={`<EmptyState title="No results" description="Try adjusting your filters." />`}>
      <div style="width: 100%; border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-300, 0.5rem);">
        <EmptyState title="No results" description="Try adjusting your filters." />
      </div>
    </Preview>
  </Section>

  <Section id="sizes" title="Sizes">
    <Preview align="start" code={`<EmptyState size="xs" title="No results" description="Try adjusting your filters." />
<EmptyState size="sm" title="No results" description="Try adjusting your filters." />
<EmptyState size="md" title="No results" description="Try adjusting your filters." />
<EmptyState size="lg" title="No results" description="Try adjusting your filters." />`}>
      <div style="display: flex; flex-direction: column; gap: 16px; width: 100%;">
        <div style="border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-300, 0.5rem);">
          <EmptyState size="xs" title="No results" description="Try adjusting your filters." />
        </div>
        <div style="border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-300, 0.5rem);">
          <EmptyState size="sm" title="No results" description="Try adjusting your filters." />
        </div>
        <div style="border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-300, 0.5rem);">
          <EmptyState size="md" title="No results" description="Try adjusting your filters." />
        </div>
        <div style="border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-300, 0.5rem);">
          <EmptyState size="lg" title="No results" description="Try adjusting your filters." />
        </div>
      </div>
    </Preview>
  </Section>

  <Section id="states" title="Icon & actions">
    <p>Pass an icon via the <code>icon</code> slot and action buttons via the default slot. The title alone is enough for a minimal state.</p>
    <Preview align="start" code={`<EmptyState title="No documents yet" description="Upload your first document to get started.">
  <svg slot="icon">…</svg>
  <button type="button">Upload document</button>
</EmptyState>`}>
      <div style="width: 100%; border: 1px solid var(--color-border, #e5e5e5); border-radius: var(--radius-300, 0.5rem);">
        <EmptyState title="No documents yet" description="Upload your first document to get started.">
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
            <path d="M14 2v6h6"></path>
          </svg>
          <button type="button">Upload document</button>
        </EmptyState>
      </div>
    </Preview>
  </Section>

  <Section id="api" title="API">
    <Api props={props} />
    <h3 style="margin-top: 1.5rem;">Slots</h3>
    <PropsTable rows={slots} />
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>The title renders as an <code>&lt;h3&gt;</code> — keep heading order coherent within the page.</li>
      <li>The icon is decorative (<code>aria-hidden</code>); meaning comes from the title and description.</li>
      <li>Action buttons in the default slot keep native button semantics and focus order.</li>
    </ul>
  </Section>

</ComponentDoc>
