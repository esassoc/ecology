---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stack from '@esa/ecology/Stack.astro';
import Pill from '@esa/ecology/esa-pill.astro';
---
<BaseLayout title="Pill — Ecology">
  <Stack gap="500">
    <Stack gap="200">
      <p><a href="/">← Ecology</a></p>
      <h1>Pill</h1>
      <p>Compact, rounded tag with color variants, sizes, an optional leading icon, and an optional remove control.</p>
    </Stack>

    <Stack gap="300">
      <h2>Variants</h2>
      <Stack gap="300" direction="row" align="center" wrap={true}>
        <Pill label="Default" variant="default" removable={false} />
        <Pill label="Primary" variant="primary" removable={false} />
        <Pill label="Success" variant="success" removable={false} />
        <Pill label="Warning" variant="warning" removable={false} />
        <Pill label="Danger" variant="danger" removable={false} />
        <Pill label="Info" variant="info" removable={false} />
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Sizes</h2>
      <Stack gap="300" direction="row" align="center" wrap={true}>
        <Pill label="Small" size="small" removable={false} />
        <Pill label="Medium" size="medium" removable={false} />
        <Pill label="Large" size="large" removable={false} />
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Removable</h2>
      <Stack gap="300" direction="row" align="center" wrap={true}>
        <Pill label="Wetlands" variant="success" />
        <Pill label="Air quality" variant="info" />
        <Pill label="Overdue" variant="danger" />
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>With leading icon</h2>
      <Stack gap="300" direction="row" align="center" wrap={true}>
        <Pill label="Tagged" variant="primary" removable={false}>
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path>
            <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle>
          </svg>
        </Pill>
      </Stack>
    </Stack>

    <Stack gap="300">
      <h2>Anatomy &amp; behavior</h2>
      <ul>
        <li><strong>Slots:</strong> <code>icon</code> for a leading inline SVG; <code>label</code> is a required prop.</li>
        <li><strong>Remove:</strong> inline script removes the pill from the DOM and dispatches a bubbling <code>removed</code> event.</li>
        <li><strong>Tokens consumed:</strong> surface-sunken / variant subtle+border colors, radius-full, spacing scale.</li>
      </ul>
    </Stack>
  </Stack>
</BaseLayout>
