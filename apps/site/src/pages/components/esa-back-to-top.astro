---
import ComponentDoc from '../../layouts/ComponentDoc.astro';
import Section from '@esa/docs/Section.astro';
import Api from '@esa/docs/Api.astro';

const attrs = [
  { name: 'threshold', type: 'number', default: '300', description: 'Scroll distance (px) before the button fades in.' },
  { name: 'smooth-scroll', type: 'boolean', default: 'true', description: 'Smooth vs instant scroll-to-top. (Property: smoothScroll.)' },
  { name: 'scrollTarget', type: 'HTMLElement | null', default: 'null', description: 'JS-only property — element to track instead of window.' },
  { name: 'visible', type: 'boolean (reflected)', default: 'false', description: 'Reflected attribute set when scrolled past the threshold; drives the fade/translate.' },
];
---
<ComponentDoc name="Back to Top" category="Display" slug="esa-back-to-top" type="wc" status="stable"
  summary="Floating button that appears once the page is scrolled past a threshold and smooth-scrolls back to the top on click.">

  <Section id="preview" title="Try it">
    <p>The element is mounted on this page. Scroll down past ~300px and a button appears pinned to the bottom-right corner — click it to smooth-scroll back up.</p>
    <p style="font-family: var(--font-mono, monospace); font-size: 13px; color: var(--color-text-muted, #737373); background: var(--color-surface-sunken, #f5f5f5); padding: 10px 12px; border-radius: 7px;">&lt;esa-back-to-top&gt;&lt;/esa-back-to-top&gt;</p>
    <div style="height: 1400px; display: flex; align-items: flex-end; justify-content: center; padding-bottom: var(--spacing-600, 2rem); color: var(--color-text-muted, #737373);">
      <span>Keep scrolling… the back-to-top button is pinned bottom-right.</span>
    </div>
  </Section>

  <Section id="api" title="API">
    <p>Attributes and properties:</p>
    <Api props={attrs} />
    <p style="margin-top: 1rem;">No custom events — clicking the button scrolls the target (or <code>window</code>) to the top directly.</p>
  </Section>

  <Section id="accessibility" title="Accessibility">
    <ul class="a11y">
      <li>Renders a native <code>&lt;button&gt;</code> with <code>aria-label="Back to top"</code>.</li>
      <li>While hidden it is <code>pointer-events: none</code> with <code>opacity: 0</code>, so it isn't a click target until visible.</li>
      <li>Visible focus ring via the <code>--focus-ring-*</code> tokens; the chevron icon is <code>aria-hidden</code>.</li>
    </ul>
  </Section>

  <esa-back-to-top></esa-back-to-top>
</ComponentDoc>

<script>import '@esa/ecology/esa-back-to-top';</script>
