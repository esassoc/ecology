---
import '@esa/tokens/tokens.css';
import '@esa/tokens/component-tokens.css';
import '../styles/themes.css';
import { allGroups } from '../data/nav';

interface TocEntry { id: string; label: string }
interface Props {
  title?: string;
  activeHref?: string;
  toc?: TocEntry[];
}
const { title = 'Ecology', activeHref = '', toc = [] } = Astro.props;
---
<!doctype html>
<html lang="en" data-scheme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <!-- set color scheme before paint to avoid flash -->
    <script is:inline>
      const s = localStorage.getItem('ecology-scheme') || 'light';
      document.documentElement.setAttribute('data-scheme', s);
    </script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      :root { color-scheme: light; }
      html[data-scheme='dark'] {
        color-scheme: dark;
        --color-background: #09090b;
        --color-surface: #0c0c0e;
        --color-surface-elevated: #161618;
        --color-surface-sunken: #161618;
        --color-text-primary: #ededef;
        --color-text-secondary: #a1a1aa;
        --color-text-tertiary: #b4b4ba;
        --color-text-muted: #71717a;
        --color-border: #242428;
        --color-border-light: #1a1a1d;
        --color-border-strong: #34343a;
        --color-primary: #14b8a6;
        --color-primary-hover: #2dd4bf;
        --color-text-link: #2dd4bf;
        --color-surface-sunken-rgb: 22, 22, 24;
      }
      body {
        margin: 0;
        font-family: var(--font-sans, system-ui, sans-serif);
        font-size: 16px;
        line-height: var(--line-height-normal, 1.6);
        color: var(--color-text-primary, #171717);
        background: var(--color-background, #fafafa);
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }

      /* ---------- App grid ---------- */
      .app {
        display: grid;
        grid-template-columns: 264px minmax(0, 1fr);
        min-height: 100vh;
      }
      .sidebar {
        position: sticky;
        top: 0;
        align-self: start;
        height: 100vh;
        overflow-y: auto;
        border-right: 1px solid var(--color-border, #e5e5e5);
        background: var(--color-surface, #fff);
        padding: 0 0 var(--spacing-600, 2rem);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: var(--spacing-250, 0.625rem);
        height: 56px;
        padding: 0 var(--spacing-400, 1rem);
        position: sticky;
        top: 0;
        background: var(--color-surface, #fff);
        border-bottom: 1px solid var(--color-border, #e5e5e5);
        z-index: 1;
      }
      .brand .mark {
        width: 26px; height: 26px; border-radius: 7px;
        background: var(--color-primary, #005862);
        display: grid; place-items: center;
        color: #fff; font-weight: 700; font-size: 15px;
      }
      .brand b { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; }
      .brand .ver { font-size: 13px; color: var(--color-text-muted, #737373); font-family: var(--font-mono, monospace); }

      .nav { padding: var(--spacing-400, 1rem) var(--spacing-300, 0.75rem) 0; }
      .nav-group { margin-bottom: var(--spacing-500, 1.5rem); }
      .nav-group > h4 {
        margin: 0 0 var(--spacing-150, 0.375rem);
        padding: 0 var(--spacing-300, 0.75rem);
        font-size: 14px;
        font-weight: 600;
        color: var(--color-text-secondary, #525252);
      }
      .nav-group ul { list-style: none; margin: 0; padding: 0; }
      .nav-link {
        display: flex; align-items: center; justify-content: space-between;
        padding: 6px var(--spacing-300, 0.75rem);
        margin: 1px 0;
        border-radius: 7px;
        font-size: 14.5px;
        color: var(--color-text-secondary, #525252);
        transition: background 120ms ease, color 120ms ease;
      }
      .nav-link:hover { background: var(--color-surface-sunken, #f5f5f5); color: var(--color-text-primary, #171717); }
      .nav-link[aria-current='page'] {
        background: color-mix(in srgb, var(--color-primary, #005862) 10%, transparent);
        color: var(--color-primary, #005862);
        font-weight: 600;
      }
      html[data-scheme='dark'] .nav-link[aria-current='page'] { color: var(--color-primary-hover, #2dd4bf); }
      .nav-link .tag {
        font-size: 11px; font-family: var(--font-mono, monospace);
        color: var(--color-text-muted, #737373);
        border: 1px solid var(--color-border, #e5e5e5);
        border-radius: 5px; padding: 0 5px; line-height: 16px;
      }

      /* ---------- Topbar ---------- */
      .main { min-width: 0; }
      .topbar {
        position: sticky; top: 0; z-index: 5;
        height: 56px;
        display: flex; align-items: center; gap: var(--spacing-400, 1rem);
        padding: 0 var(--spacing-600, 2rem);
        border-bottom: 1px solid var(--color-border, #e5e5e5);
        background: color-mix(in srgb, var(--color-background, #fafafa) 80%, transparent);
        backdrop-filter: saturate(1.2) blur(8px);
      }
      .search {
        display: flex; align-items: center; gap: var(--spacing-200, 0.5rem);
        width: 280px; max-width: 40%;
        padding: 7px var(--spacing-300, 0.75rem);
        border: 1px solid var(--color-border, #e5e5e5);
        border-radius: 9px;
        color: var(--color-text-muted, #737373);
        font-size: 14px; cursor: text;
        background: var(--color-surface, #fff);
      }
      .search kbd {
        margin-left: auto; font-family: var(--font-mono, monospace); font-size: 11px;
        border: 1px solid var(--color-border, #e5e5e5); border-radius: 5px;
        padding: 1px 5px; color: var(--color-text-muted, #737373);
      }
      .topbar .spacer { flex: 1; }
      .icon-btn {
        display: grid; place-items: center; width: 34px; height: 34px;
        border: 1px solid var(--color-border, #e5e5e5); border-radius: 9px;
        background: var(--color-surface, #fff); color: var(--color-text-secondary, #525252);
        cursor: pointer; transition: background 120ms ease, color 120ms ease;
      }
      .icon-btn:hover { background: var(--color-surface-sunken, #f5f5f5); color: var(--color-text-primary, #171717); }

      /* ---------- Content + TOC ---------- */
      .content-wrap {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 220px;
        gap: var(--spacing-700, 3rem);
        max-width: 1100px;
        margin: 0 auto;
        padding: var(--spacing-700, 3rem) var(--spacing-600, 2rem) var(--spacing-900, 6rem);
      }
      .article { min-width: 0; }
      .toc { position: sticky; top: 80px; align-self: start; height: fit-content; }
      .toc h5 { margin: 0 0 var(--spacing-250, 0.625rem); font-size: 14px; font-weight: 600; color: var(--color-text-secondary, #525252); }
      .toc ul { list-style: none; margin: 0; padding: 0; }
      .toc a { display: block; padding: 4px 0; font-size: 14px; color: var(--color-text-muted, #737373); border-left: 2px solid transparent; padding-left: 12px; margin-left: -2px; transition: color 120ms ease, border-color 120ms ease; }
      .toc a:hover, .toc a.active { color: var(--color-text-primary, #171717); border-color: var(--color-primary, #005862); }

      @media (max-width: 1080px) { .content-wrap { grid-template-columns: minmax(0, 1fr); } .toc { display: none; } }
      @media (max-width: 760px) { .app { grid-template-columns: 1fr; } .sidebar { display: none; } }

      /* ---------- Shared content typography ---------- */
      .article h1 { font-size: 32px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 var(--spacing-200, 0.5rem); line-height: 1.2; }
      .article .lede { font-size: 18px; color: var(--color-text-secondary, #525252); margin: 0 0 var(--spacing-600, 2rem); line-height: 1.55; }
      .article h2 { font-size: 22px; font-weight: 600; letter-spacing: -0.01em; margin: var(--spacing-700, 3rem) 0 var(--spacing-300, 0.75rem); padding-top: var(--spacing-200, 0.5rem); scroll-margin-top: 76px; }
      .article p { color: var(--color-text-secondary, #525252); }
      .article code { font-family: var(--font-mono, monospace); font-size: 0.875em; background: var(--color-surface-sunken, #f5f5f5); padding: 0.12em 0.4em; border-radius: 5px; color: var(--color-text-primary, #171717); }

      /* ---------- Shared page header (used by every component/foundation page) ---------- */
      .content-wrap.no-toc { grid-template-columns: minmax(0, 1fr); }
      .crumbs { display: flex; gap: 8px; align-items: center; font-size: 14px; color: var(--color-text-muted, #737373); margin-bottom: var(--spacing-300, 0.75rem); }
      .crumbs a:hover { color: var(--color-text-primary, #171717); }
      .lede { font-size: 18px; color: var(--color-text-secondary, #525252); margin: 0 0 var(--spacing-500, 1.5rem); line-height: 1.55; }
      .meta-row { display: flex; align-items: center; gap: var(--spacing-250, 0.625rem); flex-wrap: wrap; margin-bottom: var(--spacing-600, 2rem); }
      .pill { font-size: 12.5px; font-weight: 500; padding: 2px 9px; border-radius: 999px; border: 1px solid var(--color-border, #e5e5e5); color: var(--color-text-secondary, #525252); }
      .pill--stable { color: var(--color-success, #22c55e); border-color: color-mix(in srgb, var(--color-success, #22c55e) 40%, transparent); }
      .pill--reference { color: var(--color-warning, #f59e0b); border-color: color-mix(in srgb, var(--color-warning, #f59e0b) 40%, transparent); }
      .imp { font-family: var(--font-mono, monospace); font-size: 13px; color: var(--color-text-muted, #737373); background: var(--color-surface-sunken, #f5f5f5); padding: 4px 10px; border-radius: 7px; }
      .a11y, .tokens { color: var(--color-text-secondary, #525252); line-height: 1.9; padding-left: 1.1rem; }
      .a11y li, .tokens li { margin-bottom: 4px; }
    </style>
  </head>
  <body>
    <div class="app">
      <aside class="sidebar">
        <div class="brand">
          <span class="mark">E</span>
          <b>Ecology</b>
          <span class="ver">v0.1</span>
        </div>
        <nav class="nav" aria-label="Docs">
          {allGroups.map((group) => (
            <div class="nav-group">
              <h4>{group.label}</h4>
              <ul>
                {group.items.map((item) => (
                  <li>
                    <a
                      class="nav-link"
                      href={item.href}
                      aria-current={item.href === activeHref ? 'page' : undefined}
                    >
                      <span>{item.label}</span>
                      {item.status === 'reference' && <span class="tag">ref</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <div class="main">
        <header class="topbar">
          <div class="search" role="search"><span>Search…</span><kbd>⌘K</kbd></div>
          <div class="spacer"></div>
          <button class="icon-btn" id="scheme-toggle" type="button" aria-label="Toggle color scheme" title="Toggle light / dark">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ico-sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ico-moon" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a class="icon-btn" href="https://github.com/andrewlovseth-esa/ecology" target="_blank" rel="noreferrer" aria-label="GitHub">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.6 9.6 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.16.58.67.48A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10z"/></svg>
          </a>
        </header>

        <div class="content-wrap">
          <article class="article">
            <slot />
          </article>
          <aside class="toc" id="page-toc" aria-label="On this page" hidden>
            <h5>On this page</h5>
            <ul></ul>
          </aside>
        </div>
      </div>
    </div>

    <script>
      // Scheme toggle
      const root = document.documentElement;
      const btn = document.getElementById('scheme-toggle');
      const sun = btn?.querySelector('.ico-sun');
      const moon = btn?.querySelector('.ico-moon');
      const paint = () => {
        const dark = root.getAttribute('data-scheme') === 'dark';
        if (sun) (sun as HTMLElement).style.display = dark ? 'none' : '';
        if (moon) (moon as HTMLElement).style.display = dark ? '' : 'none';
      };
      paint();
      btn?.addEventListener('click', () => {
        const next = root.getAttribute('data-scheme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-scheme', next);
        localStorage.setItem('ecology-scheme', next);
        paint();
      });

      // Auto-build "On this page" from the section headings, then scroll-spy.
      const toc = document.getElementById('page-toc');
      const headings = Array.from(document.querySelectorAll('.article h2[id]')) as HTMLElement[];
      if (toc && headings.length) {
        const ul = toc.querySelector('ul') as HTMLUListElement;
        const links = headings.map((h) => {
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          a.setAttribute('data-toc', h.id);
          const li = document.createElement('li');
          li.appendChild(a);
          ul.appendChild(li);
          return a;
        });
        toc.hidden = false;
        const map = new Map(links.map((l) => [l.getAttribute('data-toc'), l]));
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              links.forEach((l) => l.classList.remove('active'));
              map.get(e.target.id)?.classList.add('active');
            }
          });
        }, { rootMargin: '-76px 0px -70% 0px' });
        headings.forEach((h) => obs.observe(h));
      } else {
        document.querySelector('.content-wrap')?.classList.add('no-toc');
      }
    </script>
  </body>
</html>
