---
import '@esa/tokens/tokens.css';
import '@esa/tokens/component-tokens.css';
import '../styles/themes.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

interface Props {
  title?: string;
}
const { title = 'Ecology' } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="default">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--font-sans, system-ui, sans-serif);
        font-size: var(--type-size-200, 1rem);
        font-weight: var(--font-weight-regular, 350);
        line-height: var(--line-height-normal, 1.6);
        background: var(--color-surface, #fff);
        color: var(--color-text-primary, #171717);
      }
      h1, h2, h3 { line-height: var(--line-height-tight, 1.3); font-weight: var(--font-weight-semibold, 550); }
      h1 { font-size: var(--type-size-700, 2.25rem); letter-spacing: var(--letter-spacing-tight, -0.01em); }
      h2 { font-size: var(--type-size-500, 1.5rem); margin-top: var(--spacing-600, 2rem); }
      a { color: var(--color-text-link, #005862); }
      code {
        font-family: var(--font-mono, ui-monospace, monospace);
        font-size: 0.9em;
        background: var(--color-surface-sunken, #efefef);
        padding: 0.1em 0.35em;
        border-radius: var(--radius-100, 4px);
      }
      .page { max-width: 880px; margin: 0 auto; padding: var(--spacing-700, 3rem) var(--spacing-500, 1.5rem); }
      .swatches { display: flex; flex-wrap: wrap; gap: var(--spacing-300, 0.75rem); }
      .swatch { width: 110px; }
      .swatch .chip { height: 48px; border-radius: var(--radius-200, 8px); border: 1px solid var(--color-border, #e5e5e5); }
      .swatch .label { font-size: var(--type-size-100, 0.75rem); color: var(--color-text-muted, #737373); margin-top: 0.35rem; }
    </style>
  </head>
  <body>
    <ThemeSwitcher />
    <main class="page">
      <slot />
    </main>
  </body>
</html>
