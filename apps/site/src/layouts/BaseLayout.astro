---
import '@esa/ecology/styles.css';
import '../styles/themes.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

interface Props {
  title?: string;
}
const { title = 'Ecology' } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="default">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--font-sans);
        font-size: var(--type-size-200);
        font-weight: var(--font-weight-regular);
        line-height: var(--line-height-normal);
        background: var(--color-surface);
        color: var(--color-text-primary);
      }
      h1, h2, h3 { line-height: var(--line-height-tight); font-weight: var(--font-weight-semibold); }
      h1 { font-size: var(--type-size-700); letter-spacing: var(--letter-spacing-tight); }
      h2 { font-size: var(--type-size-500); margin-top: var(--spacing-600); }
      a { color: var(--color-text-link); }
      code {
        font-family: var(--font-mono);
        font-size: 0.9em;
        background: var(--color-surface-sunken);
        padding: 0.1em 0.35em;
        border-radius: var(--radius-100);
      }
      .page { max-width: 880px; margin: 0 auto; padding: var(--spacing-700) var(--spacing-500); }
      .swatches { display: flex; flex-wrap: wrap; gap: var(--spacing-300); }
      .swatch { width: 110px; }
      .swatch .chip { height: 48px; border-radius: var(--radius-200); border: 1px solid var(--color-border); }
      .swatch .label { font-size: var(--type-size-100); color: var(--color-text-muted); margin-top: 0.35rem; }
    </style>
  </head>
  <body>
    <ThemeSwitcher />
    <main class="page">
      <slot />
    </main>
  </body>
</html>
