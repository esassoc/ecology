---
import DocsLayout from './DocsLayout.astro';
import Section from '@esa/docs/Section.astro';
import { withBase } from '@esa/docs/base';
import { themingSurface } from '../data/theming';

interface Props {
  name: string;          // display name, e.g. "Button"
  category: string;      // e.g. "Core"
  slug: string;          // component basename, e.g. "esa-button"
  type: '.astro' | 'wc' | 'reference';
  status?: 'stable' | 'reference';
  summary: string;
  wraps?: string;        // reference only, e.g. "AG Grid"
}
const { name, category, slug, type, status = 'stable', summary, wraps } = Astro.props;

const activeHref = `/components/${slug}`;
const pascal = slug.split('-').map((p) => p.charAt(0).toUpperCase() + p.slice(1)).join('');
const importLine =
  type === '.astro' ? `import ${pascal} from '@esa/ecology/${slug}.astro';`
  : type === 'wc' ? `import '@esa/ecology/${slug}';`
  : null;
const statusLabel = type === 'reference' ? 'Reference' : 'Stable';
const statusClass = type === 'reference' ? 'pill--reference' : 'pill--stable';

// Build-time-extracted public theming surface (src/data/theming.ts) — every
// token this component's CSS reads. Rendered on every component page so
// "what can my spoke re-point?" can never drift from the source.
const hooks = themingSurface[slug] ?? [];
const isColor = (v: string) => /^#[0-9a-fA-F]{3,8}$|^(rgb|rgba|hsl|hsla|oklch|color)\(/.test(v.trim());
---
<DocsLayout title={`${name} — Ecology`} activeHref={activeHref}>
  <nav class="crumbs"><a href={withBase('/')}>Ecology</a> <span>/</span> <span>{category}</span> <span>/</span> <span>{name}</span></nav>
  <h1>{name}</h1>
  <p class="lede" set:html={summary} />
  <div class="meta-row">
    <span class={`pill ${statusClass}`}>{statusLabel}</span>
    {type !== 'reference' && <span class="pill">{type}</span>}
    {wraps && <span class="pill">wraps {wraps}</span>}
    {importLine && <code class="imp">{importLine}</code>}
  </div>
  <slot />

  {hooks.length > 0 && (
    <Section id="theming-surface" title="Theming surface">
      <p class="ts-note">
        Every public token this component reads, extracted from its source at build time.
        The <strong>Resolves&nbsp;to</strong> column walks each token's real lineage —
        component&nbsp;→&nbsp;semantic&nbsp;→&nbsp;primitive&nbsp;→&nbsp;raw value — so you
        can see exactly where re-pointing it lands. A spoke re-skins by overriding these in
        its <code>theme-&lt;slug&gt;.css</code>; component internals are never edited. No
        hook for what you need? File it with <code>/request-lego</code>.
      </p>
      <table class="ts-table">
        <thead><tr><th>Token</th><th>Tier</th><th>Resolves to</th></tr></thead>
        <tbody>
          {hooks.map((h) => {
            const terminal = h.lineage[h.lineage.length - 1]; // last link = the raw value it lands on
            const path = h.lineage.slice(0, -1);              // the tokens it passes through to get there
            return (
              <tr>
                <td><code>{h.token}</code></td>
                <td><span class={`ts-tier ts-tier--${h.tier}`}>{h.tier}</span></td>
                <td class="ts-chain">
                  {h.lineage.length === 0 ? (
                    <span class="ts-none">—</span>
                  ) : (
                    <Fragment>
                      <span class="ts-resolved">
                        {isColor(terminal.ref) && <span class="ts-swatch" style={`background:${terminal.ref}`} />}
                        <code>{terminal.ref}</code>
                      </span>
                      {path.length > 0 && (
                        <span class="ts-via">via {path.map((p, i) => (
                          <Fragment>{i > 0 && <span class="ts-arrow"> → </span>}<code>{p.ref}</code></Fragment>
                        ))}</span>
                      )}
                    </Fragment>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </Section>
  )}
</DocsLayout>

<style>
  .ts-note { color: var(--color-text-secondary); }
  .ts-table { width: 100%; border-collapse: collapse; }
  .ts-table th { text-align: left; padding: var(--spacing-200) var(--spacing-300); border-bottom: 2px solid var(--color-border); }
  .ts-table td { padding: var(--spacing-150) var(--spacing-300); border-bottom: 1px solid var(--color-border); }
  .ts-tier { font-size: 0.8125rem; padding: 1px 8px; border-radius: 999px; border: 1px solid var(--color-border); }
  .ts-tier--component { background: var(--color-primary-subtle); border-color: var(--color-primary-border); }
  .ts-tier--ad-hoc { background: var(--color-primary-subtle); }
  .ts-tier--semantic { background: var(--color-surface-sunken); }
  .ts-tier--undefined { background: var(--color-danger-subtle); border-color: var(--color-danger-border); }
  .ts-none { color: var(--color-text-muted); }

  /* Lineage: the resolved value leads; the cascade path is a quiet breadcrumb beneath. */
  .ts-resolved { display: inline-flex; align-items: center; gap: var(--spacing-150); }
  .ts-swatch { width: 0.95em; height: 0.95em; border-radius: 3px; border: 1px solid rgba(0, 0, 0, 0.15); flex: none; }
  .ts-via { display: block; margin-top: 3px; font-size: 0.8125rem; color: var(--color-text-muted); }
  .ts-via code { font-size: inherit; background: none; padding: 0; color: inherit; }
  .ts-via .ts-arrow { color: var(--color-border-strong); }
</style>
