---
// esa-nav-dropdown — presentational disclosure (.astro).
//
// An icon-link trigger paired with a floating panel, using a native
// <details>/<summary> disclosure — zero runtime JS, same pattern as
// esa-header-nav. The trigger reuses esa-icon-link (tag="summary"); the panel
// content is slotted, so the consumer supplies whatever menu it needs. The
// trailing chevron rotates when open. The panel resets to surface colors so it
// reads correctly even when the trigger lives on a dark/brand bar.
import EsaIconLink from './esa-icon-link.astro';

interface Props {
  /** Trigger label. */
  label: string;
  /** Leading icon on the trigger. */
  icon?: string;
  size?: 'sm' | 'md';
  /** Panel edge alignment under the trigger. */
  align?: 'start' | 'end';
}

const { label, icon, size = 'md', align = 'start' } = Astro.props;
const cls = ['esa-nav-dropdown', `esa-nav-dropdown--${align}`].join(' ');
---
<details class={cls}>
  <EsaIconLink tag="summary" icon={icon} trailing="chevron-down" size={size}>{label}</EsaIconLink>
  <div class="esa-nav-dropdown__panel">
    <slot />
  </div>
</details>

<style>
  .esa-nav-dropdown { position: relative; }

  /* chevron (last icon in the trigger) rotates when open */
  .esa-nav-dropdown :global(.esa-icon-link > .esa-icon:last-child) {
    transition: transform 150ms ease;
  }
  .esa-nav-dropdown[open] :global(.esa-icon-link > .esa-icon:last-child) {
    transform: rotate(180deg);
  }

  .esa-nav-dropdown__panel {
    position: absolute;
    top: calc(100% + var(--spacing-200));
    left: 0;
    z-index: var(--z-dropdown);
    min-width: var(--nav-dropdown-panel-min-width);
    padding: var(--nav-dropdown-panel-padding);
    background: var(--nav-dropdown-panel-bg);
    color: var(--nav-dropdown-panel-text);
    border: 1px solid var(--nav-dropdown-panel-border-color);
    border-radius: var(--nav-dropdown-panel-radius);
    box-shadow: var(--nav-dropdown-panel-shadow);
  }
  .esa-nav-dropdown--end .esa-nav-dropdown__panel { left: auto; right: 0; }
</style>
