---
// esa-loading-overlay — presentational (.astro).
// Faithful translation of the Angular esa-loading-overlay: covers its positioned
// parent with a spinner (large) and an optional message when `active`; `transparent`
// switches the opaque backdrop to a semi-transparent one. Angular host classes +
// @if(active) → class list + conditional render. The spinner markup is inlined
// (mirrors esa-loading-spinner size="large"). Place inside a `position: relative`
// container so the absolute backdrop fills it.
interface Props {
  active?: boolean;
  message?: string;
  transparent?: boolean;
}
const { active = false, message, transparent = false } = Astro.props;

const cls = ['esa-loading-overlay', transparent && 'esa-loading-overlay--transparent']
  .filter(Boolean)
  .join(' ');
---
<div class={cls}>
  {active && (
    <div class="esa-loading-overlay__backdrop">
      <div class="esa-loading-overlay__content">
        <span class="esa-loading-overlay__spinner" role="status" aria-label="Loading"></span>
        {message && <p class="esa-loading-overlay__message">{message}</p>}
      </div>
    </div>
  )}
</div>

<style>
  .esa-loading-overlay {
    display: contents;
  }

  .esa-loading-overlay__backdrop {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface, #fff);
    z-index: 10;
  }

  .esa-loading-overlay--transparent .esa-loading-overlay__backdrop {
    background: rgba(255, 255, 255, 0.8);
  }

  .esa-loading-overlay__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-300, 0.75rem);
  }

  /* Inlined large spinner (mirrors esa-loading-spinner size="large"). */
  .esa-loading-overlay__spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--color-border-light, #efefef);
    border-top-color: var(--color-primary, #005862);
    border-radius: var(--radius-full, 9999px);
    animation: esa-overlay-spinner-rotate 0.75s linear infinite;
    box-sizing: border-box;
  }

  @keyframes esa-overlay-spinner-rotate {
    to { transform: rotate(360deg); }
  }

  .esa-loading-overlay__message {
    margin: 0;
    font-size: var(--type-size-150, 0.875rem);
    color: var(--color-text-secondary, #525252);
    text-align: center;
  }
</style>
