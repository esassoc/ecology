---
// esa-icon-button — presentational (.astro).
//
// Icon-only action for toolbars and chrome (search, close, overflow, etc.).
// Lightweight + transparent and INHERITS currentColor, so it lives happily on a
// dark app bar or a light surface. Square footprint on the shared form size
// scale. This is the chrome-grade counterpart to esa-button's heavier `iconOnly`
// mode (which carries a solid color + fixed 40px box).
//
// `label` is REQUIRED — an icon-only control needs an accessible name.
import EsaIcon from './esa-icon.astro';

type EsaSize = 'xs' | 'sm' | 'md' | 'lg';

interface Props {
  /** Lucide icon name. */
  icon: string;
  /** Accessible name (aria-label + title). Required. */
  label: string;
  /** When present, renders an <a>; otherwise a <button>. */
  href?: string;
  size?: EsaSize;
  type?: 'button' | 'submit' | 'reset';
}

const { icon, label, href, size = 'md', type = 'button' } = Astro.props;
const Tag = href ? 'a' : 'button';
const cls = ['esa-icon-button', `esa-icon-button--${size}`].join(' ');
---
<Tag
  class={cls}
  href={href}
  type={href ? undefined : type}
  aria-label={label}
  title={label}
>
  <EsaIcon name={icon} size={size} />
</Tag>

<style>
  .esa-icon-button {
    --_ib-size: var(--form-height-md);
    --_ib-bg-hover: var(--icon-button-bg-hover);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--_ib-size);
    height: var(--_ib-size);
    padding: 0;
    border: 0;
    border-radius: var(--radius-200);
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background var(--transition-fast);
    -webkit-appearance: none;
    appearance: none;
  }
  .esa-icon-button--xs { --_ib-size: var(--form-height-xs); }
  .esa-icon-button--sm { --_ib-size: var(--form-height-sm); }
  .esa-icon-button--lg { --_ib-size: var(--form-height-lg); }

  .esa-icon-button:hover { background: var(--_ib-bg-hover); }
  .esa-icon-button:focus-visible {
    outline: var(--focus-ring-width) solid currentColor;
    outline-offset: var(--focus-ring-offset);
  }
</style>
