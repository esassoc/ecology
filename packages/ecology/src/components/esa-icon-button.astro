---
// esa-icon-button — presentational (.astro).
//
// Icon-only action for toolbars and chrome (search, close, overflow, etc.).
// Lightweight + transparent and INHERITS currentColor, so it lives happily on a
// dark app bar or a light surface. Square footprint on the shared form size
// scale. This is the chrome-grade counterpart to esa-button's heavier `iconOnly`
// mode (which carries a solid color + fixed 40px box).
//
// `label` is REQUIRED — an icon-only control needs an accessible name.
import EsaIcon from './esa-icon.astro';

type EsaSize = 'xs' | 'sm' | 'md' | 'lg';

interface Props {
  /** Lucide icon name. */
  icon: string;
  /** Accessible name (aria-label + title). Required. */
  label: string;
  /** When present, renders an <a>; otherwise a <button>. */
  href?: string;
  size?: EsaSize;
  type?: 'button' | 'submit' | 'reset';
  /** Selected/toggled state — adopts the brand color so it tracks the theme. */
  active?: boolean;
}

const { icon, label, href, size = 'md', type = 'button', active = false } = Astro.props;
const Tag = href ? 'a' : 'button';
const cls = ['esa-icon-button', `esa-icon-button--${size}`, active && 'is-active'].filter(Boolean).join(' ');
---
<Tag
  class={cls}
  href={href}
  type={href ? undefined : type}
  aria-label={label}
  title={label}
  aria-pressed={!href && active ? 'true' : undefined}
  aria-current={href && active ? 'true' : undefined}
>
  <EsaIcon name={icon} size={size} />
</Tag>

<style>
  .esa-icon-button {
    --_ib-size: var(--form-height-md, 40px);
    --_ib-bg-hover: var(--icon-button-bg-hover, color-mix(in srgb, currentColor 14%, transparent));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--_ib-size);
    height: var(--_ib-size);
    padding: 0;
    border: 0;
    border-radius: var(--radius-200, 8px);
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition:
      background-color var(--motion-ease-quick, 150ms ease),
      transform var(--motion-ease-out-quick, 150ms cubic-bezier(0.215, 0.61, 0.355, 1));
    -webkit-appearance: none;
    appearance: none;
  }
  .esa-icon-button--xs { --_ib-size: var(--form-height-xs, 28px); }
  .esa-icon-button--sm { --_ib-size: var(--form-height-sm, 32px); }
  .esa-icon-button--lg { --_ib-size: var(--form-height-lg, 48px); }

  .esa-icon-button:hover { background: var(--_ib-bg-hover); }
  /* Selected/toggled: brand foreground + subtle brand wash, both theme-driven. */
  .esa-icon-button.is-active {
    color: var(--icon-button-active-color, var(--color-primary, currentColor));
    background: var(--icon-button-active-bg, transparent);
  }
  /* Tactile press — scale down slightly while the pointer/key is held. */
  .esa-icon-button:active:not(:disabled) { transform: scale(0.97); }
  @media (prefers-reduced-motion: reduce) {
    .esa-icon-button:active:not(:disabled) { transform: none; }
  }
  .esa-icon-button:focus-visible {
    outline: var(--focus-ring-width) solid currentColor;
    outline-offset: var(--focus-ring-offset, 2px);
  }
</style>
