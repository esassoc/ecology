---
// esa-button — presentational (.astro).
//
// Faithful translation of the Angular esa-button:
//   - variant: primary | secondary | outline | ghost   (host classes → class list)
//   - size:    small | medium | large
//   - disabled / loading / iconOnly                      (boolean host classes)
//   - icon:    Lucide name rendered left of the label (hidden while loading)
//   - loading: CSS-only spinner; label kept in place but visually hidden
//   - type:    native button type
//
// The Angular form-height/form-padding/form-font tokens live in the forms entry
// point (not present in the hub token build yet), so the private --_btn-* tokens
// fall back to the same literal pixel values the SCSS used as fallbacks.
import EsaIcon from './esa-icon.astro';

type EsaSize = 'small' | 'medium' | 'large';

interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: EsaSize;
  disabled?: boolean;
  loading?: boolean;
  /** Lucide icon name, shown left of the label. */
  icon?: string;
  /** Icon-only mode (no text). */
  iconOnly?: boolean;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  size = 'medium',
  disabled = false,
  loading = false,
  icon = '',
  iconOnly = false,
  type = 'button',
} = Astro.props;

const cls = [
  'esa-button',
  `esa-button--${variant}`,
  `esa-button--${size}`,
  disabled && 'esa-button--disabled',
  loading && 'esa-button--loading',
  iconOnly && 'esa-button--icon-only',
]
  .filter(Boolean)
  .join(' ');
---
<span class={cls}>
  <button class="esa-button__native" type={type} disabled={disabled || loading} aria-busy={loading ? 'true' : undefined}>
    {loading && <span class="esa-button__spinner" aria-hidden="true" />}

    {icon && !loading && <EsaIcon name={icon} size={size} />}

    {!iconOnly && (
      <span class={`esa-button__label${loading ? ' esa-button__label--hidden' : ''}`}>
        <slot />
      </span>
    )}
  </button>
</span>

<style>
  .esa-button {
    /* Size tokens — medium defaults (form-* tokens unavailable here → literals). */
    --_btn-height: var(--form-height-medium, 40px);
    --_btn-padding-x: var(--form-padding-x-medium, 16px);
    --_btn-font-size: var(--form-font-size-medium, 14px);
    --_btn-radius: var(--form-radius-medium, 6px);

    /* Variant tokens — primary defaults. */
    --_btn-bg: var(--color-primary, #005862);
    --_btn-bg-hover: var(--color-primary-hover, #004752);
    --_btn-bg-active: var(--color-primary-active, #003d47);
    --_btn-text: var(--color-text-inverse, #ffffff);
    --_btn-border: transparent;

    display: inline-block;
  }

  /* Sizes */
  .esa-button--small {
    --_btn-height: var(--form-height-small, 32px);
    --_btn-padding-x: var(--form-padding-x-small, 12px);
    --_btn-font-size: var(--form-font-size-small, 12px);
    --_btn-radius: var(--form-radius-small, 4px);
  }
  .esa-button--large {
    --_btn-height: var(--form-height-large, 48px);
    --_btn-padding-x: var(--form-padding-x-large, 20px);
    --_btn-font-size: var(--form-font-size-large, 16px);
    --_btn-radius: var(--form-radius-large, 8px);
  }

  /* Variants */
  .esa-button--secondary {
    --_btn-bg: var(--color-secondary, #0d9488);
    --_btn-bg-hover: var(--color-secondary-hover, #115e59);
    --_btn-bg-active: var(--color-secondary-hover, #115e59);
    --_btn-text: var(--color-text-inverse, #ffffff);
    --_btn-border: transparent;
  }
  .esa-button--outline {
    --_btn-bg: transparent;
    --_btn-bg-hover: var(--color-hover-overlay, rgba(0, 0, 0, 0.03));
    --_btn-bg-active: var(--color-active-overlay, rgba(0, 88, 98, 0.08));
    --_btn-text: var(--color-text-primary, #171717);
    --_btn-border: var(--color-border, #e5e5e5);
  }
  .esa-button--ghost {
    --_btn-bg: transparent;
    --_btn-bg-hover: var(--color-hover-overlay, rgba(0, 0, 0, 0.03));
    --_btn-bg-active: var(--color-active-overlay, rgba(0, 88, 98, 0.08));
    --_btn-text: var(--color-text-primary, #171717);
    --_btn-border: transparent;
  }

  /* Disabled */
  .esa-button--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Icon-only */
  .esa-button--icon-only .esa-button__native {
    padding-inline: 0;
    width: var(--_btn-height);
    justify-content: center;
  }

  /* Native button */
  .esa-button__native {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-200, 8px);
    width: 100%;
    height: var(--_btn-height);
    padding-inline: var(--_btn-padding-x);
    border: 1px solid var(--_btn-border);
    border-radius: var(--_btn-radius);
    background: var(--_btn-bg);
    color: var(--_btn-text);
    font-size: var(--_btn-font-size);
    font-family: var(--font-sans, system-ui, sans-serif);
    font-weight: var(--font-weight-medium, 500);
    line-height: 1;
    cursor: pointer;
    transition:
      background var(--transition-fast, 150ms ease),
      border-color var(--transition-fast, 150ms ease),
      box-shadow var(--transition-fast, 150ms ease);
    -webkit-appearance: none;
    appearance: none;
  }

  .esa-button__native:hover:not(:disabled) { background: var(--_btn-bg-hover); }
  .esa-button__native:active:not(:disabled) { background: var(--_btn-bg-active); }

  .esa-button__native:focus-visible {
    outline: var(--focus-ring-width, 2px) solid var(--focus-ring-color, #005862);
    outline-offset: var(--focus-ring-offset, 2px);
  }

  .esa-button__native:disabled { cursor: not-allowed; }

  /* Label */
  .esa-button__label { white-space: nowrap; }
  .esa-button__label--hidden {
    visibility: hidden;
    width: 0;
    overflow: hidden;
  }

  /* Loading spinner (CSS-only) */
  .esa-button__spinner {
    display: inline-block;
    width: 1em;
    height: 1em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: esa-button-spin 0.6s linear infinite;
  }

  @keyframes esa-button-spin {
    to { transform: rotate(360deg); }
  }
</style>
