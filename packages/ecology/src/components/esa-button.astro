---
// esa-button — presentational (.astro).
//
// Variant model aligned to Beacon's UiButton (two independent axes + toggle):
//   - color:      primary | secondary | danger | success | warning | info | ai | ghost
//   - appearance: fill | outline | dashed
//   - active:     aria-pressed toggle (selected look)
//   - size:       xs | sm | md | lg   (shared form size scale)
//   - icon / iconOnly / loading / disabled / type
//
// `ai` maps to the copper "AI context" tokens. Color sets a private --_accent;
// appearance decides how that accent renders (solid fill vs bordered).
import EsaIcon from './esa-icon.astro';

type EsaSize = 'xs' | 'sm' | 'md' | 'lg';
type EsaButtonColor = 'primary' | 'secondary' | 'danger' | 'success' | 'warning' | 'info' | 'ai' | 'ghost';
type EsaButtonAppearance = 'fill' | 'outline' | 'dashed';

interface Props {
  color?: EsaButtonColor;
  appearance?: EsaButtonAppearance;
  active?: boolean;
  size?: EsaSize;
  disabled?: boolean;
  loading?: boolean;
  /** Lucide icon name, shown left of the label. */
  icon?: string;
  /** Icon-only mode (no text). */
  iconOnly?: boolean;
  type?: 'button' | 'submit' | 'reset';
  /** When set, the button renders as an <a> styled identically — a link that looks like a button. */
  href?: string;
  /** Link target (href only), e.g. "_blank". */
  target?: string;
  /** Link rel (href only). Defaults to "noreferrer" when target="_blank". */
  rel?: string;
}

const {
  color = 'primary',
  appearance = 'fill',
  active = false,
  size = 'md',
  disabled = false,
  loading = false,
  icon = '',
  iconOnly = false,
  type = 'button',
  href,
  target,
  rel,
} = Astro.props;

const cls = [
  'esa-button',
  `esa-button--color-${color}`,
  `esa-button--appearance-${appearance}`,
  `esa-button--${size}`,
  active && 'esa-button--active',
  disabled && 'esa-button--disabled',
  loading && 'esa-button--loading',
  iconOnly && 'esa-button--icon-only',
]
  .filter(Boolean)
  .join(' ');

// hub-edit-approved: Andy approved (2026-06-15) — a disabled/loading link also
// drops out of the tab order (tabindex=-1); the --disabled wrapper only kills
// pointer events, so without this a keyboard user could still focus + activate it.
//
// href ⇒ render an <a> styled identically (a link that looks like a button).
// Anchors can't be natively disabled, so a disabled/loading link drops its href
// and is marked aria-disabled (the --disabled wrapper kills pointer events).
const isLink = href != null && href !== '';
const isDisabled = disabled || loading;
const Tag = isLink ? 'a' : 'button';
const nativeAttrs = isLink
  ? {
      href: isDisabled ? undefined : href,
      target: target || undefined,
      rel: rel || (target === '_blank' ? 'noreferrer' : undefined),
      role: 'button',
      tabindex: isDisabled ? -1 : undefined,
      'aria-disabled': isDisabled ? 'true' : undefined,
      'aria-busy': loading ? 'true' : undefined,
      'aria-pressed': active ? 'true' : undefined,
    }
  : {
      type,
      disabled: isDisabled,
      'aria-busy': loading ? 'true' : undefined,
      'aria-pressed': active ? 'true' : undefined,
    };
---
<span class={cls}>
  <Tag class="esa-button__native" {...nativeAttrs}>
    {loading && <span class="esa-button__spinner" aria-hidden="true" />}
    {icon && !loading && <EsaIcon name={icon} size={size} />}
    {!iconOnly && (
      <span class={`esa-button__label${loading ? ' esa-button__label--hidden' : ''}`}>
        <slot />
      </span>
    )}
  </Tag>
</span>

<style>
  .esa-button {
    /* Size tokens — md default. */
    --_btn-height: var(--form-height-md, 40px);
    --_btn-padding-x: var(--form-padding-x-md, 16px);
    --_btn-font-size: var(--form-font-size-md, 14px);
    --_btn-radius: var(--form-radius-md, 6px);
    /* Color tokens — primary default.
       --_accent      = fill / border color (step 9)
       --_accent-text = text color for outline/dashed (step 11 of the ramp)
       --_on          = text color on a solid fill (step 12 for bright/mid fills) */
    --_accent: var(--color-primary, #46a758);
    --_accent-hover: var(--color-primary-hover, #3e9b4f);
    --_on: var(--color-text-inverse, #ffffff);
    --_accent-text: var(--_accent);
    /* Tint overlays for outline/dashed appearances — track --_accent so they update per color variant. */
    --_btn-tint-hover: color-mix(in srgb, var(--_accent) 8%, transparent);
    --_btn-tint-active: color-mix(in srgb, var(--_accent) 14%, transparent);
    display: inline-block;
  }

  /* ---------- Sizes ---------- */
  .esa-button--xs { --_btn-height: var(--form-height-xs, 28px); --_btn-padding-x: var(--form-padding-x-xs, 8px);  --_btn-font-size: var(--form-font-size-xs, 11px); --_btn-radius: var(--form-radius-xs, 4px); }
  .esa-button--sm { --_btn-height: var(--form-height-sm, 32px); --_btn-padding-x: var(--form-padding-x-sm, 12px); --_btn-font-size: var(--form-font-size-sm, 12px); --_btn-radius: var(--form-radius-sm, 4px); }
  .esa-button--lg { --_btn-height: var(--form-height-lg, 48px); --_btn-padding-x: var(--form-padding-x-lg, 20px); --_btn-font-size: var(--form-font-size-lg, 16px); --_btn-radius: var(--form-radius-lg, 8px); }

  /* ---------- Colors (set the accent, on-fill text, and outline text) ----------
     --_on          = foreground text on a solid fill. Defaults to white (correct for
                      most step-9 fills). Override for bright scales (Lime, Yellow,
                      Amber, Sky, Mint) whose step-9 is too light for white text.
     --_accent-text = foreground text in outline/dashed contexts. Uses the semantic
                      *-strong token (step 11) — designed for colored text on surfaces.
                      Spokes override via their theme's *-strong tokens, not primitives. */
  .esa-button--color-primary {
    --_accent-text: var(--color-primary-strong);
  }
  .esa-button--color-secondary {
    --_accent: var(--color-secondary);
    --_accent-hover: var(--color-secondary-hover);
    --_accent-text: var(--color-primary-strong);
  }
  .esa-button--color-danger {
    --_accent: var(--color-danger);
    --_accent-hover: var(--color-danger-hover);
    --_accent-text: var(--color-danger-strong);
  }
  .esa-button--color-success {
    --_accent: var(--color-success);
    --_accent-hover: var(--color-success-hover);
    --_on: var(--color-success-on-fill);
    --_accent-text: var(--color-success-strong);
  }
  .esa-button--color-warning {
    --_accent: var(--color-warning);
    --_accent-hover: var(--color-warning-hover);
    --_on: var(--button-on-warning, var(--color-gray-12));
    --_accent-text: var(--color-warning-strong);
  }
  .esa-button--color-info {
    --_accent: var(--color-info);
    --_accent-hover: var(--color-info-hover);
    --_accent-text: var(--color-info-strong);
  }
  .esa-button--color-ai {
    --_accent: var(--color-ai);
    --_accent-hover: var(--color-ai-hover);
    --_accent-text: var(--color-ai-strong);
  }

  /* ---------- Appearances ---------- */
  .esa-button--appearance-fill .esa-button__native {
    background: var(--_accent);
    color: var(--_on);
    border-color: transparent;
  }
  .esa-button--appearance-fill .esa-button__native:hover:not(:disabled) { background: var(--_accent-hover); }
  .esa-button--appearance-fill.esa-button--active .esa-button__native { background: var(--_accent-hover); }

  .esa-button--appearance-outline .esa-button__native,
  .esa-button--appearance-dashed .esa-button__native {
    background: transparent;
    color: var(--_accent-text);
    border-color: var(--_accent);
  }
  .esa-button--appearance-dashed .esa-button__native { border-style: dashed; }
  .esa-button--appearance-outline .esa-button__native:hover:not(:disabled),
  .esa-button--appearance-dashed .esa-button__native:hover:not(:disabled) { background: var(--_btn-tint-hover); }
  .esa-button--appearance-outline.esa-button--active .esa-button__native,
  .esa-button--appearance-dashed.esa-button--active .esa-button__native { background: var(--_btn-tint-active); }

  /* ---------- Ghost (neutral, transparent regardless of appearance) ---------- */
  .esa-button--color-ghost .esa-button__native {
    background: transparent;
    color: var(--color-text-primary, #171717);
    border-color: transparent;
  }
  .esa-button--color-ghost.esa-button--appearance-outline .esa-button__native,
  .esa-button--color-ghost.esa-button--appearance-dashed .esa-button__native { border-color: var(--color-border, #e5e5e5); }
  .esa-button--color-ghost .esa-button__native:hover:not(:disabled),
  .esa-button--color-ghost.esa-button--active .esa-button__native { background: var(--color-surface-sunken, #efefef); }

  /* ---------- Native button ---------- */
  .esa-button__native {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-200, 8px);
    width: 100%;
    height: var(--_btn-height);
    padding-inline: var(--_btn-padding-x);
    border: 1px solid transparent;
    border-radius: var(--_btn-radius);
    font-size: var(--_btn-font-size);
    font-family: var(--font-sans, system-ui, sans-serif);
    font-weight: var(--font-weight-medium, 500);
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease), border-color var(--transition-fast, 150ms ease);
    -webkit-appearance: none;
    appearance: none;
  }
  .esa-button__native:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset, 2px);
  }

  /* States */
  .esa-button--disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
  .esa-button--icon-only .esa-button__native { padding-inline: 0; width: var(--_btn-height); }

  /* Label + loading */
  .esa-button__label { white-space: nowrap; }
  .esa-button__label--hidden { visibility: hidden; width: 0; overflow: hidden; }
  .esa-button__spinner {
    display: inline-block; width: 1em; height: 1em;
    border: 2px solid currentColor; border-right-color: transparent; border-radius: 50%;
    animation: esa-button-spin 0.6s linear infinite;
  }
  @keyframes esa-button-spin { to { transform: rotate(360deg); } }
</style>
