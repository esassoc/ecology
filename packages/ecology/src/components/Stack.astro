---
// Stack — a layout primitive. `gap` takes a space-token step ("400") rather than
// a raw length, so spacing stays on the token scale. Demonstrates that layout
// primitives travel through the package the same way visual ones do.
interface Props {
  gap?: string;
  direction?: 'row' | 'column';
  align?: string;
  justify?: string;
  wrap?: boolean;
}
const { gap = '400', direction = 'column', align = 'stretch', justify = 'flex-start', wrap = false } = Astro.props;
const style = [
  `--_gap: var(--spacing-${gap}, 1rem)`,
  `--_dir: ${direction}`,
  `--_align: ${align}`,
  `--_justify: ${justify}`,
  `--_wrap: ${wrap ? 'wrap' : 'nowrap'}`
].join('; ');
---
<div class="esa-stack" style={style}>
  <slot />
</div>

<style>
  .esa-stack {
    display: flex;
    flex-direction: var(--_dir, column);
    gap: var(--_gap, 1rem);
    align-items: var(--_align, stretch);
    justify-content: var(--_justify, flex-start);
    flex-wrap: var(--_wrap, nowrap);
  }
</style>
