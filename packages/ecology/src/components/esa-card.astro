---
// esa-card — presentational (.astro).
// Faithful translation of the Angular esa-card: variant / headerVariant / padding
// host classes, header (icon + title + subtitle), body and optional footer.
// Angular TemplateRef inputs (header/actions/footer) → Astro named slots
// ("header", "actions", "footer"); the default slot is the body.
// Angular @if → conditional render here.
interface Props {
  title?: string;
  subtitle?: string;
  icon?: string;
  variant?: 'default' | 'outlined' | 'elevated' | 'filled';
  headerVariant?: 'default' | 'primary' | 'muted';
  padding?: 'none' | 'compact' | 'default' | 'spacious';
}
const {
  title,
  subtitle,
  icon,
  variant = 'default',
  headerVariant = 'default',
  padding = 'default',
} = Astro.props;

const hasHeaderSlot = Astro.slots.has('header');
const hasActionsSlot = Astro.slots.has('actions');
const hasFooterSlot = Astro.slots.has('footer');
const showHeader = !!title || hasHeaderSlot || hasActionsSlot;

const cls = [
  'esa-card',
  variant !== 'default' && `esa-card--${variant}`,
  headerVariant !== 'default' && `esa-card--header-${headerVariant}`,
  padding !== 'default' && `esa-card--padding-${padding}`,
]
  .filter(Boolean)
  .join(' ');
---
<div class={cls}>
  {showHeader && (
    <div class="esa-card__header">
      {hasHeaderSlot ? (
        <slot name="header" />
      ) : (
        <>
          <div class="esa-card__header-content">
            {icon && (
              <svg
                class="esa-card__icon"
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 16v-4"></path>
                <path d="M12 8h.01"></path>
              </svg>
            )}
            <div class="esa-card__titles">
              {title && <h3 class="esa-card__title">{title}</h3>}
              {subtitle && <p class="esa-card__subtitle">{subtitle}</p>}
            </div>
          </div>
          {hasActionsSlot && (
            <div class="esa-card__actions">
              <slot name="actions" />
            </div>
          )}
        </>
      )}
    </div>
  )}
  <div class="esa-card__body">
    <slot />
  </div>
  {hasFooterSlot && (
    <div class="esa-card__footer">
      <slot name="footer" />
    </div>
  )}
</div>

<style>
  .esa-card {
    --_card-bg: var(--card-bg);
    --_card-border: var(--card-border-color);
    --_card-radius: var(--card-radius);
    --_card-padding: var(--card-padding);
    --_card-header-bg: var(--card-header-bg);
    --_card-header-color: var(--card-header-color);
    --_card-header-border: var(--card-header-border-color);

    display: block;
    background: var(--_card-bg);
    border: 1px solid var(--_card-border);
    border-radius: var(--_card-radius);
    overflow: hidden;
  }

  /* outlined: explicit (same as default) */
  .esa-card--outlined { --_card-border: var(--color-border); }

  /* elevated: shadow, no border */
  .esa-card--elevated {
    --_card-border: transparent;
    box-shadow: var(--shadow-100);
  }

  /* filled: sunken background, no border */
  .esa-card--filled {
    --_card-bg: var(--color-surface-sunken);
    --_card-border: transparent;
  }

  .esa-card--header-primary .esa-card__header {
    --_card-header-bg: var(--color-primary);
    --_card-header-color: var(--color-text-inverse);
  }

  .esa-card--header-muted .esa-card__header {
    --_card-header-bg: var(--color-surface-sunken);
  }

  .esa-card--padding-none { --_card-padding: 0; }
  .esa-card--padding-compact { --_card-padding: var(--spacing-300); }
  .esa-card--padding-spacious { --_card-padding: var(--spacing-700); }

  .esa-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-400) var(--_card-padding);
    background: var(--_card-header-bg);
    color: var(--_card-header-color);
    border-bottom: 1px solid var(--_card-header-border);
    min-height: 56px;
  }

  .esa-card__header-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-300);
  }

  .esa-card__titles {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-050);
  }

  .esa-card__title {
    font-size: var(--type-size-250);
    font-weight: 600;
    margin: 0;
    color: inherit;
    font-family: var(--font-sans);
  }

  .esa-card__subtitle {
    font-size: var(--type-size-150);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .esa-card--header-primary .esa-card__subtitle {
    color: rgba(255, 255, 255, 0.8);
  }

  .esa-card__icon {
    color: inherit;
    flex-shrink: 0;
  }

  .esa-card__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-200);
  }

  .esa-card__body {
    padding: var(--_card-padding);
  }

  .esa-card__footer {
    padding: var(--spacing-300) var(--_card-padding);
    border-top: 1px solid var(--_card-header-border);
    background: var(--card-footer-bg);
  }
</style>
