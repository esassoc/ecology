---
// esa-badge — GOLDEN PRESENTATIONAL PATTERN (.astro).
// Faithful translation of the Angular esa-badge: same variants, sizes, dot mode,
// same private --_* tokens reading public semantic tokens bare (@layer esa.defaults).
// Angular host classes → class list here; Angular @if(!dot) → conditional render.
interface Props {
  value?: string | number;
  variant?: 'primary' | 'secondary' | 'success' | 'warning' | 'danger' | 'info';
  size?: 'xs' | 'sm' | 'md' | 'lg';
  dot?: boolean;
}
const { value, variant = 'primary', size = 'md', dot = false } = Astro.props;
const cls = ['esa-badge', `esa-badge--${variant}`, `esa-badge--${size}`, dot && 'esa-badge--dot']
  .filter(Boolean)
  .join(' ');
---
<span class={cls}>
  {!dot && <span class="esa-badge__text">{value}</span>}
</span>

<style>
  .esa-badge {
    --_badge-bg: var(--badge-bg);
    --_badge-text: var(--badge-text-color);
    --_badge-height: var(--badge-height-md);
    --_badge-font-size: 13px;
    --_badge-padding-x: var(--spacing-200);
    --_badge-min-width: var(--badge-height-md);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--_badge-height);
    min-width: var(--_badge-min-width);
    padding-inline: var(--_badge-padding-x);
    border-radius: var(--badge-radius);
    background: var(--_badge-bg);
    color: var(--_badge-text);
    font-size: var(--_badge-font-size);
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    box-sizing: border-box;
  }

  /* base .esa-badge = md. xs is one step below sm; sm/lg keep the old small/large values. */
  .esa-badge--xs { --_badge-height: var(--badge-height-xs); --_badge-font-size: 10px; --_badge-padding-x: var(--spacing-100);  --_badge-min-width: var(--badge-height-xs); }
  .esa-badge--sm { --_badge-height: var(--badge-height-sm); --_badge-font-size: 11px; --_badge-padding-x: var(--spacing-150); --_badge-min-width: var(--badge-height-sm); }
  .esa-badge--lg { --_badge-height: var(--badge-height-lg); --_badge-font-size: 14px; --_badge-padding-x: var(--spacing-300);  --_badge-min-width: var(--badge-height-lg); }

  .esa-badge--secondary { --_badge-bg: var(--color-secondary); }
  .esa-badge--success   { --_badge-bg: var(--color-success); --_badge-text: var(--color-success-on-fill); }
  .esa-badge--warning   { --_badge-bg: var(--color-warning); --_badge-text: var(--color-warning-on-fill); }
  .esa-badge--danger    { --_badge-bg: var(--color-danger); }
  .esa-badge--info      { --_badge-bg: var(--color-info); }

  .esa-badge--dot {
    width: 8px;
    height: 8px;
    min-width: 8px;
    padding: 0;
    border-radius: var(--radius-full);
  }

  .esa-badge--dot.esa-badge--primary   { --_badge-bg: var(--color-primary-hover); }
  .esa-badge--dot.esa-badge--secondary { --_badge-bg: var(--color-secondary-hover); }
  .esa-badge--dot.esa-badge--success   { --_badge-bg: var(--color-success-hover); }
  .esa-badge--dot.esa-badge--warning   { --_badge-bg: var(--color-warning-hover); }
  .esa-badge--dot.esa-badge--danger    { --_badge-bg: var(--color-danger-hover); }
  .esa-badge--dot.esa-badge--info      { --_badge-bg: var(--color-info-hover); }
</style>
