---
// esa-badge — GOLDEN PRESENTATIONAL PATTERN (.astro).
// Faithful translation of the Angular esa-badge: same variants, sizes, dot mode,
// same private --_* tokens reading public semantic tokens with literal fallbacks.
// Angular host classes → class list here; Angular @if(!dot) → conditional render.
interface Props {
  value?: string | number;
  /** Accent hue (any Radix ramp) or a semantic tone — sets data-accent so the
   *  solid fill (accent-9) and contrast text track the hue. `secondary` = green. */
  color?:
    | 'gray' | 'blue' | 'copper' | 'gold' | 'grass' | 'green' | 'lime'
    | 'orange' | 'red' | 'teal' | 'yellow'
    | 'primary' | 'secondary' | 'success' | 'warning' | 'danger' | 'info' | 'neutral';
  /** @deprecated Use `color`. Kept as an alias so existing markup keeps working. */
  variant?: Props['color'];
  size?: 'xs' | 'sm' | 'md' | 'lg';
  dot?: boolean;
}
const { value, color, variant, size = 'md', dot = false } = Astro.props;
const accent = color ?? variant ?? 'primary';
const cls = ['esa-badge', `esa-badge--${size}`, dot && 'esa-badge--dot']
  .filter(Boolean)
  .join(' ');
---
<span class={cls} data-accent={accent}>
  {!dot && <span class="esa-badge__text">{value}</span>}
</span>

<style>
  .esa-badge {
    /* Solid fill: accent-9 background with contrast text — both resolve from the
       accent context set by data-accent, so any hue works with no per-tone CSS. */
    --_badge-bg: var(--badge-bg, var(--color-accent-9));
    --_badge-text: var(--badge-text-color, var(--color-accent-contrast, #fff));
    --_badge-height: var(--badge-height-md, 28px);
    --_badge-font-size: 13px;
    --_badge-padding-x: var(--spacing-200, 0.5rem);
    --_badge-min-width: var(--badge-height-md, 28px);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--_badge-height);
    min-width: var(--_badge-min-width);
    padding-inline: var(--_badge-padding-x);
    border-radius: var(--badge-radius, var(--radius-100, 4px));
    background: var(--_badge-bg);
    color: var(--_badge-text);
    font-size: var(--_badge-font-size);
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    box-sizing: border-box;
  }

  /* base .esa-badge = md. xs is one step below sm; sm/lg keep the old small/large values. */
  .esa-badge--xs { --_badge-height: var(--badge-height-xs, 18px); --_badge-font-size: 10px; --_badge-padding-x: var(--spacing-100, 0.25rem);  --_badge-min-width: var(--badge-height-xs, 18px); }
  .esa-badge--sm { --_badge-height: var(--badge-height-sm, 22px); --_badge-font-size: 11px; --_badge-padding-x: var(--spacing-150, 0.375rem); --_badge-min-width: var(--badge-height-sm, 22px); }
  .esa-badge--lg { --_badge-height: var(--badge-height-lg, 34px); --_badge-font-size: 14px; --_badge-padding-x: var(--spacing-300, 0.75rem);  --_badge-min-width: var(--badge-height-lg, 34px); }

  .esa-badge--dot {
    width: 8px;
    height: 8px;
    min-width: 8px;
    padding: 0;
    border-radius: var(--radius-full, 9999px);
    /* Dot uses the hovered fill step (10) for a touch more saturation at 8px. */
    --_badge-bg: var(--color-accent-10);
  }
</style>
