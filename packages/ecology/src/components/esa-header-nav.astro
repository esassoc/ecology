---
// esa-header-nav — presentational top app bar (.astro).
//
// A data-driven convenience SET, now composed from the chrome bricks rather than
// re-implementing them:
//   esa-app-bar      → the bar shell + start/main/end slots + tone
//   esa-icon-link    → plain nav links
//   esa-nav-dropdown → items with children (native <details>, zero JS)
// The signed-in user menu stays bespoke here (an avatar-triggered disclosure is
// set-specific, not a generic brick). `icon` on an item is a Lucide name (passed
// straight to esa-icon-link), consistent with the rest of the system.
//
// For full control, compose esa-app-bar + the bricks directly (see cb-fish-design's
// cbf-public-nav, or the App Bar specimen). This component is the batteries-included
// shortcut for the common brand · nav · user shape.
import EsaAppBar from './esa-app-bar.astro';
import EsaIconLink from './esa-icon-link.astro';
import EsaNavDropdown from './esa-nav-dropdown.astro';
import EsaIcon from './esa-icon.astro';

export interface EsaHeaderNavItem {
  label: string;
  href?: string;
  /** Lucide icon name (esa-icon). */
  icon?: string;
  children?: EsaHeaderNavItem[];
}
export interface EsaHeaderNavUser {
  name: string;
  email?: string;
  avatarUrl?: string;
  initials?: string;
}
interface Props {
  items?: EsaHeaderNavItem[];
  user?: EsaHeaderNavUser;
}
const { items = [], user } = Astro.props;

function initialsFor(u: EsaHeaderNavUser): string {
  if (u.initials) return u.initials;
  return u.name
    .split(' ')
    .map((p) => p[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
}
---
<EsaAppBar tone="surface" as="header" class="esa-header-nav">
  <div slot="start" class="esa-header-nav__brand"><slot name="brand" /></div>

  {items.map((item) =>
    item.children && item.children.length ? (
      <EsaNavDropdown label={item.label} icon={item.icon}>
        <ul class="esa-header-nav__menu" role="list">
          {item.children.map((child) => (
            <li>
              {child.href ? (
                <a class="esa-header-nav__menu-item" href={child.href}>{child.label}</a>
              ) : (
                <span class="esa-header-nav__menu-item esa-header-nav__menu-item--inert">{child.label}</span>
              )}
            </li>
          ))}
        </ul>
      </EsaNavDropdown>
    ) : (
      <EsaIconLink href={item.href} icon={item.icon}>{item.label}</EsaIconLink>
    )
  )}

  <Fragment slot="end">
    {Astro.slots.has('actions') && (
      <span class="esa-header-nav__actions"><slot name="actions" /></span>
    )}

    {user && (
      <details class="esa-header-nav__user">
        <summary class="esa-header-nav__avatar-btn" aria-label={`User menu for ${user.name}`}>
          {user.avatarUrl ? (
            <img class="esa-header-nav__avatar-img" src={user.avatarUrl} alt={user.name} />
          ) : (
            <span class="esa-header-nav__avatar-initials">{initialsFor(user)}</span>
          )}
        </summary>
        <div class="esa-header-nav__user-dropdown">
          <div class="esa-header-nav__user-info">
            <span class="esa-header-nav__user-name">{user.name}</span>
            {user.email && <span class="esa-header-nav__user-email">{user.email}</span>}
          </div>
          <div class="esa-header-nav__user-actions">
            <a class="esa-header-nav__user-action" href="#profile"><EsaIcon name="user" size="sm" /><span>Profile</span></a>
            <a class="esa-header-nav__user-action" href="#settings"><EsaIcon name="settings" size="sm" /><span>Settings</span></a>
            <div class="esa-header-nav__user-divider"></div>
            <a class="esa-header-nav__user-action esa-header-nav__user-action--danger" href="#logout"><span>Log out</span></a>
          </div>
        </div>
      </details>
    )}
  </Fragment>
</EsaAppBar>

<style>
  /* The .esa-header-nav class lands on esa-app-bar's root (a child component), so
     it doesn't carry this file's scope hash — target it with :global. The custom
     props inherit into the app-bar internals; the border sits on the bar itself. */
  :global(.esa-header-nav) {
    --app-bar-gap: var(--spacing-300);
    --app-bar-pad-x: var(--spacing-500);
    --app-bar-pad-y: var(--spacing-150);
    border-bottom: 1px solid var(--header-nav-border-color);
  }
  .esa-header-nav__brand { display: inline-flex; align-items: center; }
  .esa-header-nav__actions { display: inline-flex; align-items: center; gap: var(--spacing-200); }

  /* Dropdown menu list (rendered inside esa-nav-dropdown's panel) */
  .esa-header-nav__menu { list-style: none; margin: 0; padding: 0; min-width: 180px; }
  .esa-header-nav__menu-item {
    display: block;
    padding: var(--spacing-150) var(--spacing-300);
    border-radius: var(--radius-100);
    color: var(--header-nav-menu-item-color);
    font-size: var(--type-size-200);
    text-decoration: none;
  }
  .esa-header-nav__menu-item:hover { background: var(--color-surface-sunken); }
  .esa-header-nav__menu-item--inert { color: var(--color-text-muted); }

  /* User menu (bespoke — avatar-triggered disclosure) */
  .esa-header-nav__user { position: relative; display: flex; align-items: center; }
  .esa-header-nav__avatar-btn {
    display: flex; align-items: center; justify-content: center;
    width: var(--header-nav-avatar-size); height: var(--header-nav-avatar-size);
    border-radius: var(--radius-full);
    background: var(--header-nav-avatar-bg);
    color: var(--header-nav-avatar-text);
    cursor: pointer; overflow: hidden; list-style: none;
  }
  .esa-header-nav__avatar-btn::-webkit-details-marker { display: none; }
  .esa-header-nav__avatar-btn:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }
  .esa-header-nav__avatar-img { width: 100%; height: 100%; object-fit: cover; }
  .esa-header-nav__avatar-initials { font-size: var(--type-size-100); font-weight: var(--font-weight-semibold); }

  .esa-header-nav__user-dropdown {
    position: absolute; top: calc(100% + var(--spacing-100)); right: 0;
    z-index: var(--z-dropdown);
    min-width: 220px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-200);
    box-shadow: var(--shadow-200);
    overflow: hidden;
  }
  .esa-header-nav__user-info {
    display: flex; flex-direction: column; gap: 2px;
    padding: var(--spacing-300) var(--spacing-400);
    border-bottom: 1px solid var(--color-border);
  }
  .esa-header-nav__user-name { font-size: var(--type-size-200); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .esa-header-nav__user-email { font-size: var(--type-size-100); color: var(--color-text-secondary); }
  .esa-header-nav__user-actions { padding: var(--spacing-100); }
  .esa-header-nav__user-action {
    display: flex; align-items: center; gap: var(--spacing-200);
    padding: var(--spacing-150) var(--spacing-300);
    border-radius: var(--radius-100);
    color: var(--header-nav-menu-item-color);
    font-size: var(--type-size-200); text-decoration: none;
  }
  .esa-header-nav__user-action:hover { background: var(--color-surface-sunken); }
  .esa-header-nav__user-action--danger { color: var(--color-danger-strong); }
  .esa-header-nav__user-divider { height: 1px; margin: var(--spacing-100) 0; background: var(--color-border); }
</style>
