---
// esa-breadcrumbs — presentational breadcrumb trail (.astro).
// Faithful translation of the Angular esa-breadcrumbs: same item shape, size
// variants, separator icon, and "last item = current page" semantics.
// Angular host classes → class list; Angular @for/@if → JS map + conditionals.
// Lucide icons are inlined as SVG (chevron-right separator by default).
export interface EsaBreadcrumbItem {
  label: string;
  href?: string;
  icon?: string;
}
interface Props {
  items: EsaBreadcrumbItem[];
  size?: 'xs' | 'sm' | 'md' | 'lg';
}
const { items, size = 'md' } = Astro.props;
const cls = ['esa-breadcrumbs', `esa-breadcrumbs--${size}`].join(' ');
---
<nav class={cls} aria-label="Breadcrumb">
  <ol class="esa-breadcrumbs__list">
    {items.map((item, i) => {
      const last = i === items.length - 1;
      return (
        <li class="esa-breadcrumbs__item" aria-current={last ? 'page' : undefined}>
          {!last && item.href ? (
            <a href={item.href} class="esa-breadcrumbs__link">
              {item.icon && <span class="esa-breadcrumbs__icon" set:html={item.icon} />}
              {item.label}
            </a>
          ) : (
            <span class="esa-breadcrumbs__current">
              {item.icon && <span class="esa-breadcrumbs__icon" set:html={item.icon} />}
              {item.label}
            </span>
          )}
          {!last && (
            <svg
              class="esa-breadcrumbs__separator"
              width="16" height="16" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .esa-breadcrumbs {
    --_crumb-font-size: var(--type-size-200);
    --_crumb-link-color: var(--breadcrumbs-link-color);
    --_crumb-link-hover: var(--breadcrumbs-link-hover);
    --_crumb-current-color: var(--color-text-primary);
    --_crumb-separator-color: var(--breadcrumbs-separator-color);
    --_crumb-gap: var(--spacing-200);

    display: block;
  }

  /* base .esa-breadcrumbs = md. xs is one step below sm; sm/lg keep the old small/large values. */
  .esa-breadcrumbs--xs { --_crumb-font-size: var(--type-size-100); }
  .esa-breadcrumbs--sm { --_crumb-font-size: var(--type-size-150); }
  .esa-breadcrumbs--lg { --_crumb-font-size: var(--type-size-300); }

  .esa-breadcrumbs__list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--_crumb-gap);
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--_crumb-font-size);
  }

  .esa-breadcrumbs__item {
    display: flex;
    align-items: center;
    gap: var(--_crumb-gap);
  }

  .esa-breadcrumbs__link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-100);
    color: var(--_crumb-link-color);
    text-decoration: none;
  }
  .esa-breadcrumbs__link:hover {
    color: var(--_crumb-link-hover);
    text-decoration: underline;
  }

  .esa-breadcrumbs__current {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-100);
    color: var(--_crumb-current-color);
    font-weight: var(--font-weight-medium);
  }

  .esa-breadcrumbs__icon {
    display: inline-flex;
    align-items: center;
  }

  .esa-breadcrumbs__separator {
    flex-shrink: 0;
    color: var(--_crumb-separator-color);
  }
</style>
