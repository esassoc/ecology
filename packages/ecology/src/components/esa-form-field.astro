---
// esa-form-field — PRESENTATIONAL layout wrapper (.astro).
// Faithful translation of the Angular esa-form-field: label row + control slot +
// hint/error text. Error text replaces help text when present. Size variants drive
// the label font-size. Angular @if → conditional render; host classes → class list.
interface Props {
  label?: string;
  size?: 'xs' | 'sm' | 'md' | 'lg';
  helpText?: string;
  errorText?: string;
  required?: boolean;
  disabled?: boolean;
}
const {
  label = '',
  size = 'md',
  helpText = '',
  errorText = '',
  required = false,
  disabled = false,
} = Astro.props;

const hasError = !!errorText;
const cls = [
  'esa-form-field',
  `esa-form-field--${size}`,
  hasError && 'esa-form-field--error',
  disabled && 'esa-form-field--disabled',
]
  .filter(Boolean)
  .join(' ');
---
<div class={cls}>
  {label && (
    <label class="esa-form-field__label">
      {label}
      {required && <span class="esa-form-field__required" aria-label="required">*</span>}
    </label>
  )}

  <div class="esa-form-field__input">
    <slot />
  </div>

  {hasError ? (
    <p class="esa-form-field__error">{errorText}</p>
  ) : helpText ? (
    <p class="esa-form-field__help">{helpText}</p>
  ) : null}
</div>

<style>
  .esa-form-field {
    --_label-color: var(--form-label-color);
    --_help-color: var(--form-help-color);
    --_error-color: var(--form-error-color);
    --_label-gap: var(--form-label-gap);
    --_help-gap: var(--form-help-gap);
    --_font-weight: var(--font-weight-medium);
    --_help-font-size: var(--type-size-100);
    --_required-color: var(--color-danger-strong);
    --_label-font-size: var(--form-font-size-md);

    display: flex;
    flex-direction: column;
  }

  .esa-form-field--xs { --_label-font-size: var(--form-font-size-xs); }
  .esa-form-field--sm { --_label-font-size: var(--form-font-size-sm); }
  .esa-form-field--lg { --_label-font-size: var(--form-font-size-lg); }

  .esa-form-field__label {
    color: var(--_label-color);
    font-weight: var(--_font-weight);
    font-size: var(--_label-font-size);
    margin-block-end: var(--_label-gap);
  }

  .esa-form-field__required {
    color: var(--_required-color);
    margin-inline-start: 2px;
  }

  .esa-form-field__input {
    display: flex;
    flex-direction: column;
  }

  .esa-form-field__help,
  .esa-form-field__error {
    margin: 0;
    margin-block-start: var(--_help-gap);
    font-size: var(--_help-font-size);
  }

  .esa-form-field__help { color: var(--_help-color); }
  .esa-form-field__error { color: var(--_error-color); }

  .esa-form-field--disabled {
    opacity: 0.5;
    pointer-events: none;
  }
</style>
