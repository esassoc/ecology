};

// Built-in glyph wins; fall back to a consumer-supplied `paths` for icons the
// registry doesn't ship (keeps the component extensible without forking it).
const inner = ICONS[name] ?? paths ?? '';
const cls = ['esa-icon', `esa-icon--${size}`].join(' ');
const decorative = !label;
---
<span class={cls} role={label ? 'img' : undefined} aria-label={label} aria-hidden={decorative ? 'true' : undefined}>
  <svg
    width={px}
    height={px}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    focusable="false"
    set:html={inner}
  />
</span>

<style>
  .esa-icon {
    --_icon-size: var(--icon-size-medium, 20px);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--_icon-size);
    height: var(--_icon-size);
    line-height: 1;
    color: inherit;
  }

  /* Class names emitted by the component are esa-icon--{xs|sm|md|lg|xl} (see `cls`
     above). Match them all — previously only --small/--large existed, so every size
     fell through to the 20px default and the svg width/height attribute was overridden. */
  .esa-icon--xs { --_icon-size: var(--icon-size-xs, 14px); }
  .esa-icon--sm { --_icon-size: var(--icon-size-small, 16px); }
  .esa-icon--md { --_icon-size: var(--icon-size-medium, 20px); }
  .esa-icon--lg { --_icon-size: var(--icon-size-large, 24px); }
  .esa-icon--xl { --_icon-size: var(--icon-size-xl, 28px); }

  .esa-icon svg {
    display: block;
    width: var(--_icon-size);
    height: var(--_icon-size);
  }
</style>
