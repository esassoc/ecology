---
// esa-icon — presentational (.astro).
//
// hub-edit-approved: Andy approved (2026-06-15) — the Lucide glyph lookup moved to
// the shared ./icon-registry module so the SAME map feeds both this server
// component and the client-side esa-sidebar-nav island (icons referenced by name,
// not pasted as raw SVG in spoke nav data). Requested from a spoke prototype.
//
// Faithful translation of the Angular esa-icon, which wrapped <lucide-icon> and
// also supported custom registered SVGs. Rather than pull in an icon dependency,
// the Lucide SVGs we ship are inlined in ./icon-registry (paths copied from
// lucide.dev). Each Lucide icon is a 24×24, stroke-based outline (stroke-width 2,
// round caps/joins), matching lucide's defaults.
//
// Size mapping (shared UiSize scale + xl for icons): xs=14, sm=16, md=20, lg=24, xl=28.
// host size classes → class list here; private --_icon-size token reads the
// public --icon-size-* tokens with literal fallbacks (same SCSS convention).
import { ICON_PATHS } from './icon-registry';

type EsaSize = 'xs' | 'sm' | 'md' | 'lg' | 'xl';

interface Props {
  /** Lucide icon name (kebab-case), e.g. "chevron-down". */
  name: string;
  /** Icon size. */
  size?: EsaSize;
  /** Accessible label. When omitted the icon is aria-hidden (decorative). */
  label?: string;
  /**
   * Inner SVG markup (the <path>/<circle>… children, no <svg> wrapper) for a glyph
   * not in the built-in registry. Lets a consumer supply brand- or feature-specific
   * icons without forking this component — used as the fallback when `name` is unknown.
   */
  paths?: string;
}

const { name, size = 'md', label, paths } = Astro.props;

const SIZE_MAP: Record<EsaSize, number> = { xs: 14, sm: 16, md: 20, lg: 24, xl: 28 };
const px = SIZE_MAP[size];

// Built-in glyph wins; fall back to a consumer-supplied `paths` for icons the
// registry doesn't ship (keeps the component extensible without forking it).
const inner = ICON_PATHS[name] ?? paths ?? '';
const cls = ['esa-icon', `esa-icon--${size}`].join(' ');
const decorative = !label;
---
<span class={cls} role={label ? 'img' : undefined} aria-label={label} aria-hidden={decorative ? 'true' : undefined}>
  <svg
    width={px}
    height={px}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    focusable="false"
    set:html={inner}
  />
</span>

<style>
  .esa-icon {
    --_icon-size: var(--icon-size-md);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--_icon-size);
    height: var(--_icon-size);
    line-height: 1;
    color: inherit;
  }

  /* Class names emitted by the component are esa-icon--{xs|sm|md|lg|xl} (see `cls`
     above). Match them all — previously only --small/--large existed, so every size
     fell through to the 20px default and the svg width/height attribute was overridden. */
  .esa-icon--xs { --_icon-size: var(--icon-size-xs); }
  .esa-icon--sm { --_icon-size: var(--icon-size-sm); }
  .esa-icon--md { --_icon-size: var(--icon-size-md); }
  .esa-icon--lg { --_icon-size: var(--icon-size-lg); }
  .esa-icon--xl { --_icon-size: var(--icon-size-xl); }

  .esa-icon svg {
    display: block;
    width: var(--_icon-size);
    height: var(--_icon-size);
  }
</style>
