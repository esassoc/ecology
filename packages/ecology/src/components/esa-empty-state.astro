---
// esa-empty-state — presentational (.astro).
// Faithful translation of the Angular esa-empty-state: optional icon, required title,
// optional description, slotted actions, and xs/sm/md/lg size variants.
// Angular host classes → class list; @if → conditional render; required title input
// → required `title` prop. The icon prop names a Lucide icon; pass an inline SVG via
// the "icon" slot for full fidelity, or omit it.
interface Props {
  title: string;
  description?: string;
  size?: 'xs' | 'sm' | 'md' | 'lg';
}
const { title, description, size = 'md' } = Astro.props;

const hasIconSlot = Astro.slots.has('icon');
const cls = ['esa-empty-state', `esa-empty-state--${size}`].join(' ');
---
<div class={cls}>
  {hasIconSlot && (
    <div class="esa-empty-state__icon">
      <slot name="icon" />
    </div>
  )}
  <h3 class="esa-empty-state__title">{title}</h3>
  {description && <p class="esa-empty-state__description">{description}</p>}
  <div class="esa-empty-state__actions">
    <slot />
  </div>
</div>

<style>
  .esa-empty-state {
    --_empty-icon-size: var(--empty-state-icon-size-md);
    --_empty-title-size: 16px;
    --_empty-desc-size: 14px;
    --_empty-gap: var(--empty-state-gap);

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--spacing-600) var(--spacing-400);
    gap: var(--_empty-gap);
  }

  .esa-empty-state--xs {
    --_empty-icon-size: var(--empty-state-icon-size-xs);
    --_empty-title-size: 13px;
    --_empty-desc-size: 11px;
    padding: var(--spacing-300) var(--spacing-200);
  }

  .esa-empty-state--sm {
    --_empty-icon-size: var(--empty-state-icon-size-sm);
    --_empty-title-size: 14px;
    --_empty-desc-size: 12px;
    padding: var(--spacing-400) var(--spacing-300);
  }

  .esa-empty-state--lg {
    --_empty-icon-size: var(--empty-state-icon-size-lg);
    --_empty-title-size: 20px;
    --_empty-desc-size: 16px;
    padding: var(--spacing-800) var(--spacing-400);
  }

  .esa-empty-state__icon {
    color: var(--empty-state-icon-color);
    margin-bottom: var(--spacing-100);
    display: inline-flex;
  }

  .esa-empty-state__icon :global(svg) {
    width: var(--_empty-icon-size);
    height: var(--_empty-icon-size);
  }

  .esa-empty-state__title {
    margin: 0;
    font-size: var(--_empty-title-size);
    font-weight: 600;
    color: var(--empty-state-title-color);
  }

  .esa-empty-state__description {
    margin: 0;
    font-size: var(--_empty-desc-size);
    color: var(--empty-state-description-color);
    max-width: 360px;
  }

  .esa-empty-state__actions {
    margin-top: var(--spacing-200);
  }

  .esa-empty-state__actions:empty {
    display: none;
  }
</style>
