---
// esa-collapsible — presentational (.astro).
//
// A single disclosure section: an icon + title summary over a slotted body, built on
// the native <details>/<summary> element (free a11y, keyboard, and open/close state —
// no JS). The standard disclosure triangle is hidden in favor of a right-aligned caret
// so the icon + title can lead the row.
//
// NET-NEW to the hub (the Angular lib had no accordion/expansion-panel). It was promoted
// up from spoke demand: both the Beacon and CB-Fish spokes hand-rolled the same
// collapsible-section pattern for sidebar/detail groups, so it belongs here as one lego.
// This is a SINGLE disclosure, not a single-open accordion group — compose several for a
// stacked set; each opens independently, matching native <details> semantics.
import EsaIcon from './esa-icon.astro';

interface Props {
  /** Summary label (required). */
  title: string;
  /** Optional leading Lucide icon name (kebab-case). */
  icon?: string;
  /** Inner SVG markup for an icon not in esa-icon's registry (passed through to esa-icon). */
  iconPaths?: string;
  /** Render expanded on load. */
  open?: boolean;
  /** No card chrome (border/radius/background, flush horizontal padding) — for
      stacked drawer/sidebar sections separated by the host's own dividers. */
  flush?: boolean;
}
const { title, icon, iconPaths, open = false, flush = false } = Astro.props;
---

<details class:list={['esa-collapsible', { 'esa-collapsible--flush': flush }]} open={open}>
  <summary class="esa-collapsible__summary">
    {icon && <EsaIcon name={icon} paths={iconPaths} size="sm" />}
    <span class="esa-collapsible__title">{title}</span>
  </summary>
  <div class="esa-collapsible__body"><slot /></div>
</details>

<style>
  .esa-collapsible {
    border: 1px solid var(--collapsible-border-color);
    border-radius: var(--collapsible-radius);
    background: var(--collapsible-bg);
  }
  .esa-collapsible--flush {
    border: none;
    border-radius: 0;
    background: transparent;
  }
  .esa-collapsible--flush > .esa-collapsible__summary,
  .esa-collapsible--flush > .esa-collapsible__body {
    padding-inline: 0;
  }
  .esa-collapsible__summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-200);
    padding: var(--spacing-300) var(--collapsible-padding-x);
    font-size: var(--type-size-150);
    font-weight: var(--font-weight-semibold);
    color: var(--collapsible-title-color);
    cursor: pointer;
    list-style: none;
  }
  /* Hide the native disclosure marker (both engines) so the caret can lead from the right. */
  .esa-collapsible__summary::-webkit-details-marker { display: none; }
  /* Right-aligned chevron caret; rotates when open. */
  .esa-collapsible__summary::after {
    content: '';
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--color-text-tertiary);
    border-bottom: 2px solid var(--color-text-tertiary);
    transform: rotate(-45deg);
    transition: transform 150ms ease;
    margin-left: auto;
  }
  .esa-collapsible[open] > .esa-collapsible__summary::after { transform: rotate(45deg); }

  /* Leading summary glyph — quiet, secondary. */
  .esa-collapsible__summary :global(.esa-icon) { flex-shrink: 0; color: var(--color-text-secondary); }

  .esa-collapsible__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-400);
    padding: 0 var(--collapsible-padding-x) var(--spacing-400);
  }
</style>
