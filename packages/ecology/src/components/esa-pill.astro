---
// esa-pill — presentational (.astro).
// Faithful translation of the Angular esa-pill: required label, color variants,
// size variants, optional leading Lucide icon, and an optional remove button.
// Angular host classes → class list; @if → conditional render. The remove
// interaction (emit + remove from DOM) is handled by a tiny inline script — light
// enough to keep this in the presentational bucket. Pass an inline SVG via the
// "icon" slot for the leading icon.
interface Props {
  label: string;
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'danger' | 'info';
  removable?: boolean;
  size?: 'xs' | 'sm' | 'md' | 'lg';
}
const { label, variant = 'default', removable = true, size = 'md' } = Astro.props;

const hasIconSlot = Astro.slots.has('icon');
const cls = ['esa-pill', `esa-pill--${variant}`, `esa-pill--${size}`].join(' ');
---
<span class={cls}>
  {hasIconSlot && (
    <span class="esa-pill__icon">
      <slot name="icon" />
    </span>
  )}
  <span class="esa-pill__label">{label}</span>
  {removable && (
    <button class="esa-pill__remove" type="button" aria-label="Remove" data-esa-pill-remove>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  )}
</span>

{removable && (
  <script>
    document.querySelectorAll('[data-esa-pill-remove]').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.stopPropagation();
        const pill = (btn as HTMLElement).closest('.esa-pill') as HTMLElement | null;
        if (pill) {
          pill.dispatchEvent(new CustomEvent('removed', { bubbles: true }));
          pill.remove();
        }
      });
    });
  </script>
)}

<style>
  .esa-pill {
    --_pill-bg: var(--pill-bg);
    --_pill-text: var(--pill-text-color);
    --_pill-border: var(--pill-border-color);
    --_pill-height: var(--pill-height-md);
    --_pill-font-size: 13px;
    --_pill-padding-x: var(--spacing-200);
    --_pill-gap: var(--spacing-100);

    display: inline-flex;
    align-items: center;
    gap: var(--_pill-gap);
    height: var(--_pill-height);
    padding-inline: var(--_pill-padding-x);
    border: 1px solid var(--_pill-border);
    border-radius: var(--pill-radius);
    background: var(--_pill-bg);
    color: var(--_pill-text);
    font-size: var(--_pill-font-size);
    line-height: 1;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .esa-pill--xs {
    --_pill-height: var(--pill-height-xs);
    --_pill-font-size: 10px;
    --_pill-padding-x: var(--spacing-100);
  }

  .esa-pill--sm {
    --_pill-height: var(--pill-height-sm);
    --_pill-font-size: 11px;
    --_pill-padding-x: var(--spacing-150);
  }

  .esa-pill--lg {
    --_pill-height: var(--pill-height-lg);
    --_pill-font-size: 14px;
    --_pill-padding-x: var(--spacing-300);
  }

  .esa-pill--primary {
    --_pill-bg: var(--color-primary-subtle);
    --_pill-text: var(--color-primary-strong);
    --_pill-border: var(--color-primary-border);
  }

  .esa-pill--info {
    --_pill-bg: var(--color-info-subtle);
    --_pill-text: var(--color-info-strong);
    --_pill-border: var(--color-info-border);
  }

  .esa-pill--success {
    --_pill-bg: var(--color-success-subtle);
    --_pill-text: var(--color-success-strong);
    --_pill-border: var(--color-success-border);
  }

  .esa-pill--warning {
    --_pill-bg: var(--color-warning-subtle);
    --_pill-text: var(--color-warning-strong);
    --_pill-border: var(--color-warning-border);
  }

  .esa-pill--danger {
    --_pill-bg: var(--color-danger-subtle);
    --_pill-text: var(--color-danger-strong);
    --_pill-border: var(--color-danger-border);
  }

  .esa-pill__icon {
    flex-shrink: 0;
    display: inline-flex;
  }

  .esa-pill__label {
    font-weight: 500;
  }

  .esa-pill__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    padding: 0;
    border: none;
    border-radius: var(--radius-full);
    background: transparent;
    color: inherit;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity var(--transition-fast),
                background var(--transition-fast);
  }

  .esa-pill__remove:hover {
    opacity: 1;
    background: var(--pill-remove-bg-hover);
  }

  .esa-pill__remove:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }
</style>
