---
// esa-pill — presentational (.astro).
// Faithful translation of the Angular esa-pill: required label, color variants,
// size variants, optional leading Lucide icon, and an optional remove button.
// Angular host classes → class list; @if → conditional render. The remove
// interaction (emit + remove from DOM) is handled by a tiny inline script — light
// enough to keep this in the presentational bucket. Pass an inline SVG via the
// "icon" slot for the leading icon.
interface Props {
  label: string;
  /** Accent hue (any Radix ramp) or a semantic tone — drives fill + ring + text
   *  from a single accent context via data-accent. `default` = neutral gray. */
  color?:
    | 'default' | 'gray' | 'blue' | 'copper' | 'gold' | 'grass' | 'green'
    | 'lime' | 'orange' | 'red' | 'teal' | 'yellow'
    | 'accent' | 'brand' | 'primary' | 'neutral' | 'success' | 'warning' | 'danger' | 'info';
  /** @deprecated Use `color`. Kept as an alias so existing markup keeps working. */
  variant?: Props['color'];
  removable?: boolean;
  size?: 'xs' | 'sm' | 'md' | 'lg';
}
const { label, color, variant, removable = true, size = 'md' } = Astro.props;
const tone = color ?? variant ?? 'default';
const accent = tone === 'default' ? 'gray' : tone;

const hasIconSlot = Astro.slots.has('icon');
const cls = ['esa-pill', `esa-pill--${size}`].join(' ');
---
<span class={cls} data-accent={accent}>
  {hasIconSlot && (
    <span class="esa-pill__icon">
      <slot name="icon" />
    </span>
  )}
  <span class="esa-pill__label">{label}</span>
  {removable && (
    <button class="esa-pill__remove" type="button" aria-label="Remove" data-esa-pill-remove>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  )}
</span>

{removable && (
  <script>
    document.querySelectorAll('[data-esa-pill-remove]').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.stopPropagation();
        const pill = (btn as HTMLElement).closest('.esa-pill') as HTMLElement | null;
        if (pill) {
          pill.dispatchEvent(new CustomEvent('removed', { bubbles: true }));
          pill.remove();
        }
      });
    });
  </script>
)}

<style>
  .esa-pill {
    /* Soft tone: a-3 fill, a-6 ring, step-11 text — all from the accent context
       set by data-accent. Swap the hue and all three track it. Component tokens
       still win when a theme wants to force a specific look. */
    --_pill-bg: var(--pill-bg, var(--color-accent-a-3));
    --_pill-text: var(--pill-text-color, var(--color-accent-11));
    --_pill-border: var(--pill-border-color, var(--color-accent-a-6));
    --_pill-height: var(--pill-height-md, 28px);
    --_pill-font-size: 13px;
    --_pill-padding-x: var(--spacing-200, 0.5rem);
    --_pill-gap: var(--spacing-100, 0.25rem);

    display: inline-flex;
    align-items: center;
    gap: var(--_pill-gap);
    height: var(--_pill-height);
    padding-inline: var(--_pill-padding-x);
    box-shadow: inset 0 0 0 1px var(--_pill-border);
    border-radius: var(--pill-radius, var(--radius-full, 9999px));
    background: var(--_pill-bg);
    color: var(--_pill-text);
    font-size: var(--_pill-font-size);
    line-height: 1;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .esa-pill--xs {
    --_pill-height: var(--pill-height-xs, 18px);
    --_pill-font-size: 10px;
    --_pill-padding-x: var(--spacing-100, 0.25rem);
  }

  .esa-pill--sm {
    --_pill-height: var(--pill-height-sm, 22px);
    --_pill-font-size: 11px;
    --_pill-padding-x: var(--spacing-150, 0.375rem);
  }

  .esa-pill--lg {
    --_pill-height: var(--pill-height-lg, 34px);
    --_pill-font-size: 14px;
    --_pill-padding-x: var(--spacing-300, 0.75rem);
  }

  .esa-pill__icon {
    flex-shrink: 0;
    display: inline-flex;
  }

  .esa-pill__label {
    font-weight: 500;
  }

  .esa-pill__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    padding: 0;
    border: none;
    border-radius: var(--radius-full, 9999px);
    background: transparent;
    color: inherit;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity var(--transition-fast, 150ms ease),
                background var(--transition-fast, 150ms ease);
  }

  .esa-pill__remove:hover {
    opacity: 1;
    background: var(--pill-remove-bg-hover, rgba(0, 0, 0, 0.1));
  }

  .esa-pill__remove:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset, 2px);
  }
</style>
