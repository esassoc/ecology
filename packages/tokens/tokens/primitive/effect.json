{
  "shadow": {
    "edge":       { "$value": "0 0 0 1px var(--color-gray-a-5)", "$type": "other", "$description": "Flat surface hairline — a ring-only edge with no lift. The elevation-0 tier (Radix's resting flat card)." },
    "edge-inset": { "$value": "inset 0 0 0 1px var(--color-gray-a-7)", "$type": "other", "$description": "Inset field hairline — the resting edge for form controls and wells (Radix's input ring)." },
    "inset": { "$value": "inset 0 0 0 1px var(--color-gray-a-5), inset 0 1.5px 2px 0 var(--color-gray-a-2), inset 0 1.5px 2px 0 var(--color-black-a-2)", "$type": "other", "$description": "Inset well — sunken fields and pressed surfaces (Radix shadow-1)." },
    "50":  { "$value": "0 0 0 1px var(--color-gray-a-3), 0 0 0 0.5px var(--color-black-a-1), 0 1px 1px 0 var(--color-gray-a-2), 0 2px 1px -1px var(--color-black-a-1), 0 1px 3px 0 var(--color-black-a-1)", "$type": "other", "$description": "Resting lift with hairline ring (Radix shadow-2)." },
    "100": { "$value": "0 0 0 1px var(--color-gray-a-3), 0 2px 3px -2px var(--color-gray-a-3), 0 3px 12px -4px var(--color-black-a-2), 0 4px 16px -8px var(--color-black-a-2)", "$type": "other", "$description": "Cards and list items (Radix shadow-3)." },
    "200": { "$value": "0 0 0 1px var(--color-gray-a-3), 0 8px 40px var(--color-black-a-1), 0 12px 32px -16px var(--color-gray-a-3)", "$type": "other", "$description": "Raised cards, hover state (Radix shadow-4)." },
    "300": { "$value": "0 0 0 1px var(--color-gray-a-3), 0 12px 60px var(--color-black-a-3), 0 12px 32px -16px var(--color-gray-a-5)", "$type": "other", "$description": "Dropdowns, popovers, menus (Radix shadow-5)." },
    "400": { "$value": "0 0 0 1px var(--color-gray-a-3), 0 12px 60px var(--color-black-a-3), 0 16px 64px var(--color-gray-a-2), 0 16px 36px -20px var(--color-gray-a-7)", "$type": "other", "$description": "Modals and dialogs (Radix shadow-6)." }
  },
  "duration": {
    "instant": { "$value": "0ms",   "$type": "other", "$description": "No animation — snaps instantly." },
    "quick":   { "$value": "150ms", "$type": "other", "$description": "Micro-interactions: hover, press, small state flips." },
    "base":    { "$value": "200ms", "$type": "other", "$description": "Default UI transition." },
    "long":    { "$value": "350ms", "$type": "other", "$description": "Larger movements: panels, disclosures, overlays." }
  },
  "easing": {
    "ease":     { "$value": "ease", "$type": "other", "$description": "Built-in ease — asymmetric, starts faster and ends slower than ease-in-out. The house curve for small, gentle animations: hover/state color, background-color, opacity, subtle button transforms, success flourishes." },
    "out":      { "$value": "cubic-bezier(0.215, 0.61, 0.355, 1)",  "$type": "other", "$description": "Decelerate (easeOutCubic) — the default for UI. Enters, exits, reveals (fast start, soft stop)." },
    "in-out":   { "$value": "cubic-bezier(0.645, 0.045, 0.355, 1)",  "$type": "other", "$description": "easeInOutCubic — slow start, speed up, slow finish (like a car). On-screen elements moving to a new position or morphing shape." }
  },
  "transition": {
    "fast": { "$value": "{duration.quick} {easing.ease}", "$type": "other", "$description": "Legacy shorthand — prefer the semantic --motion-* tokens. Equals --motion-ease-quick." },
    "base": { "$value": "{duration.base} {easing.ease}", "$type": "other", "$description": "Legacy shorthand — prefer the semantic --motion-* tokens. Equals --motion-ease-base." },
    "slow": { "$value": "{duration.long} {easing.ease}", "$type": "other", "$description": "Legacy shorthand — prefer the semantic --motion-* tokens. Equals --motion-ease-long." }
  },
  "z": {
    "dropdown":       { "$value": "50",  "$type": "other" },
    "sidebar":        { "$value": "100", "$type": "other" },
    "header":         { "$value": "200", "$type": "other" },
    "modal-backdrop": { "$value": "300", "$type": "other" },
    "modal":          { "$value": "400", "$type": "other" },
    "toast":          { "$value": "500", "$type": "other" },
    "tooltip":        { "$value": "600", "$type": "other" }
  },
  "focus-ring": {
    "color":  { "$value": "{color.primary}", "$type": "color" },
    "width":  { "$value": "2px", "$type": "dimension" },
    "offset": { "$value": "2px", "$type": "dimension" }
  },
  "icon": {
    "size": {
      "xs": { "$value": "14px", "$type": "dimension" },
      "sm": { "$value": "16px", "$type": "dimension" },
      "md": { "$value": "20px", "$type": "dimension" },
      "lg": { "$value": "24px", "$type": "dimension" },
      "xl": { "$value": "28px", "$type": "dimension" }
    }
  },
  "color": {
    "hover-overlay":        { "$value": "rgba(0, 0, 0, 0.03)",   "$type": "color" },
    "hover-overlay-strong": { "$value": "rgba(0, 0, 0, 0.05)",   "$type": "color" },
    "active-overlay":       { "$value": "rgba(0, 88, 98, 0.08)", "$type": "color" },
    "backdrop":             { "$value": "{color.black-a.7}",     "$type": "color" }
  },
  "touch-target": {
    "min": { "$value": "44px", "$type": "dimension" }
  }
}
