{
  "shadow": {
    "50":  { "$value": "0 1px 4px 0 rgba(0, 0, 0, 0.03)",    "$type": "other" },
    "100": { "$value": "0 2px 12px 0 rgba(0, 0, 0, 0.04)",   "$type": "other" },
    "200": { "$value": "0 4px 20px -4px rgba(0, 0, 0, 0.06)","$type": "other" },
    "300": { "$value": "0 6px 24px -6px rgba(0, 0, 0, 0.07)","$type": "other" },
    "400": { "$value": "0 8px 32px -8px rgba(0, 0, 0, 0.08)","$type": "other" }
  },
  "duration": {
    "instant": { "$value": "0ms",   "$type": "other", "$description": "No animation — snaps instantly." },
    "fast":    { "$value": "150ms", "$type": "other", "$description": "Micro-interactions: hover, press, small state flips." },
    "base":    { "$value": "200ms", "$type": "other", "$description": "Default UI transition." },
    "slow":    { "$value": "350ms", "$type": "other", "$description": "Larger movements: panels, disclosures, overlays." }
  },
  "easing": {
    "standard": { "$value": "ease",                        "$type": "other", "$description": "Default curve — general-purpose." },
    "out":      { "$value": "cubic-bezier(0, 0, 0.2, 1)",  "$type": "other", "$description": "Decelerate — enters/appears (fast start, soft stop)." },
    "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",  "$type": "other", "$description": "Accelerate — exits/dismisses (soft start, fast end)." },
    "in-out":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)","$type": "other", "$description": "Symmetric ease — movement that starts and ends on screen." }
  },
  "transition": {
    "fast": { "$value": "{duration.fast} {easing.standard}", "$type": "other", "$description": "Composite shorthand: fast duration + standard easing." },
    "base": { "$value": "{duration.base} {easing.standard}", "$type": "other", "$description": "Composite shorthand: base duration + standard easing." },
    "slow": { "$value": "{duration.slow} {easing.standard}", "$type": "other", "$description": "Composite shorthand: slow duration + standard easing." }
  },
  "z": {
    "dropdown":       { "$value": "50",  "$type": "other" },
    "sidebar":        { "$value": "100", "$type": "other" },
    "header":         { "$value": "200", "$type": "other" },
    "modal-backdrop": { "$value": "300", "$type": "other" },
    "modal":          { "$value": "400", "$type": "other" },
    "toast":          { "$value": "500", "$type": "other" },
    "tooltip":        { "$value": "600", "$type": "other" }
  },
  "focus-ring": {
    "color":  { "$value": "{color.primary}", "$type": "color" },
    "width":  { "$value": "2px", "$type": "dimension" },
    "offset": { "$value": "2px", "$type": "dimension" }
  },
  "icon": {
    "size": {
      "xs": { "$value": "14px", "$type": "dimension" },
      "sm": { "$value": "16px", "$type": "dimension" },
      "md": { "$value": "20px", "$type": "dimension" },
      "lg": { "$value": "24px", "$type": "dimension" },
      "xl": { "$value": "28px", "$type": "dimension" }
    }
  },
  "color": {
    "hover-overlay":        { "$value": "rgba(0, 0, 0, 0.03)",   "$type": "color" },
    "hover-overlay-strong": { "$value": "rgba(0, 0, 0, 0.05)",   "$type": "color" },
    "active-overlay":       { "$value": "rgba(0, 88, 98, 0.08)", "$type": "color" },
    "backdrop":             { "$value": "{color.black-a.7}",     "$type": "color" }
  },
  "touch-target": {
    "min": { "$value": "44px", "$type": "dimension" }
  }
}
