{
  "color": {
    "primary":        { "$value": "{color.grass.9}",  "$type": "color", "$description": "Ecology brand grass. Step 9 = Radix solid fill (the canonical interactive fill hue)." },
    "primary-hover":  { "$value": "{color.grass.10}", "$type": "color", "$description": "Step 10 = Radix hovered solid fill." },
    "primary-active": { "$value": "{color.grass.10}", "$type": "color" },
    "primary-subtle": { "$value": "{color.grass.2}",  "$type": "color", "$description": "Brand-tinted subtle surface — selected states, brand callout tiles. Pairs with primary-border." },
    "primary-border": { "$value": "{color.grass.6}",  "$type": "color", "$description": "Soft brand-tinted border. Step 6 = Radix subtle border." },
    "primary-strong": { "$value": "{color.grass.11}", "$type": "color", "$description": "Step 11 = colored text on surfaces (outline buttons, links). Override in your theme when changing the primary ramp." },
    "secondary":        { "$value": "{color.grass.8}",  "$type": "color" },
    "secondary-hover":  { "$value": "{color.grass.9}",  "$type": "color" },
    "secondary-strong": { "$value": "{color.grass.11}", "$type": "color", "$description": "Step 11 = colored text on surfaces for secondary contexts (outline buttons). Override in your theme when changing the secondary ramp." },
    "accent":          { "$value": "{color.orange.9}",  "$type": "color" },
    "accent-hover":    { "$value": "{color.orange.10}", "$type": "color" },
    "ai":              { "$value": "{color.copper.9}",  "$type": "color" },
    "ai-hover":        { "$value": "{color.copper.10}", "$type": "color" },
    "ai-subtle":       { "$value": "{color.copper.2}",  "$type": "color" },
    "ai-strong":       { "$value": "{color.copper.11}", "$type": "color", "$description": "Step 11 = colored text on surfaces for AI/copper contexts." },

    "background":       { "$value": "{color.gray.2}", "$type": "color" },
    "surface":          { "$value": "{color.gray.1}", "$type": "color" },
    "surface-elevated": { "$value": "{color.gray.1}", "$type": "color" },
    "surface-sunken":   { "$value": "{color.gray.3}", "$type": "color" },
    "surface-inverse":       { "$value": "{color.gray.12}", "$type": "color", "$description": "Darkest chrome surface — top app bars, dark navigation. Pairs with text-inverse. A spoke re-points this to its darkest brand shade." },
    "surface-inverse-hover": { "$value": "{color.gray.11}", "$type": "color", "$description": "Hover/active state for surface-inverse." },

    "text-primary":    { "$value": "{color.gray.12}", "$type": "color" },
    "text-secondary":  { "$value": "{color.gray.11}", "$type": "color" },
    "text-tertiary":   { "$value": "{color.gray.11}", "$type": "color" },
    "text-muted":      { "$value": "{color.gray.10}", "$type": "color" },
    "text-inverse":    { "$value": "{color.gray.1}",  "$type": "color" },
    "text-link":       { "$value": "{color.primary}",       "$type": "color" },
    "text-link-hover": { "$value": "{color.primary-hover}", "$type": "color" },

    "border":        { "$value": "{color.gray.7}", "$type": "color" },
    "border-light":  { "$value": "{color.gray.6}", "$type": "color" },
    "border-strong": { "$value": "{color.gray.8}", "$type": "color" },
    "border-focus":  { "$value": "{color.grass.8}", "$type": "color", "$description": "Step 8 = Radix stronger interactive border / focus ring." },

    "info":          { "$value": "{color.status.info}",    "$type": "color" },
    "info-hover":    { "$value": "{color.blue.10}",        "$type": "color", "$description": "Step 10 = Radix hovered solid." },
    "success":         { "$value": "{color.status.success}", "$type": "color" },
    "success-hover":   { "$value": "{color.lime.10}",       "$type": "color", "$description": "Step 10 = Radix hovered solid." },
    "success-on-fill": { "$value": "{color.lime.12}",       "$type": "color", "$description": "Foreground text on a success (lime) solid fill. Lime is a bright scale — step 9 needs dark text. Override when your success color is not a bright scale." },
    "warning":       { "$value": "{color.status.warning}", "$type": "color" },
    "warning-hover": { "$value": "{color.yellow.10}",      "$type": "color", "$description": "Step 10 = Radix hovered solid." },
    "danger":       { "$value": "{color.red.9}",  "$type": "color", "$description": "Error/destructive intent. Step 9 = Radix solid fill." },
    "danger-hover": { "$value": "{color.red.10}", "$type": "color", "$description": "Step 10 = Radix hovered solid." },

    "info-subtle":    { "$value": "{color.status.info-subtle}",    "$type": "color" },
    "success-subtle": { "$value": "{color.status.success-subtle}", "$type": "color" },
    "warning-subtle": { "$value": "{color.status.warning-subtle}", "$type": "color" },
    "danger-subtle":  { "$value": "{color.red.2}",                 "$type": "color" },

    "info-border":    { "$value": "{color.status.info-border}",    "$type": "color" },
    "success-border": { "$value": "{color.status.success-border}", "$type": "color" },
    "warning-border": { "$value": "{color.status.warning-border}", "$type": "color" },
    "danger-border":  { "$value": "{color.red.6}",                 "$type": "color" },

    "info-strong":    { "$value": "{color.status.info-strong}",    "$type": "color" },
    "success-strong": { "$value": "{color.status.success-strong}", "$type": "color" },
    "warning-strong": { "$value": "{color.status.warning-strong}", "$type": "color" },
    "danger-strong":  { "$value": "{color.red.11}",                "$type": "color" },

    "disabled-bg":     { "$value": "{color.gray.3}", "$type": "color" },
    "disabled-text":   { "$value": "{color.gray.9}", "$type": "color" },
    "disabled-border": { "$value": "{color.gray.6}", "$type": "color" }
  }
}
