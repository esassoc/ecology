{
  "color": {
    "primary":        { "$value": "{color.blue.800}", "$type": "color", "$description": "Ecology brand blue (the network-mark hue, blue-500 #699cc6, at button depth). Replaced the legacy Beacon teal 2026-06-12 — the teal ramp's 50-500 never belonged to its 900. White-on passes AA at 6.4:1." },
    "primary-hover":  { "$value": "{color.blue.900}", "$type": "color" },
    "primary-active": { "$value": "{color.blue.950}", "$type": "color" },
    "primary-subtle": { "$value": "{color.blue.50}",  "$type": "color", "$description": "Brand-tinted subtle surface — selected states, brand callout tiles, control pills. Pairs with primary-border. (Promoted from cb-fish, which needed a brand-tint surface the hub lacked.)" },
    "primary-border": { "$value": "{color.blue.200}", "$type": "color", "$description": "Soft brand-tinted border to pair with primary-subtle. Distinct from border-focus (= primary, a strong focus ring)." },
    "secondary":       { "$value": "{color.blue.600}", "$type": "color" },
    "secondary-hover": { "$value": "{color.blue.800}", "$type": "color" },
    "accent":          { "$value": "{color.orange.400}", "$type": "color" },
    "accent-hover":    { "$value": "{color.orange.500}", "$type": "color" },
    "ai":              { "$value": "{color.copper.600}", "$type": "color" },
    "ai-hover":        { "$value": "{color.copper.700}", "$type": "color" },
    "ai-subtle":       { "$value": "{color.copper.50}",  "$type": "color" },

    "background":       { "$value": "{color.gray.50}",  "$type": "color" },
    "surface":          { "$value": "{color.gray.0}",   "$type": "color" },
    "surface-elevated": { "$value": "{color.gray.0}",   "$type": "color" },
    "surface-sunken":   { "$value": "{color.gray.100}", "$type": "color" },
    "surface-inverse":       { "$value": "{color.gray.900}", "$type": "color", "$description": "Darkest chrome surface — top app bars, dark navigation. Pairs with text-inverse. A spoke re-points this to its darkest brand shade (cb-fish → blue-950). Consumed by esa-app-bar tone=brand-strong." },
    "surface-inverse-hover": { "$value": "{color.gray.800}", "$type": "color", "$description": "Hover/active state for surface-inverse." },

    "text-primary":    { "$value": "{color.gray.900}", "$type": "color" },
    "text-secondary":  { "$value": "{color.gray.600}", "$type": "color" },
    "text-tertiary":   { "$value": "{color.gray.700}", "$type": "color" },
    "text-muted":      { "$value": "{color.gray.500}", "$type": "color" },
    "text-inverse":    { "$value": "{color.gray.0}",   "$type": "color" },
    "text-link":       { "$value": "{color.primary}",  "$type": "color" },
    "text-link-hover": { "$value": "{color.primary-hover}", "$type": "color" },

    "border":        { "$value": "{color.gray.200}", "$type": "color" },
    "border-light":  { "$value": "{color.gray.100}", "$type": "color" },
    "border-strong": { "$value": "{color.gray.300}", "$type": "color" },
    "border-focus":  { "$value": "{color.primary}",  "$type": "color" },

    "info":    { "$value": "{color.status.info}",    "$type": "color" },
    "success": { "$value": "{color.status.success}", "$type": "color" },
    "warning": { "$value": "{color.status.warning}", "$type": "color" },
    "danger":  { "$value": "{color.red.500}",        "$type": "color", "$description": "Error/destructive intent. References the standard red ramp (red-500 == the old literal #ef4444). Kept on color.red rather than color.status because that ramp already exists and matches exactly." },

    "info-subtle":    { "$value": "{color.status.info-subtle}",    "$type": "color" },
    "success-subtle": { "$value": "{color.status.success-subtle}", "$type": "color" },
    "warning-subtle": { "$value": "{color.status.warning-subtle}", "$type": "color" },
    "danger-subtle":  { "$value": "{color.red.50}",                "$type": "color" },

    "info-border":    { "$value": "{color.status.info-border}",    "$type": "color" },
    "success-border": { "$value": "{color.status.success-border}", "$type": "color" },
    "warning-border": { "$value": "{color.status.warning-border}", "$type": "color" },
    "danger-border":  { "$value": "{color.red.200}",               "$type": "color" },

    "info-strong":    { "$value": "{color.status.info-strong}",    "$type": "color", "$description": "Readable dark text to sit on the matching -subtle surface (e.g. status pill text on a tinted bg). Pairs with info-subtle. All three spokes hand-coded this shade before it existed." },
    "success-strong": { "$value": "{color.status.success-strong}", "$type": "color" },
    "warning-strong": { "$value": "{color.status.warning-strong}", "$type": "color" },
    "danger-strong":  { "$value": "{color.red.700}",               "$type": "color" },

    "disabled-bg":     { "$value": "{color.gray.100}", "$type": "color" },
    "disabled-text":   { "$value": "{color.gray.400}", "$type": "color" },
    "disabled-border": { "$value": "{color.gray.200}", "$type": "color" }
  }
}
