---
// Shared docs-site shell for Ecology + its brand spokes. Owns the structure:
// sticky sidebar nav, topbar, centered article, auto-built "On this page" rail
// with scroll-spy. Brand-agnostic — every visual comes from a token (--color-*,
// --font-*), so a consumer re-skins purely by setting `theme` + loading its theme
// CSS. Per-consumer axes are injected, not forked:
//   - theming   → `theme` prop sets data-theme; consumer loads its theme CSS
//   - base path → withBase() (resolves per consuming app via import.meta.env.BASE_URL)
//   - nav       → `groups` prop (each app keeps its own nav data)
//   - brand     → brand* props + the `head` and `topbar-actions` slots
//   - dark mode → `colorScheme: 'toggle'` renders the toggle + scheme wiring;
//                 the dark TOKEN VALUES are the consumer's CSS, not baked here.
import '@esa/tokens/tokens.css';
import '@esa/tokens/component-tokens.css';
import { withBase } from './base';
import type { NavGroup } from './nav';

interface Props {
  title?: string;
  activeHref?: string;          // base-less, e.g. "/design-system/foundations/color"
  groups: NavGroup[];           // sidebar nav data (per-consumer)
  theme?: string;               // data-theme value, e.g. "cb-fish"; omit for hub default
  colorScheme?: 'light' | 'toggle';
  brandMark?: string;           // short text mark, e.g. "CB" or "E"
  brandName?: string;           // e.g. "CB Fish"
  brandTag?: string;            // e.g. "Design System" or a version
  brandHref?: string;           // base-less; sidebar brand links here
}
const {
  title = 'Design System',
  activeHref = '',
  groups,
  theme,
  colorScheme = 'light',
  brandMark = 'E',
  brandName = 'Docs',
  brandTag,
  brandHref = '/',
} = Astro.props;

const showToggle = colorScheme === 'toggle';
---
<!doctype html>
<html lang="en" data-theme={theme} data-scheme={showToggle ? 'light' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {showToggle && (
      <script is:inline>
        const s = localStorage.getItem('docs-scheme') || 'light';
        document.documentElement.setAttribute('data-scheme', s);
      </script>
    )}
    <slot name="head" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--font-sans, system-ui, sans-serif);
        font-size: 16px;
        line-height: 1.6;
        color: var(--color-text-primary, #171717);
        background: var(--color-background, #fafafa);
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }

      /* ---------- App grid ---------- */
      .app { display: grid; grid-template-columns: 264px minmax(0, 1fr); min-height: 100vh; }
      .sidebar {
        position: sticky; top: 0; align-self: start; height: 100vh; overflow-y: auto;
        border-right: 1px solid var(--color-border, #dcdcdc);
        background: var(--color-surface, #fff);
        padding: 0 0 var(--spacing-600, 2rem);
      }
      .brand {
        display: flex; align-items: center; gap: var(--spacing-250, 0.625rem);
        height: 56px; padding: 0 var(--spacing-400, 1rem);
        position: sticky; top: 0; z-index: 1;
        background: var(--color-surface, #fff);
        border-bottom: 1px solid var(--color-border, #dcdcdc);
      }
      .brand .mark {
        width: 26px; height: 26px; border-radius: 7px;
        background: var(--color-primary, #1e5386);
        display: grid; place-items: center;
        color: #fff; font-weight: 700; font-size: 12px; letter-spacing: 0.02em;
      }
      /* Consumer-supplied inline logo (via the brand-mark slot) in place of the lettered square. */
      .brand .brand-mark-slot { display: inline-flex; width: 30px; height: 30px; flex: none; }
      .brand .brand-mark-slot :global(svg) { width: 100%; height: 100%; display: block; }
      .brand b { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; }
      .brand .ver { font-size: 12px; color: var(--color-text-muted, #7c7c7c); }

      .nav { padding: var(--spacing-400, 1rem) var(--spacing-300, 0.75rem) 0; }
      .nav-group { margin-bottom: var(--spacing-500, 1.5rem); }
      .nav-group > h4 {
        margin: 0 0 var(--spacing-150, 0.375rem);
        padding: 0 var(--spacing-300, 0.75rem);
        font-size: 14px; font-weight: 600;
        color: var(--color-text-secondary, #525252);
      }
      .nav-group ul { list-style: none; margin: 0; padding: 0; }
      .nav-link {
        display: flex; align-items: center; justify-content: space-between;
        padding: 6px var(--spacing-300, 0.75rem);
        margin: 1px 0; border-radius: 7px;
        font-size: 14.5px; color: var(--color-text-secondary, #525252);
        transition: background 120ms ease, color 120ms ease;
      }
      .nav-link:hover { background: var(--color-surface-sunken, #f3f7fc); color: var(--color-text-primary, #171717); }
      .nav-link[aria-current='page'] {
        background: color-mix(in srgb, var(--color-primary, #1e5386) 10%, transparent);
        color: var(--color-primary, #1e5386); font-weight: 600;
      }
      .nav-link .tag {
        font-size: 11px; font-family: var(--font-mono, monospace);
        color: var(--color-text-muted, #7c7c7c);
        border: 1px solid var(--color-border, #dcdcdc);
        border-radius: 5px; padding: 0 5px; line-height: 16px;
      }

      /* ---------- Topbar ---------- */
      .main { min-width: 0; }
      .topbar {
        position: sticky; top: 0; z-index: 5; height: 56px;
        display: flex; align-items: center; gap: var(--spacing-400, 1rem);
        padding: 0 var(--spacing-600, 2rem);
        border-bottom: 1px solid var(--color-border, #dcdcdc);
        background: color-mix(in srgb, var(--color-background, #fafafa) 80%, transparent);
        backdrop-filter: saturate(1.2) blur(8px);
      }
      .search {
        display: flex; align-items: center; gap: var(--spacing-200, 0.5rem);
        width: 280px; max-width: 40%;
        padding: 7px var(--spacing-300, 0.75rem);
        border: 1px solid var(--color-border, #dcdcdc); border-radius: 9px;
        color: var(--color-text-muted, #7c7c7c); font-size: 14px; cursor: text;
        background: var(--color-surface, #fff);
        font-family: inherit; text-align: left;
      }
      .search:hover { border-color: var(--color-primary-border, #c6dcf1); }
      .search kbd {
        margin-left: auto; font-family: var(--font-mono, monospace); font-size: 11px;
        border: 1px solid var(--color-border, #dcdcdc); border-radius: 5px;
        padding: 1px 5px; color: var(--color-text-muted, #7c7c7c);
      }
      .topbar .spacer { flex: 1; }
      /* Generic style for consumer-slotted topbar actions (back-links, GitHub, etc.) */
      .topbar-action {
        display: inline-flex; align-items: center; gap: var(--spacing-150, 0.375rem);
        font-size: 14px; color: var(--color-text-secondary, #525252);
        padding: 7px var(--spacing-300, 0.75rem);
        border: 1px solid var(--color-border, #dcdcdc); border-radius: 9px;
        background: var(--color-surface, #fff);
      }
      .topbar-action:hover { color: var(--color-primary, #1e5386); border-color: var(--color-primary-border, #c6dcf1); }
      .scheme-toggle {
        display: grid; place-items: center; width: 34px; height: 34px;
        border: 1px solid var(--color-border, #dcdcdc); border-radius: 9px;
        background: var(--color-surface, #fff); color: var(--color-text-secondary, #525252); cursor: pointer;
      }
      .scheme-toggle:hover { color: var(--color-text-primary, #171717); }

      /* ---------- Content + TOC ---------- */
      .content-wrap {
        display: grid; grid-template-columns: minmax(0, 1fr) 220px;
        gap: var(--spacing-700, 3rem); max-width: 1100px; margin: 0 auto;
        padding: var(--spacing-700, 3rem) var(--spacing-600, 2rem) var(--spacing-900, 6rem);
      }
      .article { min-width: 0; }
      .toc { position: sticky; top: 80px; align-self: start; height: fit-content; }
      .toc h5 { margin: 0 0 var(--spacing-250, 0.625rem); font-size: 14px; font-weight: 600; color: var(--color-text-secondary, #525252); }
      .toc ul { list-style: none; margin: 0; padding: 0; }
      .toc a { display: block; padding: 4px 0 4px 12px; margin-left: -2px; font-size: 14px; color: var(--color-text-muted, #7c7c7c); border-left: 2px solid transparent; transition: color 120ms ease, border-color 120ms ease; }
      .toc a:hover, .toc a.active { color: var(--color-text-primary, #171717); border-color: var(--color-primary, #1e5386); }

      @media (max-width: 1080px) { .content-wrap { grid-template-columns: minmax(0, 1fr); } .toc { display: none; } }
      @media (max-width: 760px) { .app { grid-template-columns: 1fr; } .sidebar { display: none; } }

      /* ---------- Shared content typography ---------- */
      .article h1 { font-family: var(--font-display, var(--font-sans)); font-size: 34px; font-weight: 600; letter-spacing: -0.02em; margin: 0 0 var(--spacing-200, 0.5rem); line-height: 1.2; }
      .article .lede { font-size: 18px; color: var(--color-text-secondary, #525252); margin: 0 0 var(--spacing-600, 2rem); line-height: 1.55; }
      .article h2 { font-size: 22px; font-weight: 600; letter-spacing: -0.01em; color: var(--color-primary, #1e5386); margin: var(--spacing-700, 3rem) 0 var(--spacing-300, 0.75rem); padding-bottom: var(--spacing-200, 0.5rem); border-bottom: 1px solid var(--color-border, #dcdcdc); scroll-margin-top: 76px; }
      .article h3 { font-size: 16px; font-weight: 600; margin: var(--spacing-500, 1.5rem) 0 var(--spacing-250, 0.625rem); color: var(--color-text-primary, #171717); }
      .article p { color: var(--color-text-secondary, #525252); }
      .article code { font-family: var(--font-mono, monospace); font-size: 0.875em; background: var(--color-surface-sunken, #f3f7fc); padding: 0.12em 0.4em; border-radius: 5px; color: var(--color-text-primary, #171717); }

      /* ---------- Shared page header ---------- */
      .crumbs { display: flex; gap: 8px; align-items: center; font-size: 14px; color: var(--color-text-muted, #7c7c7c); margin-bottom: var(--spacing-300, 0.75rem); }
      .crumbs a:hover { color: var(--color-text-primary, #171717); }
      .meta-row { display: flex; align-items: center; gap: var(--spacing-250, 0.625rem); flex-wrap: wrap; margin-bottom: var(--spacing-600, 2rem); }
      .pill { font-size: 12.5px; font-weight: 500; padding: 2px 9px; border-radius: 999px; border: 1px solid var(--color-border, #dcdcdc); color: var(--color-text-secondary, #525252); }
      .pill--stable { color: var(--color-success-strong, #1a9b54); border-color: var(--color-success-border); background: var(--color-success-subtle); }
      .imp { font-family: var(--font-mono, monospace); font-size: 13px; color: var(--color-text-muted, #7c7c7c); background: var(--color-surface-sunken, #f3f7fc); padding: 4px 10px; border-radius: 7px; }
    </style>
  </head>
  <body>
    <div class="app">
      <aside class="sidebar">
        <a class="brand" href={withBase(brandHref)}>
          {Astro.slots.has('brand-mark')
            ? <span class="brand-mark-slot"><slot name="brand-mark" /></span>
            : <span class="mark">{brandMark}</span>}
          <b>{brandName}</b>
          {brandTag && <span class="ver">{brandTag}</span>}
        </a>
        <nav class="nav" aria-label="Documentation">
          {groups.map((group) => (
            <div class="nav-group">
              <h4>{group.label}</h4>
              <ul>
                {group.items.map((item) => (
                  <li>
                    <a
                      class="nav-link"
                      href={withBase(item.href)}
                      aria-current={item.href === activeHref ? 'page' : undefined}
                    >
                      <span>{item.label}</span>
                      {item.status === 'reference' && <span class="tag">ref</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <div class="main">
        <header class="topbar">
          <button class="search" id="search-trigger" type="button" aria-label="Search documentation"><span>Search…</span><kbd>⌘K</kbd></button>
          <div class="spacer"></div>
          {showToggle && (
            <button class="scheme-toggle" id="scheme-toggle" type="button" aria-label="Toggle color scheme" title="Toggle light / dark">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ico-sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ico-moon" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
          )}
          <slot name="topbar-actions" />
        </header>

        <div class="content-wrap">
          <article class="article">
            <slot />
          </article>
          <aside class="toc" id="page-toc" aria-label="On this page" hidden>
            <h5>On this page</h5>
            <ul></ul>
          </aside>
        </div>
      </div>
    </div>

    <slot name="cmd-overlay" />

    {showToggle && (
      <script>
        const root = document.documentElement;
        const btn = document.getElementById('scheme-toggle');
        const sun = btn?.querySelector('.ico-sun') as HTMLElement | null;
        const moon = btn?.querySelector('.ico-moon') as HTMLElement | null;
        const paint = () => {
          const dark = root.getAttribute('data-scheme') === 'dark';
          if (sun) sun.style.display = dark ? 'none' : '';
          if (moon) moon.style.display = dark ? '' : 'none';
        };
        paint();
        btn?.addEventListener('click', () => {
          const next = root.getAttribute('data-scheme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-scheme', next);
          localStorage.setItem('docs-scheme', next);
          paint();
        });
      </script>
    )}

    <script>
      // Auto-build "On this page" from section headings, then scroll-spy.
      const toc = document.getElementById('page-toc');
      const headings = Array.from(document.querySelectorAll('.article h2[id]')) as HTMLElement[];
      if (toc && headings.length) {
        const ul = toc.querySelector('ul') as HTMLUListElement;
        const links = headings.map((h) => {
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          a.setAttribute('data-toc', h.id);
          const li = document.createElement('li');
          li.appendChild(a);
          ul.appendChild(li);
          return a;
        });
        toc.hidden = false;
        const map = new Map(links.map((l) => [l.getAttribute('data-toc'), l]));
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              links.forEach((l) => l.classList.remove('active'));
              map.get(e.target.id)?.classList.add('active');
            }
          });
        }, { rootMargin: '-76px 0px -70% 0px' });
        headings.forEach((h) => obs.observe(h));
      } else {
        document.querySelector('.content-wrap')?.classList.add('no-toc');
      }
    </script>
  </body>
</html>
