---
import PropsTable from './PropsTable.astro';
interface Row { name: string; type: string; default?: string; description: string }
interface Props { props?: Row[]; events?: Row[] }
const { props = [], events = [] } = Astro.props;
---
{props.length > 0 && <PropsTable rows={props} nameHeader="Prop" />}
{events.length > 0 && (
  <>
    <h3 class="api-sub">Events</h3>
    <PropsTable rows={events} nameHeader="Event" />
  </>
)}

<style>
  .api-sub { font-size: 16px; font-weight: 600; margin: var(--spacing-400) 0 var(--spacing-250); color: var(--color-text-primary); }
</style>
