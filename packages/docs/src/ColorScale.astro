---
// A labeled ramp of color chips. Each step paints from either a literal `value`
// (accurate whether or not the color is wired as a token) or a `token` suffix
// (painted live via var(--token) — nice for a theme-driven ramp). Supply one;
// `value` wins if both are given. The token, if present, is the hover title.
interface Step { step: string; value?: string; token?: string }
interface Props { name: string; steps: Step[] }
const { name, steps } = Astro.props;
const paint = (s: Step) => s.value ?? `var(--${s.token})`;
---
<div class="scale">
  <div class="scale__name">{name}</div>
  <div class="scale__row">
    {steps.map((s) => (
      <div class="chip" title={s.token ? `--${s.token}` : s.value}>
        <div class="chip__swatch" style={`background: ${paint(s)}`}></div>
        <div class="chip__step">{s.step}</div>
      </div>
    ))}
  </div>
</div>

<style>
  .scale { margin-bottom: var(--spacing-500); }
  .scale__name { font-size: 14px; font-weight: 600; color: var(--color-text-primary); margin-bottom: var(--spacing-200); }
  .scale__row { display: grid; grid-template-columns: repeat(auto-fit, minmax(56px, 1fr)); gap: var(--spacing-150); }
  .chip__swatch {
    height: 52px; border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--color-text-primary) 8%, transparent);
  }
  .chip__step { font-size: 12px; font-family: var(--font-mono); color: var(--color-text-muted); margin-top: 5px; text-align: center; }
</style>
