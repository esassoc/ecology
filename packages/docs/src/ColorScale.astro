---
// A labeled ramp of color chips. Each step paints from a literal value (so it's
// accurate whether or not the color is wired as a live token) and shows its step
// number; the optional token name is the title on hover.
interface Step { step: string; value: string; token?: string }
interface Props { name: string; steps: Step[] }
const { name, steps } = Astro.props;
---
<div class="scale">
  <div class="scale__name">{name}</div>
  <div class="scale__row">
    {steps.map((s) => (
      <div class="chip" title={s.token ? `--${s.token}` : s.value}>
        <div class="chip__swatch" style={`background: ${s.value}`}></div>
        <div class="chip__step">{s.step}</div>
      </div>
    ))}
  </div>
</div>

<style>
  .scale { margin-bottom: var(--spacing-500, 1.5rem); }
  .scale__name { font-size: 14px; font-weight: 600; color: var(--color-text-primary, #171717); margin-bottom: var(--spacing-200, 0.5rem); }
  .scale__row { display: grid; grid-template-columns: repeat(auto-fit, minmax(56px, 1fr)); gap: var(--spacing-150, 0.375rem); }
  .chip__swatch {
    height: 52px; border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--color-text-primary, #000) 8%, transparent);
  }
  .chip__step { font-size: 12px; font-family: var(--font-mono, monospace); color: var(--color-text-muted, #7c7c7c); margin-top: 5px; text-align: center; }
</style>
