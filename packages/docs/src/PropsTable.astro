---
interface Row { name: string; type: string; default?: string; description: string }
interface Props { rows: Row[]; nameHeader?: string }
const { rows, nameHeader = 'Prop' } = Astro.props;
---
<div class="props">
  <table>
    <thead>
      <tr><th>{nameHeader}</th><th>Type</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr>
          <td><code>{r.name}</code></td>
          <td><code class="type">{r.type}</code></td>
          <td>{r.default ? <code class="def">{r.default}</code> : <span class="dash">—</span>}</td>
          <td>{r.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .props { border: 1px solid var(--color-border); border-radius: 12px; overflow: hidden; margin-bottom: var(--spacing-300); }
  table { width: 100%; border-collapse: collapse; font-size: 14.5px; }
  thead th {
    text-align: left; font-weight: 600; color: var(--color-text-secondary);
    font-size: 13px; padding: 10px var(--spacing-400);
    background: var(--color-surface-sunken);
    border-bottom: 1px solid var(--color-border);
  }
  tbody td { padding: 11px var(--spacing-400); border-bottom: 1px solid var(--color-border-light); vertical-align: top; color: var(--color-text-secondary); }
  tbody tr:last-child td { border-bottom: 0; }
  td code { font-family: var(--font-mono); font-size: 13px; background: var(--color-surface-sunken); padding: 1px 6px; border-radius: 5px; color: var(--color-text-primary); }
  td code.type { background: none; padding: 0; color: var(--color-primary); }
  td code.def { background: none; padding: 0; color: var(--color-text-muted); }
  .dash { color: var(--color-text-muted); }
</style>
