---
// Drop-in Typography foundation body. Families + weights are brand-specific (a
// spoke swaps the face); the size scale is invariant. All three render their
// samples through the live tokens and label themselves from the active theme.
import Section from './Section.astro';
import { typeFamilies, typeWeights, typeSizes } from './tokens';
import { withBase } from './base';

interface Props { brand?: string; brandHref?: string }
const { brand, brandHref = '/design-system' } = Astro.props;
const sample = 'The quick brown fox jumps over the lazy dog';
---
{brand && (
  <nav class="crumbs">
    <a href={withBase(brandHref)}>{brand}</a> <span>/</span> <span>Foundations</span> <span>/</span> <span>Typography</span>
  </nav>
)}
<h1>Typography</h1>
<p class="lede">
  The type families, weights and scale this theme ships. Samples render in the live face;
  families and the fluid <code>--type-size-*</code> scale read straight from the active theme.
</p>

<Section id="families" title="Type families">
  {typeFamilies.map((f) => (
    <div class="fam">
      <div class="fam__sample" style={`font-family: var(--${f.token});`}>{sample}</div>
      <div class="fam__meta">
        <code>--{f.token}</code> · <span data-token-value={f.token} data-token-font>—</span>
        {f.note && <span> · {f.note}</span>}
      </div>
    </div>
  ))}
</Section>

<Section id="scale" title="Type scale">
  <p>Each row renders at its real fluid token; the px shown is the used size at this viewport.</p>
  <div class="scale">
    {typeSizes.map((token) => (
      <div class="row">
        <div class="row__meta">
          <code>--{token}</code>
          <span class="row__px" data-token-px={token}>—</span>
        </div>
        <div class="row__sample" style={`font-size: var(--${token});`}>{sample}</div>
      </div>
    ))}
  </div>
</Section>

<Section id="weights" title="Weights">
  <div class="weights">
    {typeWeights.map((w) => (
      <div class="wt">
        <div class="wt__sample" style={`font-weight: var(--${w.token});`}>Ag</div>
        <code>--{w.token}</code>
        <span class="wt__val" data-token-value={w.token}>—</span>
      </div>
    ))}
  </div>
</Section>

<script>import './foundation-hydrate';</script>

<style>
  .fam { padding: var(--spacing-400, 1rem) 0; border-bottom: 1px solid var(--color-border-light, #efefef); }
  .fam:last-child { border-bottom: 0; }
  .fam__sample { font-size: 28px; color: var(--color-text-primary, #171717); line-height: 1.3; }
  .fam__meta { margin-top: var(--spacing-200, 0.5rem); font-size: 13.5px; color: var(--color-text-muted, #7c7c7c); }
  .fam__meta code { font-family: var(--font-mono, monospace); }

  .scale { display: flex; flex-direction: column; }
  .row { display: grid; grid-template-columns: 200px minmax(0, 1fr); gap: var(--spacing-500, 1.5rem); align-items: baseline; padding: var(--spacing-400, 1rem) 0; border-bottom: 1px solid var(--color-border-light, #efefef); }
  .row:last-child { border-bottom: 0; }
  .row__meta { display: flex; flex-direction: column; gap: 1px; }
  .row__meta code { font-family: var(--font-mono, monospace); font-size: 12.5px; color: var(--color-text-primary, #171717); }
  .row__px { font-family: var(--font-mono, monospace); font-size: 12px; color: var(--color-text-muted, #7c7c7c); }
  .row__sample { color: var(--color-text-primary, #171717); min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .weights { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: var(--spacing-400, 1rem); }
  .wt { display: flex; flex-direction: column; gap: 2px; padding: var(--spacing-400, 1rem); border: 1px solid var(--color-border, #dcdcdc); border-radius: 10px; }
  .wt__sample { font-size: 30px; color: var(--color-text-primary, #171717); line-height: 1.2; }
  .wt code { font-family: var(--font-mono, monospace); font-size: 12.5px; color: var(--color-text-secondary, #525252); margin-top: var(--spacing-200, 0.5rem); }
  .wt__val { font-size: 12px; color: var(--color-text-muted, #7c7c7c); }

  @media (max-width: 560px) { .row { grid-template-columns: 1fr; gap: var(--spacing-200, 0.5rem); } }
</style>
