---
// Drop-in Radius foundation body. Corner-rounding scale, inherited unchanged.
// Each swatch rounds with its real token; the value label hydrates live.
import Section from './Section.astro';
import { radiusScale } from './tokens';
import { withBase } from './base';

interface Props { brand?: string; brandHref?: string }
const { brand, brandHref = '/design-system' } = Astro.props;
---
{brand && (
  <nav class="crumbs">
    <a href={withBase(brandHref)}>{brand}</a> <span>/</span> <span>Foundations</span> <span>/</span> <span>Radius</span>
  </nav>
)}
<h1>Radius</h1>
<p class="lede">
  Corner-rounding tokens, from a barely-there hairline to fully circular. Pick by element
  scale — small controls round tightly, large surfaces round softly.
</p>

<Section id="scale" title="Radius scale">
  <p>Each swatch is rendered with its actual token on all four corners.</p>
  <div class="grid">
    {radiusScale.map((r) => (
      <div class="cell">
        <div class="cell__swatch" style={`border-radius: var(--${r.token})`}></div>
        <div class="cell__meta">
          <code>--{r.token}</code>
          <span class="cell__value" data-token-value={r.token}>—</span>
          {r.note && <span class="cell__role">{r.note}</span>}
        </div>
      </div>
    ))}
  </div>
</Section>

<Section id="usage" title="Usage">
  <p>Match radius to element size — a sharp input nested inside a soft card reads as intentional layering.</p>
  <pre class="snippet"><code>{`.button { border-radius: var(--radius-200); }
.card   { border-radius: var(--radius-400); }
.avatar { border-radius: var(--radius-full); }`}</code></pre>
</Section>

<script>import './foundation-hydrate';</script>

<style>
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--spacing-400, 1rem); }
  .cell { border: 1px solid var(--color-border, #dcdcdc); border-radius: 10px; padding: var(--spacing-400, 1rem); }
  .cell__swatch { width: 100%; height: 88px; background: var(--color-primary-subtle, #f3f7fc); border: 1.5px solid var(--color-primary, #1e5386); margin-bottom: var(--spacing-300, 0.75rem); }
  .cell__meta { display: flex; flex-direction: column; gap: 2px; }
  .cell__meta code { font-family: var(--font-mono, monospace); font-size: 12.5px; color: var(--color-text-primary, #171717); }
  .cell__value { font-family: var(--font-mono, monospace); font-size: 12.5px; color: var(--color-text-secondary, #525252); }
  .cell__role { font-size: 12.5px; color: var(--color-text-muted, #7c7c7c); }

  .snippet { background: var(--color-surface-sunken, #f3f7fc); border: 1px solid var(--color-border, #dcdcdc); border-radius: 10px; padding: var(--spacing-400, 1rem) var(--spacing-500, 1.5rem); overflow-x: auto; }
  .snippet code { font-family: var(--font-mono, monospace); font-size: 13.5px; line-height: 1.7; color: var(--color-text-primary, #171717); background: none; padding: 0; }
</style>
