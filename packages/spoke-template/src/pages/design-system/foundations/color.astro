---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import ColorFoundation from '@esa/docs/ColorFoundation.astro';

// The semantic roles + their live values come from @esa/docs and read from the
// active theme at runtime. The only spoke-specific part is this spoke's own
// primitive ramp(s) — pass them via the `ramps` prop.
---
<DocsLayout title="Color — __SPOKE_NAME__" activeHref="/design-system/foundations/color">
  {/* TODO(spoke-init): pass this spoke's primitive ramp(s), e.g.
      ramps={[{ name: 'Warm gray — neutrals', steps: [{ step: '0', token: '__SCOPE__-gray-0' }, ...] }]} */}
  <ColorFoundation brand="__SPOKE_NAME__" />
</DocsLayout>
